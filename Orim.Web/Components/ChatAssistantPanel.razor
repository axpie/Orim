@using Orim.Web.Services
@inject DiagramAssistantService AssistantService
@inject IJSRuntime JS
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Localizer

<div class="orim-chat-panel @(_isOpen ? "open" : "") @(DockLeftOfProperties ? "dock-left-of-properties" : "")"
    @onmousedown:stopPropagation="true"
    @onclick:stopPropagation="true"
    @onkeydown:stopPropagation="true">
    <div class="orim-chat-header">
        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
        <MudText Typo="Typo.subtitle2" Style="font-weight: 600; flex: 1;">@Localizer["DiagramAssistant"]</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       Size="Size.Small"
                       OnClick="@Close" />
    </div>

    <div class="orim-chat-messages" @ref="_messagesContainer">
        @if (_messages.Count == 0)
        {
            <div class="orim-chat-empty">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="font-size: 40px; opacity: 0.3;" />
                <MudText Typo="Typo.body2" Style="opacity: 0.5; text-align: center; margin-top: 8px;">
                    @Localizer["ChatAssistantWelcome"]
                </MudText>
            </div>
        }
        else
        {
            @foreach (var msg in _messages)
            {
                <div class="orim-chat-message @(msg.Role == "user" ? "user" : "assistant")">
                    @if (msg.Role == "assistant" && msg.IsToolAction)
                    {
                        <div class="orim-chat-tool-action">
                            <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small" />
                            <span>@msg.Content</span>
                        </div>
                    }
                    else
                    {
                        <div class="orim-chat-bubble @msg.Role">
                            @((MarkupString)FormatContent(msg.Content))
                        </div>
                    }
                </div>
            }

            @if (_isProcessing)
            {
                <div class="orim-chat-message assistant">
                    <div class="orim-chat-bubble assistant">
                        <div class="orim-chat-typing">
                            <span></span><span></span><span></span>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="orim-chat-input-area">
        @if (!AssistantService.IsConfigured)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2" Style="font-size: 12px;">
                @Localizer["ChatAssistantNotConfigured"]
            </MudAlert>
        }
        <div class="orim-chat-input-row">
            <MudTextField @bind-Value="_userInput"
                          Placeholder="@Localizer["ChatInputPlaceholder"]"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          Disabled="@(_isProcessing || !AssistantService.IsConfigured)"
                          OnKeyDown="@HandleInputKeyDown"
                          Style="flex: 1;" />
            <MudIconButton Icon="@Icons.Material.Filled.Send"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="@(_isProcessing || string.IsNullOrWhiteSpace(_userInput) || !AssistantService.IsConfigured)"
                           OnClick="@SendMessageAsync" />
        </div>
    </div>
</div>

@code {
    [Parameter] public Board? Board { get; set; }
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public bool DockLeftOfProperties { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnBoardChanged { get; set; }

    private bool _isOpen;
    private string _userInput = "";
    private bool _isProcessing;
    private readonly List<ChatDisplayMessage> _messages = [];
    private ElementReference _messagesContainer;
    private bool _shouldScrollToBottom;

    protected override void OnParametersSet()
    {
        _isOpen = IsOpen;

        if (_isOpen && (_messages.Count > 0 || _isProcessing))
        {
            _shouldScrollToBottom = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_shouldScrollToBottom || !_isOpen)
        {
            return;
        }

        _shouldScrollToBottom = false;
        await JS.InvokeVoidAsync("orimWhiteboard.scrollElementToBottom", _messagesContainer);
    }

    private async Task Close()
    {
        _isOpen = false;
        await OnClose.InvokeAsync();
    }

    private async Task HandleInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !_isProcessing && !string.IsNullOrWhiteSpace(_userInput))
        {
            await SendMessageAsync();
        }
    }

    private async Task SendMessageAsync()
    {
        if (Board is null || string.IsNullOrWhiteSpace(_userInput) || _isProcessing)
            return;

        var userMessage = _userInput.Trim();
        _userInput = "";
        _messages.Add(new ChatDisplayMessage("user", userMessage));
        _isProcessing = true;
        _shouldScrollToBottom = true;
        StateHasChanged();

        var history = _messages
            .Where(m => !m.IsToolAction)
            .Select(m => new ChatMessageEntry { Role = m.Role, Content = m.Content })
            .ToList();

        var responseText = "";
        var elementCount = 0;
        var boardChanged = false;

        try
        {
            await foreach (var evt in AssistantService.StreamDiagramAsync(Board, history))
            {
                switch (evt.Type)
                {
                    case EventType.ElementAdded:
                        elementCount++;
                        boardChanged = true;
                        _messages.Add(new ChatDisplayMessage("assistant", $"Element #{elementCount} added", isToolAction: true));
                        _shouldScrollToBottom = true;
                        StateHasChanged();
                        break;

                    case EventType.ElementUpdated:
                        boardChanged = true;
                        _messages.Add(new ChatDisplayMessage("assistant", "Element updated", isToolAction: true));
                        _shouldScrollToBottom = true;
                        StateHasChanged();
                        break;

                    case EventType.ElementRemoved:
                        boardChanged = true;
                        _messages.Add(new ChatDisplayMessage("assistant", "Element removed", isToolAction: true));
                        _shouldScrollToBottom = true;
                        StateHasChanged();
                        break;

                    case EventType.BoardCleared:
                        boardChanged = true;
                        _messages.Add(new ChatDisplayMessage("assistant", "Board cleared", isToolAction: true));
                        _shouldScrollToBottom = true;
                        StateHasChanged();
                        break;

                    case EventType.Message:
                        responseText += evt.Content;
                        break;

                    case EventType.Error:
                        _messages.Add(new ChatDisplayMessage("assistant", $"⚠ {evt.Content}"));
                        _shouldScrollToBottom = true;
                        StateHasChanged();
                        break;
                }
            }
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatDisplayMessage("assistant", $"⚠ Error: {ex.Message}"));
            _shouldScrollToBottom = true;
        }

        if (!string.IsNullOrWhiteSpace(responseText))
        {
            _messages.Add(new ChatDisplayMessage("assistant", responseText));
            _shouldScrollToBottom = true;
        }

        if (boardChanged)
        {
            await OnBoardChanged.InvokeAsync();
        }

        _isProcessing = false;
        _shouldScrollToBottom = true;
        StateHasChanged();
    }

    private static string FormatContent(string content)
    {
        return System.Web.HttpUtility.HtmlEncode(content)
            .Replace("\n", "<br />");
    }

    private sealed class ChatDisplayMessage(string role, string content, bool isToolAction = false)
    {
        public string Role { get; } = role;
        public string Content { get; } = content;
        public bool IsToolAction { get; } = isToolAction;
    }
}
