@inherits LayoutComponentBase
@using System.Globalization
@using Orim.Web.Services
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Localizer
@inject IJSRuntime JS
@inject ThemeManager ThemeManager

<ThemeShell>
    <MudLayout>
        <MudAppBar Elevation="1" Class="orim-appbar">
            @if (!IsBoardEditorRoute)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                               OnClick="@ToggleDrawer" />
            }
            <a href="/" class="orim-brand-link" aria-label="ORIM Startseite">
                <OrimLogo Class="orim-logo--appbar" />
            </a>
            <MudSpacer />
            <AuthorizeView>
                <Authorized>
                    <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit"
                             AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <MudMenuItem Disabled="true">
                            @context.User.Identity?.Name
                        </MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Settings" OnClick="@OpenUserSettingsDialog">
                            @Localizer["Settings"]
                        </MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Href="/api/auth/logout" ForceLoad="true">
                            @Localizer["Logout"]
                        </MudMenuItem>
                    </MudMenu>
                </Authorized>
            </AuthorizeView>
        </MudAppBar>

        @if (!IsBoardEditorRoute)
        {
            <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Mini"
                       Class="orim-drawer">
                <MudNavMenu Color="Color.Primary">
                    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard"
                                Class="orim-nav-link">
                        @Localizer["Dashboard"]
                    </MudNavLink>
                    <AuthorizeView Roles="Admin">
                        <Authorized>
                            <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People"
                                        Class="orim-nav-link">
                                @Localizer["Users"]
                            </MudNavLink>
                            <MudNavLink Href="/admin/settings" Icon="@Icons.Material.Filled.Palette"
                                        Class="orim-nav-link">
                                @Localizer["OrimSettings"]
                            </MudNavLink>
                        </Authorized>
                    </AuthorizeView>
                </MudNavMenu>
            </MudDrawer>
        }

        <MudMainContent Class="pt-16 orim-main-content">
            @Body
        </MudMainContent>
    </MudLayout>
</ThemeShell>

<MudDialog @bind-Visible="_userSettingsDialogVisible">
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["Settings"]</MudText>
        <MudStack Row="false" Spacing="2" Class="mt-4">
            <div>
                <MudText Typo="Typo.subtitle2">@Localizer["Language"]</MudText>
                <MudText Typo="Typo.body2" Class="orim-board-muted-text">@Localizer["LanguageSettingsDescription"]</MudText>
            </div>
            <MudSelect T="string"
                       @bind-Value="_settingsLanguage"
                       Variant="Variant.Outlined"
                       Label="@Localizer["Language"]">
                <MudSelectItem Value='@("de")'>@Localizer["LanguageGerman"]</MudSelectItem>
                <MudSelectItem Value='@("en")'>@Localizer["LanguageEnglish"]</MudSelectItem>
            </MudSelect>

            <div class="mt-2">
                <MudText Typo="Typo.subtitle2">@Localizer["Theme"]</MudText>
                <MudText Typo="Typo.body2" Class="orim-board-muted-text">@Localizer["ThemeSettingsDescription"]</MudText>
            </div>
            <MudSelect T="string"
                       @bind-Value="_settingsThemeKey"
                       Variant="Variant.Outlined"
                       Label="@Localizer["Theme"]">
                @foreach (var theme in ThemeManager.AvailableThemes)
                {
                    <MudSelectItem Value="@theme.Key">@theme.Name</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseUserSettingsDialog">@Localizer["Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@SaveUserSettingsAsync">@Localizer["Save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _drawerOpen = true;
    private string _currentLang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    private bool _userSettingsDialogVisible;
    private string _settingsLanguage = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    private string _settingsThemeKey = "light";
    private bool IsBoardEditorRoute
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
            return relativePath.StartsWith("board/", StringComparison.OrdinalIgnoreCase)
                || relativePath.StartsWith("shared/", StringComparison.OrdinalIgnoreCase);
        }
    }

    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override void OnInitialized()
    {
        _currentLang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        _settingsLanguage = _currentLang;
        _settingsThemeKey = ThemeManager.CurrentThemeKey;
    }

    private Task SetThemeAsync(string themeKey) => ThemeManager.SetThemeAsync(themeKey, JS);

    private void OpenUserSettingsDialog()
    {
        _settingsLanguage = _currentLang;
        _settingsThemeKey = ThemeManager.CurrentThemeKey;
        _userSettingsDialogVisible = true;
    }

    private void CloseUserSettingsDialog()
    {
        _userSettingsDialogVisible = false;
        _settingsLanguage = _currentLang;
        _settingsThemeKey = ThemeManager.CurrentThemeKey;
    }

    private async Task SaveUserSettingsAsync()
    {
        if (!string.IsNullOrWhiteSpace(_settingsThemeKey)
            && !string.Equals(ThemeManager.CurrentThemeKey, _settingsThemeKey, StringComparison.OrdinalIgnoreCase))
        {
            await ThemeManager.SetThemeAsync(_settingsThemeKey, JS);
        }

        _userSettingsDialogVisible = false;

        if (!string.Equals(_currentLang, _settingsLanguage, StringComparison.OrdinalIgnoreCase))
        {
            _currentLang = _settingsLanguage;
            await JS.InvokeVoidAsync("orimLanguage.set", _settingsLanguage);
            Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
            return;
        }

        StateHasChanged();
    }
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
