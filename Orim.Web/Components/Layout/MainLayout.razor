@inherits LayoutComponentBase
@using System.Globalization
@using Microsoft.AspNetCore.WebUtilities
@using Orim.Web.Services
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Localizer
@inject IJSRuntime JS
@inject ThemeManager ThemeManager
@inject UserPreferencesManager UserPreferences

<ThemeShell>
    <MudLayout>
        <MudAppBar Elevation="1" Class="orim-appbar">
            @if (!IsBoardEditorRoute)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                               OnClick="@ToggleDrawer" />
            }
            <a href="/" class="orim-brand-link" aria-label="ORIM Startseite">
                <OrimLogo Class="orim-logo--appbar" />
            </a>
            <MudSpacer />
            @if (IsSharedRoute)
            {
                <MudMenu Icon="@Icons.Material.Filled.Palette" Color="Color.Inherit"
                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <MudMenuItem Disabled="true">
                        @Localizer["Theme"]
                    </MudMenuItem>
                    @foreach (var theme in ThemeManager.AvailableThemes)
                    {
                        <MudMenuItem Icon="@GetThemeIcon(theme.Key)" OnClick="@(() => SetThemeAsync(theme.Key))">
                            @theme.Name
                        </MudMenuItem>
                    }
                </MudMenu>
            }
            <AuthorizeView>
                <Authorized>
                    <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit"
                             AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <MudMenuItem Disabled="true">
                            @context.User.Identity?.Name
                        </MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Settings" OnClick="@OpenSettingsDialog">
                            @Localizer["Settings"]
                        </MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Href="/api/auth/logout" ForceLoad="true">
                            @Localizer["Logout"]
                        </MudMenuItem>
                    </MudMenu>
                </Authorized>
            </AuthorizeView>
        </MudAppBar>

        @if (!IsBoardEditorRoute)
        {
            <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Mini"
                       Class="orim-drawer">
                <MudNavMenu Color="Color.Primary">
                    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard"
                                Class="orim-nav-link">
                        @Localizer["Dashboard"]
                    </MudNavLink>
                    <AuthorizeView Roles="Admin">
                        <Authorized>
                            <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People"
                                        Class="orim-nav-link">
                                @Localizer["Users"]
                            </MudNavLink>
                            <MudNavLink Href="/admin/settings" Icon="@Icons.Material.Filled.Palette"
                                        Class="orim-nav-link">
                                @Localizer["OrimSettings"]
                            </MudNavLink>
                        </Authorized>
                    </AuthorizeView>
                </MudNavMenu>
            </MudDrawer>
        }

        <MudMainContent Class="pt-16 orim-main-content">
            @Body
        </MudMainContent>
    </MudLayout>

    <MudDialog @bind-Visible="_settingsDialogVisible" Options="_settingsDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["Settings"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudTabs Rounded="true">
                <MudTabPanel Text="@Localizer["General"]">
                    <MudStack Spacing="2" Class="pt-4">
                        <MudText Typo="Typo.body2">@Localizer["GeneralSettingsDescription"]</MudText>
                        <MudPaper Class="pa-4" Outlined="true">
                            <MudCheckBox T="bool"
                                         Value="@UserPreferences.ShowDashboardTemplates"
                                         ValueChanged="@SetShowDashboardTemplatesAsync"
                                         Label="@Localizer["ShowBoardOverviewTemplates"]" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localizer["ShowBoardOverviewTemplatesDescription"]</MudText>
                        </MudPaper>
                    </MudStack>
                </MudTabPanel>
                <MudTabPanel Text="@Localizer["Language"]">
                    <MudStack Spacing="2" Class="pt-4">
                        <MudText Typo="Typo.body2">@Localizer["LanguageSettingsDescription"]</MudText>
                        <MudList T="string" Class="orim-settings-list">
                            @foreach (var languageOption in GetLanguageOptions())
                            {
                                <MudListItem T="string" OnClick="@(() => SetLanguage(languageOption.Key))"
                                             Class="orim-settings-list-item">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body1">@languageOption.Label</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@languageOption.Description</MudText>
                                        </MudStack>
                                        <MudIcon Icon="@(IsCurrentLanguage(languageOption.Key)
                                            ? Icons.Material.Filled.RadioButtonChecked
                                            : Icons.Material.Filled.RadioButtonUnchecked)"
                                                 Color="@(IsCurrentLanguage(languageOption.Key) ? Color.Primary : Color.Default)" />
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    </MudStack>
                </MudTabPanel>
                <MudTabPanel Text="@Localizer["Theme"]">
                    <MudStack Spacing="2" Class="pt-4">
                        <MudText Typo="Typo.body2">@Localizer["ThemeSettingsDescription"]</MudText>
                        <MudList T="string" Class="orim-settings-list">
                            @foreach (var theme in ThemeManager.AvailableThemes)
                            {
                                <MudListItem T="string" OnClick="@(() => SetThemeAsync(theme.Key))"
                                             Class="orim-settings-list-item">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudIcon Icon="@GetThemeIcon(theme.Key)"
                                                     Color="@(IsCurrentTheme(theme.Key) ? Color.Primary : Color.Default)" />
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body1">@theme.Name</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@GetThemeModeLabel(theme)</MudText>
                                            </MudStack>
                                        </MudStack>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    </MudStack>
                </MudTabPanel>
            </MudTabs>
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Text" OnClick="@CloseSettingsDialog">@Localizer["Close"]</MudButton>
        </DialogActions>
    </MudDialog>
</ThemeShell>

@code {
    private sealed record LanguageOption(string Key, string Label, string Description);

    private bool _drawerOpen = true;
    private string _currentLang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    private bool _settingsDialogVisible;
    private readonly DialogOptions _settingsDialogOptions = new()
    {
        CloseButton = true,
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };

    private bool IsBoardEditorRoute
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
            return relativePath.StartsWith("board/", StringComparison.OrdinalIgnoreCase)
                || relativePath.StartsWith("shared/", StringComparison.OrdinalIgnoreCase);
        }
    }
    private bool IsSharedRoute => Navigation.ToBaseRelativePath(Navigation.Uri).StartsWith("shared/", StringComparison.OrdinalIgnoreCase);

    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override void OnInitialized()
    {
        _currentLang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await UserPreferences.InitializeAsync(JS);
        await InvokeAsync(StateHasChanged);
    }

    private Task SetThemeAsync(string themeKey) => ThemeManager.SetThemeAsync(themeKey, JS);

    private void OpenSettingsDialog() => _settingsDialogVisible = true;

    private void CloseSettingsDialog() => _settingsDialogVisible = false;

    private string GetThemeIcon(string themeKey) => string.Equals(ThemeManager.CurrentThemeKey, themeKey, StringComparison.OrdinalIgnoreCase)
        ? Icons.Material.Filled.RadioButtonChecked
        : Icons.Material.Filled.RadioButtonUnchecked;

    private bool IsCurrentTheme(string themeKey) => string.Equals(ThemeManager.CurrentThemeKey, themeKey, StringComparison.OrdinalIgnoreCase);

    private string GetThemeModeLabel(ThemeDefinition theme) => theme.IsDarkMode
        ? Localizer["ThemeDark"]
        : Localizer["ThemeLight"];

    private Task SetShowDashboardTemplatesAsync(bool value) => UserPreferences.SetShowDashboardTemplatesAsync(value, JS);

    private IReadOnlyList<LanguageOption> GetLanguageOptions()
    {
        return
        [
            new("de", Localizer["LanguageGerman"], Localizer["LanguageGermanDescription"]),
            new("en", Localizer["LanguageEnglish"], Localizer["LanguageEnglishDescription"])
        ];
    }

    private bool IsCurrentLanguage(string languageKey) => string.Equals(_currentLang, languageKey, StringComparison.OrdinalIgnoreCase);

    private void SetLanguage(string languageKey)
    {
        if (IsCurrentLanguage(languageKey))
        {
            return;
        }

        NavigateToLanguage(languageKey);
    }

    private void ToggleLanguage()
    {
        var nextLanguage = _currentLang == "de" ? "en" : "de";
        NavigateToLanguage(nextLanguage);
    }

    private void NavigateToLanguage(string languageKey)
    {
        var currentRelativeUri = Navigation.ToBaseRelativePath(Navigation.Uri);
        var relativeUriWithLeadingSlash = string.IsNullOrWhiteSpace(currentRelativeUri)
            ? "/"
            : $"/{currentRelativeUri}";
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query)
            .Where(entry => !string.Equals(entry.Key, "culture", StringComparison.OrdinalIgnoreCase)
                && !string.Equals(entry.Key, "ui-culture", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(entry => entry.Key, entry => entry.Value.LastOrDefault());

        _currentLang = languageKey;
        var redirectUri = QueryHelpers.AddQueryString(relativeUriWithLeadingSlash.Split('?', 2)[0], query);
        var switchUri = QueryHelpers.AddQueryString(
            "/api/culture/set",
            new Dictionary<string, string?>
            {
                ["culture"] = languageKey,
                ["redirectUri"] = redirectUri
            });

        Navigation.NavigateTo(switchUri, forceLoad: true);
    }
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
