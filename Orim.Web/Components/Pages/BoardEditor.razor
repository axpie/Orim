@page "/board/{BoardId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject BoardService BoardService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<PageTitle>Orim – @(_board?.Title ?? "Board")</PageTitle>

@if (_board is null)
{
    <MudContainer Class="py-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </MudContainer>
}
else if (!_hasAccess)
{
    <MudContainer Class="py-8">
        <MudAlert Severity="Severity.Error">Kein Zugriff auf dieses Board.</MudAlert>
    </MudContainer>
}
else
{
    var propertiesPanelOpen = _canvas?.SelectedElement is not null && _canEdit;
    var selectedElement = _canvas?.SelectedElement;

    <div style="display: flex; flex-direction: column; height: calc(100vh - 64px);">
        <MudPaper Elevation="1" Style="padding: 4px 16px; display: flex; align-items: center; gap: 8px; background: #fff; z-index: 10; border-bottom: 1px solid #e1e4e8;">
            <MudTooltip Text="Zur Übersicht" Arrow="true">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@GoBack" Size="Size.Small" />
            </MudTooltip>
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@_board.Title</MudText>
            <MudSpacer />

            @if (_canEdit)
            {
                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Style="border-radius: 8px;">
                    <MudTooltip Text="Auswahlwerkzeug" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.NearMe"
                                       Color="@(_selectedTool == Tool.Select ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Select))" />
                    </MudTooltip>
                    <MudTooltip Text="Rechteck zeichnen" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Rectangle"
                                       Color="@(_selectedTool == Tool.Rectangle ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Rectangle))" />
                    </MudTooltip>
                </MudButtonGroup>

                <MudDivider Vertical="true" FlexItem="true" />
            }

            <MudMenu Size="Size.Small">
                <ActivatorContent>
                    <MudTooltip Text="Board exportieren" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.FileDownload" Size="Size.Small" />
                    </MudTooltip>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem OnClick="@ExportJson">Export als JSON</MudMenuItem>
                </ChildContent>
            </MudMenu>
        </MudPaper>

        <div style="display: flex; flex: 1; min-height: 0; min-width: 0; overflow: hidden;">
            <div style="flex: 1; min-width: 0; min-height: 0; overflow: hidden; position: relative;" @onkeydown="HandleKeyDown" tabindex="0">
                <WhiteboardCanvas @ref="_canvas" Board="@_board" CanEdit="@_canEdit"
                                  CommandStack="@_commandStack"
                                  OnBoardChanged="@SaveBoard" SelectedTool="@_selectedTool" />
            </div>

            @if (propertiesPanelOpen)
            {
                <ElementPropertiesPanel Element="@(selectedElement!)"
                                        OnChanged="@OnElementPropertyChanged" />
            }
        </div>
    </div>
}

@code {
    [Parameter] public Guid BoardId { get; set; }

    private Board? _board;
    private Guid _userId;
    private bool _hasAccess;
    private bool _canEdit;
    private Tool _selectedTool = Tool.Select;
    private readonly CommandStack _commandStack = new();
    private WhiteboardCanvas? _canvas;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userId = Guid.Parse(user.FindFirst(ClaimTypes.NameIdentifier)!.Value);
        }

        _board = await BoardService.GetBoardAsync(BoardId);
        if (_board is null) return;

        _hasAccess = BoardService.HasAccess(_board, _userId);
        _canEdit = BoardService.HasAccess(_board, _userId, BoardRole.Editor);
    }

    private void SelectTool(Tool tool) => _selectedTool = tool;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (_board is null || !_canEdit) return;

        if (e.Key == "Delete" || e.Key == "Backspace")
        {
            if (_canvas?.SelectedElement is not null)
            {
                var cmd = new RemoveElementCommand(_canvas.SelectedElement.Id);
                _commandStack.Execute(_board, cmd);
                _canvas.ClearSelection();
                await SaveBoard();
            }
        }
    }

    private async Task SaveBoard()
    {
        if (_board is null) return;
        await BoardService.UpdateBoardAsync(_board);
    }

    private void GoBack() => Navigation.NavigateTo("/");

    private async Task ExportJson()
    {
        if (_board is null) return;
        var json = System.Text.Json.JsonSerializer.Serialize(_board, new System.Text.Json.JsonSerializerOptions
        {
            WriteIndented = true,
            PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase,
            Converters = { new System.Text.Json.Serialization.JsonStringEnumConverter() }
        });
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("orimWhiteboard.downloadFile",
            $"{_board.Title}.json", "application/json", base64);
    }

    private async Task OnElementPropertyChanged()
    {
        await SaveBoard();
        StateHasChanged();
    }

    public enum Tool
    {
        Select,
        Rectangle
    }
}
