    {
        Tool.Select => Localizer["Select"],
        Tool.Rectangle => Localizer["Rectangle"],
        Tool.Circle => Localizer["Ellipse"],
        Tool.Triangle => Localizer["Triangle"],
        Tool.Arrow => Localizer["Arrow"],
        Tool.Icon => Localizer["InsertIconTooltip"],
