    {
        await _editorSurface.FocusAsync();
    }

    private async Task DeleteSelectedElementAsync()
    {
        if (_board is null || !_canEdit || _selectedElements.Count == 0)
        {
            return;
        }

        foreach (var elementId in _selectedElements.Select(element => element.Id).Distinct().ToList())
        {
            if (_formatTransferSourceId == elementId)
            {
                _formatTransferActive = false;
                _formatTransferSourceId = null;
            }

            if (_board.Elements.Any(element => element.Id == elementId))
            {
                var cmd = new RemoveElementCommand(elementId);
                cmd.Execute(_board);
            }
        }

        _selectedElement = null;
        _selectedElements = [];
        _canvas?.ClearSelection();
        await SaveBoard();
        StateHasChanged();
    }

    private void CopySelectedElement()
    {
        if (_selectedElements.Count == 0)
        {
            return;
        }

        _clipboardElements = _selectedElements
            .OrderBy(element => element.ZIndex)
            .Select(CloneElement)
            .ToList();
        _pasteSequence = 0;
    }

    private async Task CutSelectedElementAsync()
    {
        if (_selectedElements.Count == 0)
        {
            return;
        }

        CopySelectedElement();
        await DeleteSelectedElementAsync();
    }

    private async Task PasteClipboardElementAsync()
    {
        if (_board is null || _clipboardElements.Count == 0)
        {
            return;
        }

        _pasteSequence++;
        var pastedElements = CloneForPaste(_clipboardElements, _board.Elements.Count, _pasteSequence);
        _board.Elements.AddRange(pastedElements);
        _selectedElements = pastedElements;
        _selectedElement = pastedElements.LastOrDefault();
        if (_canvas is not null)
        {
            await _canvas.SelectElementsAsync(pastedElements);
        }

        await SaveBoard();
        StateHasChanged();
    }

    private async Task SelectAllElementsAsync()
    {
        if (_board is null || _board.Elements.Count == 0 || _canvas is null)
        {
            return;
        }

        var selectableElements = _board.Elements.OrderBy(element => element.ZIndex).ToList();
        _selectedElements = selectableElements;
        _selectedElement = selectableElements.LastOrDefault();
        await _canvas.SelectElementsAsync(selectableElements);
        StateHasChanged();
    }

    private async Task GroupSelectedElementsAsync()
    {
        if (_board is null || !CanGroupSelection)
        {
            return;
        }

        var groupId = Guid.NewGuid();
        foreach (var element in _selectedElements.Where(element => element is not ArrowElement))
        {
            element.GroupId = groupId;
        }

        await SaveBoard();
        StateHasChanged();
    }

    private async Task UngroupSelectedElementsAsync()
    {
        if (_board is null || !CanUngroupSelection)
        {
            return;
        }

        foreach (var element in _selectedElements)
        {
            element.GroupId = null;
        }

        await SaveBoard();
        StateHasChanged();
    }

    private async Task DeleteBoardAsync()
    {
        if (_board is null || _board.OwnerId != _userId)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", string.Format(Localizer["DeleteBoardConfirmation"], _board.Title));
        if (!confirmed)
        {
            return;
