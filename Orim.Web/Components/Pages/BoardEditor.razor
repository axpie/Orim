    {
        if (_board is null) return;
        var json = System.Text.Json.JsonSerializer.Serialize(_board, Orim.Core.OrimJsonOptions.Indented);
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("orimWhiteboard.downloadFile",
            $"{_board.Title}.json", "application/json", base64);
