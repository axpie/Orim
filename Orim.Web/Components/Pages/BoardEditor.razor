    {
        _boardSettingsMessage = message;
        _boardSettingsMessageSeverity = severity;
        if (announce)
        {
            UpdateScreenReaderStatus(message);
        }
    }

    private void UpdateScreenReaderStatus(string message) => _screenReaderStatus = message;

    private Task HandleExternalBoardChangeAsync(BoardChangeNotification notification)
    {
        if (notification.SourceClientId == _boardSyncClientId)
        {
            return Task.CompletedTask;
        }

        return InvokeAsync(async () =>
        {
            var latestBoard = await BoardService.GetBoardAsync(BoardId);
            if (latestBoard is null)
            {
                Navigation.NavigateTo("/");
                return;
            }

            _board = latestBoard;
            _hasAccess = BoardService.HasAccess(_board, _userId);
            _canEdit = BoardService.HasAccess(_board, _userId, BoardRole.Editor);
            _boardLabelOutlineEnabled = _board.LabelOutlineEnabled;
            _boardArrowOutlineEnabled = _board.ArrowOutlineEnabled;
            _boardVisibility = _board.Visibility;
            _commandStack.Clear();
            _lastCommittedBoardSnapshot = CaptureBoardSnapshot(_board);
            _formatTransferActive = false;
            _formatTransferSourceId = null;
            if (!_canEdit)
            {
                _selectedTool = Tool.Select;
            }

            InitializeBoardSettingsDrafts();
            await SyncSelectionToBoardAsync();
            _canvas?.ForceRerender();
            UpdateScreenReaderStatus(Localizer["BoardCanvasUpdatedAnnouncement"]);
            StateHasChanged();
        });
    }

    private Task HandleCursorPresenceChangedAsync(IReadOnlyList<BoardCursorPresence> cursors)
    {
        return InvokeAsync(() =>
        {
            _remoteCursors = cursors
                .Where(cursor => cursor.ClientId != _boardSyncClientId)
                .ToList();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _presenceHeartbeatCancellation.Cancel();
        if (_board is not null)
        {
            _ = BoardPresenceService.RemoveCursorAsync(_board.Id, _boardSyncClientId);
            try
            {
                _ = JS.InvokeVoidAsync("orimWhiteboard.unregisterPresenceLifecycle", _board.Id, _boardSyncClientId);
            }
            catch
            {
            }
        }

        _cursorPresenceSubscription?.Dispose();
        _boardChangeSubscription?.Dispose();
        _presenceHeartbeatCancellation.Dispose();
    }

