    private async Task StartPresenceHeartbeatAsync()
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            while (await timer.WaitForNextTickAsync(_presenceHeartbeatCancellation.Token))
            {
                await PublishLocalPresenceAsync(_localPointerPosition);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task HandleSelectedElementsChanged(IReadOnlyList<BoardElement> elements)
    {
        _selectedElements = elements.ToList();
        _selectedElement = _selectedElements.LastOrDefault();

        if (_formatTransferActive && _selectedElements.Count == 1 && _selectedElement is not null)
        {
            await TryApplyFormatTransferAsync(_selectedElement);
        }

        UpdateScreenReaderStatus(_selectedElements.Count switch
        {
            0 => Localizer["SelectionClearedAnnouncement"],
            1 when _selectedElement is not null => Localizer["SelectionSingleAnnouncement", GetElementAnnouncementLabel(_selectedElement)],
            _ => Localizer["SelectionCountAnnouncement", _selectedElements.Count]
        });
        StateHasChanged();
    }

    private async Task TryApplyFormatTransferAsync(BoardElement target)
    {
        if (_board is null || !_canEdit || _formatTransferSourceId is null || _formatTransferSourceId == target.Id)
        {
            return;
        }

        var source = _board.Elements.FirstOrDefault(element => element.Id == _formatTransferSourceId.Value);
        if (source is null)
        {
            _formatTransferActive = false;
            _formatTransferSourceId = null;
            return;
        }

        ApplyFormat(source, target);
        _formatTransferActive = false;
        _formatTransferSourceId = null;
        await SaveBoard();
        _canvas?.ForceRerender();
    }

    private static void ApplyFormat(BoardElement source, BoardElement target)
    {
        target.LabelFontSize = source.LabelFontSize;
        target.LabelHorizontalAlignment = source.LabelHorizontalAlignment;
        target.LabelVerticalAlignment = source.LabelVerticalAlignment;

        switch (source)
        {
            case ShapeElement sourceShape when target is ShapeElement targetShape:
                targetShape.FillColor = sourceShape.FillColor;
                targetShape.StrokeColor = sourceShape.StrokeColor;
                targetShape.StrokeWidth = sourceShape.StrokeWidth;
                targetShape.BorderLineStyle = sourceShape.BorderLineStyle;
                break;

            case TextElement sourceText when target is TextElement targetText:
                targetText.Color = sourceText.Color;
                targetText.FontSize = sourceText.FontSize;
                targetText.IsBold = sourceText.IsBold;
                targetText.IsItalic = sourceText.IsItalic;
                break;

            case ArrowElement sourceArrow when target is ArrowElement targetArrow:
                targetArrow.StrokeColor = sourceArrow.StrokeColor;
                targetArrow.StrokeWidth = sourceArrow.StrokeWidth;
                targetArrow.LineStyle = sourceArrow.LineStyle;
                targetArrow.SourceHeadStyle = sourceArrow.SourceHeadStyle;
                targetArrow.TargetHeadStyle = sourceArrow.TargetHeadStyle;
                targetArrow.RouteStyle = sourceArrow.RouteStyle;
                break;

            case IconElement sourceIcon when target is IconElement targetIcon:
                targetIcon.Color = sourceIcon.Color;
                break;
        }
    }

    private void InitializeBoardSettingsDrafts()
    {
        if (_board is null)
        {
            return;
        }

        _boardLabelOutlineEnabled = _board.LabelOutlineEnabled;
        _boardArrowOutlineEnabled = _board.ArrowOutlineEnabled;
        _boardVisibility = _board.Visibility;
        _shareLinkTokenDraft = _board.ShareLinkToken;
        _shareAllowAnonymousEditingDraft = _board.SharedAllowAnonymousEditing;
        _sharePasswordEnabledDraft = BoardService.IsSharePasswordProtected(_board);
        _sharePasswordDraft = string.Empty;
        _memberDrafts = _board.Members
            .Select(member => new MemberDraft
            {
                UserId = member.UserId,
                Username = member.Username,
                Role = member.Role,
                IsOwner = member.Role == BoardRole.Owner || member.UserId == _board.OwnerId
            })
            .OrderBy(member => member.Role)
            .ThenBy(member => member.Username)
            .ToList();
        _selectedMemberToAddId = null;
        _selectedMemberRoleToAdd = BoardRole.Editor;
        _snapshotName = string.Empty;
    }

    private void GenerateShareLinkDraft()
    {
        _shareLinkTokenDraft = BoardService.GenerateShareLinkToken();
        _boardVisibility = BoardVisibility.Shared;
        SetBoardSettingsMessage(Localizer["ShareLinkGenerated"], Severity.Success);
    }

    private string GetShareLinkDraftUrl()
    {
        if (string.IsNullOrWhiteSpace(_shareLinkTokenDraft))
        {
            return string.Empty;
        }

        var baseUri = new Uri(Navigation.BaseUri);
        return new Uri(baseUri, $"shared/{_shareLinkTokenDraft}").ToString();
    }

    private async Task CopyShareLinkAsync()
    {
        var shareLink = GetShareLinkDraftUrl();
        if (string.IsNullOrWhiteSpace(shareLink))
        {
            return;
        }

        await JS.InvokeVoidAsync("orimWhiteboard.copyTextToClipboard", shareLink);
        SetBoardSettingsMessage(Localizer["ShareLinkCopied"], Severity.Success, announce: true);
    }

    private async Task AddSelectedMemberAsync()
    {
        if (!CanManageBoard || _selectedMemberToAddId is null)
        {
            return;
        }

        var user = _availableUsers.FirstOrDefault(candidate => candidate.Id == _selectedMemberToAddId.Value);
        if (user is null)
        {
            return;
        }

        _memberDrafts.Add(new MemberDraft
        {
            UserId = user.Id,
            Username = user.Username,
            Role = _selectedMemberRoleToAdd
        });

        _selectedMemberToAddId = null;
        _selectedMemberRoleToAdd = BoardRole.Editor;
        SetBoardSettingsMessage(Localizer["BoardMemberAdded", user.Username], Severity.Success);
        await Task.CompletedTask;
    }

    private void RemoveMemberDraft(Guid userId)
    {
        _memberDrafts.RemoveAll(member => member.UserId == userId && !member.IsOwner);
        SetBoardSettingsMessage(Localizer["BoardMemberRemoved"], Severity.Info);
    }

    private async Task ImportIntoCurrentBoardAsync(InputFileChangeEventArgs args)
    {
        if (_board is null || !CanManageBoard || args.File is null)
        {
            return;
        }

        _isApplyingBoardImport = true;

        try
        {
            var importedBoard = await DeserializeBoardFromFileAsync(args.File);
            BoardService.CreateSnapshot(_board, Localizer["AutomaticImportBackupSnapshot"], _userId, _username);
            BoardService.ReplaceBoardContent(_board, importedBoard);
            await RefreshBoardAfterStructureChangeAsync(fitToContent: true);
            InitializeBoardSettingsDrafts();
            SetBoardSettingsMessage(Localizer["ImportReplaceSuccess"], Severity.Success, announce: true);
        }
        catch (System.Text.Json.JsonException)
        {
            SetBoardSettingsMessage(Localizer["ImportBoardInvalidJson"], Severity.Error, announce: true);
        }
        catch (InvalidDataException)
        {
            SetBoardSettingsMessage(Localizer["ImportBoardInvalidJson"], Severity.Error, announce: true);
        }
        catch (IOException)
        {
            SetBoardSettingsMessage(Localizer["ImportBoardReadError"], Severity.Error, announce: true);
        }
        finally
        {
            _isApplyingBoardImport = false;
        }
    }

    private async Task CreateSnapshotAsync()
    {
        if (_board is null)
        {
            return;
        }

        var snapshot = BoardService.CreateSnapshot(_board, _snapshotName, _userId, _username);
        await BoardService.UpdateBoardAsync(_board, _boardSyncClientId);
        _snapshotName = string.Empty;
        SetBoardSettingsMessage(Localizer["SnapshotCreated", snapshot.Name], Severity.Success, announce: true);
    }

    private async Task RestoreSnapshotAsync(Guid snapshotId)
    {
        if (_board is null)
        {
            return;
        }

        BoardService.CreateSnapshot(_board, Localizer["AutomaticRestoreBackupSnapshot"], _userId, _username);
        BoardService.RestoreSnapshot(_board, snapshotId);
        await RefreshBoardAfterStructureChangeAsync(fitToContent: true);
        InitializeBoardSettingsDrafts();
        SetBoardSettingsMessage(Localizer["SnapshotRestored"], Severity.Success, announce: true);
    }

    private async Task<Board> DeserializeBoardFromFileAsync(IBrowserFile file)
    {
        await using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        var board = await System.Text.Json.JsonSerializer.DeserializeAsync<Board>(stream, Orim.Core.OrimJsonOptions.Default);
        if (board is null)
        {
            throw new InvalidDataException("Board import payload was empty.");
        }

        return board;
    }

    private async Task RefreshBoardAfterStructureChangeAsync(bool fitToContent)
    {
        if (_board is null)
        {
            return;
        }

        _commandStack.Clear();
        _selectedElements = [];
        _selectedElement = null;
        _canvas?.ClearSelection();
        _lastCommittedBoardSnapshot = CaptureBoardSnapshot(_board);
        await BoardService.UpdateBoardAsync(_board, _boardSyncClientId);
        _canvas?.ForceRerender();
        if (fitToContent && _canvas is not null)
        {
            await _canvas.FitToContentAsync();
        }

        UpdateScreenReaderStatus(Localizer["BoardCanvasUpdatedAnnouncement"]);
        StateHasChanged();
    }

    private async Task ClearSelectionAsync()
    {
        _selectedElements = [];
        _selectedElement = null;
        if (_canvas is not null)
        {
            await _canvas.SelectElementsAsync([]);
        }

        UpdateScreenReaderStatus(Localizer["SelectionClearedAnnouncement"]);
        StateHasChanged();
    }

    private async Task MoveSelectedElementsAsync(double deltaX, double deltaY)
    {
        if (_board is null || !_canEdit)
        {
            return;
        }

        var movableElements = _selectedElements.Where(element => element is not ArrowElement).ToList();
        if (movableElements.Count == 0)
        {
            return;
        }

        foreach (var element in movableElements)
        {
            element.X += deltaX;
            element.Y += deltaY;
        }

        await SaveBoard();
        _canvas?.ForceRerender();
        UpdateScreenReaderStatus(Localizer["SelectionMovedAnnouncement"]);
        StateHasChanged();
    }

    private static bool TryGetKeyboardMoveDelta(KeyboardEventArgs e, out double deltaX, out double deltaY)
    {
        deltaX = 0;
        deltaY = 0;
        var step = e.ShiftKey ? 20 : 10;
        if (e.CtrlKey || e.MetaKey || e.AltKey)
        {
            return false;
        }

        switch (e.Key)
        {
            case "ArrowUp":
                deltaY = -step;
                return true;
            case "ArrowDown":
                deltaY = step;
                return true;
            case "ArrowLeft":
                deltaX = -step;
                return true;
            case "ArrowRight":
                deltaX = step;
                return true;
            default:
                return false;
        }
    }

