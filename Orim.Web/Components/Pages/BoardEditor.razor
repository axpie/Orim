@page "/board/{BoardId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject BoardService BoardService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject IWebHostEnvironment Environment
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["AppTitle"] - @(_board?.Title ?? Localizer["Board"])</PageTitle>

@if (_board is null)
{
    <MudContainer Class="py-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </MudContainer>
}
else if (!_hasAccess)
{
    <MudContainer Class="py-8">
        <MudAlert Severity="Severity.Error">@Localizer["NoBoardAccess"]</MudAlert>
    </MudContainer>
}
else
{
    var selectedElement = _selectedElements.Count == 1 ? _selectedElements[0] : null;

    <div style="display: flex; flex-direction: column; height: calc(100vh - 64px);">
        <MudPaper Elevation="1" Style="padding: 4px 16px; display: flex; align-items: center; gap: 8px; background: #fff; z-index: 10; border-bottom: 1px solid #e1e4e8;">
            <MudTooltip Text="@Localizer["BackToOverview"]" Arrow="true">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@GoBack" Size="Size.Small" />
            </MudTooltip>
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@_board.Title</MudText>
            @if (_board.OwnerId == _userId)
            {
                <MudTooltip Text="@Localizer["RenameBoard"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@OpenRenameBoardDialog" />
                </MudTooltip>
            }
            <MudSpacer />

            @if (_canEdit)
            {
                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Style="border-radius: 8px;">
                    <MudTooltip Text="@Localizer["SelectToolTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.NearMe"
                                       Color="@(_selectedTool == Tool.Select ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Select))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["DrawRectangleTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Rectangle"
                                       Color="@(_selectedTool == Tool.Rectangle ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Rectangle))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["DrawCircleTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.PanoramaFishEye"
                                       Color="@(_selectedTool == Tool.Circle ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Circle))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["DrawTriangleTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.ChangeHistory"
                                       Color="@(_selectedTool == Tool.Triangle ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Triangle))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["ConnectArrowTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.NorthEast"
                                       Color="@(_selectedTool == Tool.Arrow ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Arrow))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["InsertIconTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.AddReaction"
                                       Color="@(_selectedTool == Tool.Icon ? Color.Primary : Color.Default)"
                                       OnClick="@OpenIconPickerAsync" />
                    </MudTooltip>
                </MudButtonGroup>

                <MudTooltip Text="@Localizer["Undo"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Undo"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   Disabled="@(!_commandStack.CanUndo)"
                                   OnClick="@UndoAsync" />
                </MudTooltip>

                <MudTooltip Text="@Localizer["Redo"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Redo"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   Disabled="@(!_commandStack.CanRedo)"
                                   OnClick="@RedoAsync" />
                </MudTooltip>

                <MudDivider Vertical="true" FlexItem="true" />

                <MudTooltip Text="@Localizer["ZoomOut"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@ZoomOutAsync" />
                </MudTooltip>

                <input value="@_zoomDisplayValue"
                       @onchange="HandleZoomInputChangedAsync"
                       style="width:72px; height:32px; border:1px solid #d0d7de; border-radius:8px; padding:0 10px; font-size:14px; font-weight:600; color:#0f172a; text-align:right; background:white;"
                       aria-label="@Localizer["ZoomLevelPercent"]" />

                <MudTooltip Text="@Localizer["ZoomIn"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@ZoomInAsync" />
                </MudTooltip>

                <MudTooltip Text="@Localizer["FitToContent"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.FitScreen"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@FitToContentAsync" />
                </MudTooltip>

                <MudTooltip Text="@Localizer["OpenHelp"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Info"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@OpenHelpDialog" />
                </MudTooltip>

                @if (_selectedElement is not null)
                {
                    <MudTooltip Text="@Localizer["DeleteSelectedElement"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@DeleteSelectedElementAsync" />
                    </MudTooltip>
                }

                @if (CanGroupSelection)
                {
                    <MudTooltip Text="@Localizer["GroupSelection"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.CreateNewFolder"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@GroupSelectedElementsAsync" />
                    </MudTooltip>
                }

                @if (CanUngroupSelection)
                {
                    <MudTooltip Text="@Localizer["UngroupSelection"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.FolderOff"
                                       Size="Size.Small"
                                       OnClick="@UngroupSelectedElementsAsync" />
                    </MudTooltip>
                }

                <MudDivider Vertical="true" FlexItem="true" />
            }

            <MudTooltip Text="@Localizer["ExportBoardJson"]" Arrow="true">
                <MudIconButton Icon="@Icons.Material.Filled.FileDownload"
                               Size="Size.Small"
                               OnClick="@ExportJson" />
            </MudTooltip>

            @if (_board.OwnerId == _userId)
            {
                <MudTooltip Text="@Localizer["DeleteBoard"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@DeleteBoardAsync" />
                </MudTooltip>
            }
        </MudPaper>

        <div style="display: flex; flex: 1; min-height: 0; min-width: 0; overflow: hidden;">
            <div @ref="_editorSurface"
                 style="flex: 1; min-width: 0; min-height: 0; overflow: hidden; position: relative; outline: none;"
                 @onmousedown="FocusEditorSurfaceAsync"
                 @onkeydown="HandleKeyDown"
                 tabindex="0">
                <WhiteboardCanvas @ref="_canvas" Board="@_board" CanEdit="@_canEdit"
                                  CommandStack="@_commandStack"
                                  OnBoardChanged="@HandleBoardChanged"
                                  OnSelectedElementChanged="@HandleSelectedElementChanged"
                                  OnSelectedElementsChanged="@HandleSelectedElementsChanged"
                                  OnZoomChanged="@HandleZoomChanged"
                                  OnToolChanged="@HandleToolChanged"
                                  PendingIconName="@_pendingIconName"
                                  SelectedTool="@_selectedTool" />
            </div>

            @if (_canEdit)
            {
                <ElementPropertiesPanel @key="@(selectedElement?.Id ?? Guid.Empty)"
                                        Element="@selectedElement"
                                        SelectionCount="@_selectedElements.Count"
                                        OnChanged="@OnElementPropertyChanged" />
            }
        </div>
    </div>

    <MudDialog @bind-Visible="_iconPickerVisible" Options="_iconDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["MaterialDesignIcons"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_iconSearch"
                          Label="@Localizer["SearchIcon"]"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" />

            @if (_isLoadingIcons)
            {
                <div style="display:flex; align-items:center; justify-content:center; min-height:220px;">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_iconLoadError))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4">@_iconLoadError</MudAlert>
            }
            else
            {
                <MudText Typo="Typo.caption" Class="mt-2 mb-2" Style="color:#667085;">
                    @string.Format(Localizer["IconCount"], FilteredMaterialIcons.Count)
                </MudText>
                <div style="max-height:420px; overflow:auto; border:1px solid #e5e7eb; border-radius:10px; padding:8px; display:grid; grid-template-columns:repeat(auto-fill, minmax(92px, 1fr)); gap:8px;">
                    @foreach (var iconName in FilteredMaterialIcons)
                    {
                        <button type="button"
                                @onclick="@(() => SelectMaterialIconAsync(iconName))"
                                style="display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px; min-height:82px; border:1px solid #d0d7de; border-radius:8px; background:white; cursor:pointer; padding:8px;">
                            <span class="mdi @iconName" style="font-size:28px; line-height:1; color:#0f172a;"></span>
                            <span style="font-size:11px; line-height:1.2; color:#475467; text-align:center; overflow-wrap:anywhere;">@iconName[4..]</span>
                        </button>
                    }
                </div>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@CloseIconPicker">@Localizer["Cancel"]</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_helpDialogVisible" Options="_helpDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["HelpDialogTitle"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["ToolsSectionTitle"]</MudText>
            <ul style="margin:0 0 16px 18px; padding:0; color:#334155; line-height:1.5;">
                <li>@Localizer["HelpToolsSelect"]</li>
                <li>@Localizer["HelpToolsShapes"]</li>
                <li>@Localizer["HelpToolsArrow"]</li>
                <li>@Localizer["HelpToolsIcon"]</li>
            </ul>

            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["SelectionGroupsSectionTitle"]</MudText>
            <ul style="margin:0 0 16px 18px; padding:0; color:#334155; line-height:1.5;">
                <li>@Localizer["HelpSelectionMarquee"]</li>
                <li>@Localizer["HelpSelectionAdditive"]</li>
                <li>@Localizer["HelpSelectionGroupMove"]</li>
                <li>@Localizer["HelpSelectionSingleEdit"]</li>
                <li>@Localizer["HelpSelectionZoom"]</li>
                <li>@Localizer["HelpSelectionSnapDisable"]</li>
            </ul>

            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["ShortcutsSectionTitle"]</MudText>
            <ul style="margin:0 0 0 18px; padding:0; color:#334155; line-height:1.5;">
                <li>@Localizer["ShortcutUndo"]</li>
                <li>@Localizer["ShortcutRedo"]</li>
                <li>@Localizer["ShortcutSelectAll"]</li>
                <li>@Localizer["ShortcutCopy"]</li>
                <li>@Localizer["ShortcutCut"]</li>
                <li>@Localizer["ShortcutPaste"]</li>
                <li>@Localizer["ShortcutGroup"]</li>
                <li>@Localizer["ShortcutUngroup"]</li>
                <li>@Localizer["ShortcutDelete"]</li>
            </ul>
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@CloseHelpDialog">@Localizer["Close"]</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_renameDialogVisible" Options="_helpDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["RenameBoardTitle"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_renameBoardTitle"
                          Label="@Localizer["BoardName"]"
                          Variant="Variant.Outlined"
                          Required="true" />
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@CloseRenameBoardDialog">@Localizer["Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@ConfirmRenameBoardAsync">@Localizer["Save"]</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    [Parameter] public Guid BoardId { get; set; }

    private Board? _board;
    private Guid _userId;
    private bool _hasAccess;
    private bool _canEdit;
    private Tool _selectedTool = Tool.Select;
    private readonly CommandStack _commandStack = new();
    private WhiteboardCanvas? _canvas;
    private BoardElement? _selectedElement;
    private List<BoardElement> _selectedElements = [];
    private ElementReference _editorSurface;
    private bool _iconPickerVisible;
    private bool _helpDialogVisible;
    private bool _renameDialogVisible;
    private bool _isLoadingIcons;
    private string _iconSearch = string.Empty;
    private string? _iconLoadError;
    private string? _pendingIconName;
    private List<BoardElement> _clipboardElements = [];
    private int _pasteSequence;
    private string _lastCommittedBoardSnapshot = string.Empty;
    private int _zoomPercentage = 100;
    private string _zoomDisplayValue = "100%";
    private string _renameBoardTitle = string.Empty;
    private bool CanGroupSelection => _selectedElements.Count(element => element is not ArrowElement) > 1;
    private bool CanUngroupSelection => _selectedElements.Any(element => element.GroupId is not null);

    private List<string> _materialIcons = [];
    private readonly DialogOptions _iconDialogOptions = new() { FullWidth = true, MaxWidth = MaxWidth.Medium, CloseButton = true };
    private readonly DialogOptions _helpDialogOptions = new() { FullWidth = true, MaxWidth = MaxWidth.Small, CloseButton = true };
    private static List<string>? _cachedMaterialIcons;

    private IReadOnlyList<string> FilteredMaterialIcons => _materialIcons
        .Where(icon => string.IsNullOrWhiteSpace(_iconSearch) || icon.Contains(_iconSearch.Trim(), StringComparison.OrdinalIgnoreCase))
        .OrderBy(icon => icon.StartsWith($"mdi-{_iconSearch.Trim()}", StringComparison.OrdinalIgnoreCase) ? 0 : 1)
        .ThenBy(icon => icon)
        .Take(240)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userId = Guid.Parse(user.FindFirst(ClaimTypes.NameIdentifier)!.Value);
        }

        _board = await BoardService.GetBoardAsync(BoardId);
        if (_board is null) return;

        _hasAccess = BoardService.HasAccess(_board, _userId);
        _canEdit = BoardService.HasAccess(_board, _userId, BoardRole.Editor);
        _commandStack.Clear();
        _lastCommittedBoardSnapshot = CaptureBoardSnapshot(_board);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _board is not null && _hasAccess)
        {
            await _editorSurface.FocusAsync();
        }
    }

    private void SelectTool(Tool tool) => _selectedTool = tool;

    private async Task OpenIconPickerAsync()
    {
        _iconPickerVisible = true;
        _iconSearch = string.Empty;
        await EnsureMaterialIconsLoadedAsync();
    }

    private void CloseIconPicker()
    {
        _iconPickerVisible = false;
        if (_selectedTool == Tool.Icon)
        {
            _selectedTool = Tool.Select;
        }
    }

    private void OpenHelpDialog()
    {
        _helpDialogVisible = true;
    }

    private void CloseHelpDialog()
    {
        _helpDialogVisible = false;
    }

    private void OpenRenameBoardDialog()
    {
        if (_board is null || _board.OwnerId != _userId)
        {
            return;
        }

        _renameBoardTitle = _board.Title;
        _renameDialogVisible = true;
    }

    private void CloseRenameBoardDialog()
    {
        _renameDialogVisible = false;
        _renameBoardTitle = string.Empty;
    }

    private async Task ConfirmRenameBoardAsync()
    {
        if (_board is null || _board.OwnerId != _userId || string.IsNullOrWhiteSpace(_renameBoardTitle))
        {
            return;
        }

        _board.Title = _renameBoardTitle.Trim();
        await BoardService.UpdateBoardAsync(_board);
        _renameDialogVisible = false;
        StateHasChanged();
    }

    private async Task ZoomInAsync()
    {
        if (_canvas is null)
        {
            return;
        }

        await _canvas.ZoomInAsync();
    }

    private async Task ZoomOutAsync()
    {
        if (_canvas is null)
        {
            return;
        }

        await _canvas.ZoomOutAsync();
    }

    private async Task HandleZoomInputChangedAsync(ChangeEventArgs args)
    {
        if (_canvas is null)
        {
            return;
        }

        var rawValue = args.Value?.ToString()?.Trim() ?? string.Empty;
        var numericValue = new string(rawValue.Where(char.IsDigit).ToArray());
        if (!int.TryParse(numericValue, out var percentage))
        {
            _zoomDisplayValue = $"{_zoomPercentage}%";
            StateHasChanged();
            return;
        }

        percentage = Math.Clamp(percentage, 20, 350);
        await _canvas.SetZoomPercentageAsync(percentage);
    }

    private async Task FitToContentAsync()
    {
        if (_canvas is null)
        {
            return;
        }

        await _canvas.FitToContentAsync();
    }

    private async Task EnsureMaterialIconsLoadedAsync()
    {
        if (_materialIcons.Count > 0 || _isLoadingIcons)
        {
            return;
        }

        if (_cachedMaterialIcons is not null)
        {
            _materialIcons = _cachedMaterialIcons;
            return;
        }

        _isLoadingIcons = true;
        _iconLoadError = null;

        try
        {
            var path = Path.Combine(Environment.WebRootPath, "data", "materialdesignicons.json");
            if (!File.Exists(path))
            {
                throw new FileNotFoundException("materialdesignicons.json not found", path);
            }

            await using var stream = File.OpenRead(path);
            var icons = await System.Text.Json.JsonSerializer.DeserializeAsync<List<string>>(stream) ?? [];
            _materialIcons = icons.Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(icon => icon).ToList();
            _cachedMaterialIcons = _materialIcons;
        }
        catch
        {
            _iconLoadError = Localizer["MaterialIconsLoadError"];
        }
        finally
        {
            _isLoadingIcons = false;
            StateHasChanged();
        }
    }

    private Task SelectMaterialIconAsync(string iconName)
    {
        _pendingIconName = iconName;
        _selectedTool = Tool.Icon;
        _iconPickerVisible = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleToolChanged(Tool tool)
    {
        _selectedTool = tool;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleZoomChanged(int percentage)
    {
        _zoomPercentage = percentage;
        _zoomDisplayValue = $"{percentage}%";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (_board is null || !_canEdit) return;

        var hasModifier = e.CtrlKey || e.MetaKey;
        var key = e.Key?.ToLowerInvariant();

        if (hasModifier)
        {
            switch (key)
            {
                case "z" when e.ShiftKey:
                    await RedoAsync();
                    return;
                case "z":
                    await UndoAsync();
                    return;
                case "y":
                    await RedoAsync();
                    return;
                case "a":
                    await SelectAllElementsAsync();
                    return;
                case "c":
                    CopySelectedElement();
                    return;
                case "x":
                    await CutSelectedElementAsync();
                    return;
                case "v":
                    await PasteClipboardElementAsync();
                    return;
                case "g" when e.ShiftKey:
                    await UngroupSelectedElementsAsync();
                    return;
                case "g":
                    await GroupSelectedElementsAsync();
                    return;
            }
        }

        if (e.Key == "Delete" || e.Key == "Backspace")
        {
            await DeleteSelectedElementAsync();
        }
    }

    private async Task FocusEditorSurfaceAsync()
    {
        await _editorSurface.FocusAsync();
    }

    private async Task DeleteSelectedElementAsync()
    {
        if (_board is null || !_canEdit || _selectedElements.Count == 0)
        {
            return;
        }

        foreach (var elementId in _selectedElements.Select(element => element.Id).Distinct().ToList())
        {
            if (_board.Elements.Any(element => element.Id == elementId))
            {
                var cmd = new RemoveElementCommand(elementId);
                cmd.Execute(_board);
            }
        }

        _selectedElement = null;
        _selectedElements = [];
        _canvas?.ClearSelection();
        await SaveBoard();
        StateHasChanged();
    }

    private void CopySelectedElement()
    {
        if (_selectedElements.Count == 0)
        {
            return;
        }

        _clipboardElements = _selectedElements
            .OrderBy(element => element.ZIndex)
            .Select(CloneElement)
            .ToList();
        _pasteSequence = 0;
    }

    private async Task CutSelectedElementAsync()
    {
        if (_selectedElements.Count == 0)
        {
            return;
        }

        CopySelectedElement();
        await DeleteSelectedElementAsync();
    }

    private async Task PasteClipboardElementAsync()
    {
        if (_board is null || _clipboardElements.Count == 0)
        {
            return;
        }

        _pasteSequence++;
        var pastedElements = CloneForPaste(_clipboardElements, _board.Elements.Count, _pasteSequence);
        _board.Elements.AddRange(pastedElements);
        _selectedElements = pastedElements;
        _selectedElement = pastedElements.LastOrDefault();
        if (_canvas is not null)
        {
            await _canvas.SelectElementsAsync(pastedElements);
        }

        await SaveBoard();
        StateHasChanged();
    }

    private async Task SelectAllElementsAsync()
    {
        if (_board is null || _board.Elements.Count == 0 || _canvas is null)
        {
            return;
        }

        var selectableElements = _board.Elements.OrderBy(element => element.ZIndex).ToList();
        _selectedElements = selectableElements;
        _selectedElement = selectableElements.LastOrDefault();
        await _canvas.SelectElementsAsync(selectableElements);
        StateHasChanged();
    }

    private async Task GroupSelectedElementsAsync()
    {
        if (_board is null || !CanGroupSelection)
        {
            return;
        }

        var groupId = Guid.NewGuid();
        foreach (var element in _selectedElements.Where(element => element is not ArrowElement))
        {
            element.GroupId = groupId;
        }

        await SaveBoard();
        StateHasChanged();
    }

    private async Task UngroupSelectedElementsAsync()
    {
        if (_board is null || !CanUngroupSelection)
        {
            return;
        }

        foreach (var element in _selectedElements)
        {
            element.GroupId = null;
        }

        await SaveBoard();
        StateHasChanged();
    }

    private async Task DeleteBoardAsync()
    {
        if (_board is null || _board.OwnerId != _userId)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", string.Format(Localizer["DeleteBoardConfirmation"], _board.Title));
        if (!confirmed)
        {
            return;
        }

        await BoardService.DeleteBoardAsync(_board.Id);
        Navigation.NavigateTo("/");
    }

    private async Task UndoAsync()
    {
        if (_board is null || !_commandStack.CanUndo)
        {
            return;
        }

        _commandStack.Undo(_board);
        await PersistBoardStateAsync();
    }

    private async Task RedoAsync()
    {
        if (_board is null || !_commandStack.CanRedo)
        {
            return;
        }

        _commandStack.Redo(_board);
        await PersistBoardStateAsync();
    }

    private Task HandleBoardChanged() => SaveBoard();

    private async Task SaveBoard(bool recordHistory = true)
    {
        if (_board is null) return;

        var currentSnapshot = CaptureBoardSnapshot(_board);
        var historyRecorded = false;
        if (recordHistory && currentSnapshot != _lastCommittedBoardSnapshot)
        {
            _commandStack.Execute(_board, new BoardSnapshotCommand(_lastCommittedBoardSnapshot, currentSnapshot));
            currentSnapshot = CaptureBoardSnapshot(_board);
            historyRecorded = true;
        }

        _lastCommittedBoardSnapshot = currentSnapshot;

        if (historyRecorded)
        {
            await SyncSelectionToBoardAsync();
        }

        await BoardService.UpdateBoardAsync(_board);
    }

    private async Task PersistBoardStateAsync()
    {
        if (_board is null)
        {
            return;
        }

        _lastCommittedBoardSnapshot = CaptureBoardSnapshot(_board);
        await SyncSelectionToBoardAsync();
        await SaveBoard(recordHistory: false);
        StateHasChanged();
    }

    private void GoBack() => Navigation.NavigateTo("/");

    private async Task ExportJson()
    {
        if (_board is null) return;
        var json = System.Text.Json.JsonSerializer.Serialize(_board, new System.Text.Json.JsonSerializerOptions
        {
            WriteIndented = true,
            PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase,
            Converters = { new System.Text.Json.Serialization.JsonStringEnumConverter() }
        });
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("orimWhiteboard.downloadFile",
            $"{_board.Title}.json", "application/json", base64);
    }

    private async Task OnElementPropertyChanged()
    {
        await SaveBoard();
        StateHasChanged();
    }

    private async Task SyncSelectionToBoardAsync()
    {
        if (_board is null)
        {
            return;
        }

        var selectedIds = _selectedElements.Select(element => element.Id).ToHashSet();
        var nextSelection = _board.Elements
            .Where(element => selectedIds.Contains(element.Id))
            .OrderBy(element => element.ZIndex)
            .ToList();

        _selectedElements = nextSelection;
        _selectedElement = nextSelection.LastOrDefault();

        if (_canvas is not null)
        {
            await _canvas.SelectElementsAsync(nextSelection);
        }
    }

    private static string CaptureBoardSnapshot(Board board)
    {
        return System.Text.Json.JsonSerializer.Serialize(board, new System.Text.Json.JsonSerializerOptions
        {
            Converters = { new System.Text.Json.Serialization.JsonStringEnumConverter() }
        });
    }

    private Task HandleSelectedElementChanged(BoardElement? element)
    {
        _selectedElement = element;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleSelectedElementsChanged(IReadOnlyList<BoardElement> elements)
    {
        _selectedElements = elements.ToList();
        _selectedElement = _selectedElements.LastOrDefault();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private static BoardElement CloneElement(BoardElement element) => element switch
    {
        ShapeElement shape => CloneShape(shape),
        TextElement text => CloneText(text),
        ArrowElement arrow => CloneArrow(arrow),
        StickyNoteElement sticky => CloneSticky(sticky),
        IconElement icon => CloneIcon(icon),
        _ => throw new InvalidOperationException($"Unsupported element type '{element.GetType().Name}'.")
    };

    private static List<BoardElement> CloneForPaste(IReadOnlyList<BoardElement> sources, int startingZIndex, int pasteSequence)
    {
        var clones = sources.Select(CloneElement).ToList();
        var idMap = new Dictionary<Guid, Guid>();
        var groupMap = new Dictionary<Guid, Guid>();

        for (var index = 0; index < sources.Count; index++)
        {
            var source = sources[index];
            var clone = clones[index];
            var newId = Guid.NewGuid();
            idMap[source.Id] = newId;
            clone.Id = newId;
            clone.ZIndex = startingZIndex + index;

            if (source.GroupId is Guid groupId)
            {
                if (!groupMap.TryGetValue(groupId, out var newGroupId))
                {
                    newGroupId = Guid.NewGuid();
                    groupMap[groupId] = newGroupId;
                }

                clone.GroupId = newGroupId;
            }

            if (clone is not ArrowElement)
            {
                var offset = 24 * pasteSequence;
                clone.X += offset;
                clone.Y += offset;
            }
            else if (clone is ArrowElement arrowClone)
            {
                var offset = 24 * pasteSequence;
                if (arrowClone.SourceElementId is null)
                {
                    arrowClone.SourceX += offset;
                    arrowClone.SourceY += offset;
                }

                if (arrowClone.TargetElementId is null)
                {
                    arrowClone.TargetX += offset;
                    arrowClone.TargetY += offset;
                }
            }
        }

        foreach (var arrow in clones.OfType<ArrowElement>())
        {
            if (arrow.SourceElementId is Guid sourceId && idMap.TryGetValue(sourceId, out var mappedSourceId))
            {
                arrow.SourceElementId = mappedSourceId;
            }

            if (arrow.TargetElementId is Guid targetId && idMap.TryGetValue(targetId, out var mappedTargetId))
            {
                arrow.TargetElementId = mappedTargetId;
            }
        }

        return clones;
    }

    private static ShapeElement CloneShape(ShapeElement shape)
    {
        var clone = new ShapeElement
        {
            ShapeType = shape.ShapeType,
            FillColor = shape.FillColor,
            StrokeColor = shape.StrokeColor,
            StrokeWidth = shape.StrokeWidth,
            BorderLineStyle = shape.BorderLineStyle
        };

        CopySharedElementProperties(shape, clone);
        return clone;
    }

    private static TextElement CloneText(TextElement text)
    {
        var clone = new TextElement
        {
            Text = text.Text,
            FontSize = text.FontSize,
            Color = text.Color,
            IsBold = text.IsBold,
            IsItalic = text.IsItalic
        };

        CopySharedElementProperties(text, clone);
        return clone;
    }

    private static ArrowElement CloneArrow(ArrowElement arrow)
    {
        var clone = new ArrowElement
        {
            SourceElementId = arrow.SourceElementId,
            TargetElementId = arrow.TargetElementId,
            SourceX = arrow.SourceX,
            SourceY = arrow.SourceY,
            TargetX = arrow.TargetX,
            TargetY = arrow.TargetY,
            SourceDock = arrow.SourceDock,
            TargetDock = arrow.TargetDock,
            StrokeColor = arrow.StrokeColor,
            StrokeWidth = arrow.StrokeWidth,
            LineStyle = arrow.LineStyle,
            SourceHeadStyle = arrow.SourceHeadStyle,
            TargetHeadStyle = arrow.TargetHeadStyle,
            RouteStyle = arrow.RouteStyle
        };

        CopySharedElementProperties(arrow, clone);
        return clone;
    }

    private static StickyNoteElement CloneSticky(StickyNoteElement sticky)
    {
        var clone = new StickyNoteElement
        {
            Text = sticky.Text,
            BackgroundColor = sticky.BackgroundColor,
            FontSize = sticky.FontSize
        };

        CopySharedElementProperties(sticky, clone);
        return clone;
    }

    private static IconElement CloneIcon(IconElement icon)
    {
        var clone = new IconElement
        {
            IconName = icon.IconName,
            Color = icon.Color
        };

        CopySharedElementProperties(icon, clone);
        return clone;
    }

    private static void CopySharedElementProperties(BoardElement source, BoardElement target)
    {
        target.GroupId = source.GroupId;
        target.X = source.X;
        target.Y = source.Y;
        target.Width = source.Width;
        target.Height = source.Height;
        target.ZIndex = source.ZIndex;
        target.Rotation = source.Rotation;
        target.Label = source.Label;
        target.LabelFontSize = source.LabelFontSize;
        target.LabelHorizontalAlignment = source.LabelHorizontalAlignment;
        target.LabelVerticalAlignment = source.LabelVerticalAlignment;
    }

    public enum Tool
    {
        Select,
        Rectangle,
        Circle,
        Triangle,
        Arrow,
        Icon
    }
}
