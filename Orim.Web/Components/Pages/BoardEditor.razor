    private Task PublishLocalPresenceAsync(BoardPointerPosition? pointer)
    {
        if (_board is null)
        {
            return Task.CompletedTask;
        }

        return BoardPresenceService.UpsertCursorAsync(
            _board.Id,
            new BoardCursorPresence(
                _boardSyncClientId,
