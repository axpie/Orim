@page "/board/{BoardId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.AspNetCore.Components.Forms
@inject BoardService BoardService
@inject BoardChangeNotifier BoardChangeNotifier
@inject BoardPresenceService BoardPresenceService
@inject UserService UserService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject IWebHostEnvironment Environment
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["AppTitle"] - @(_board?.Title ?? Localizer["Board"])</PageTitle>

@if (_board is null)
{
    <MudContainer Class="py-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </MudContainer>
}
else if (!_hasAccess)
{
    <MudContainer Class="py-8">
        <MudAlert Severity="Severity.Error">@Localizer["NoBoardAccess"]</MudAlert>
    </MudContainer>
}
else
{
    var selectedElement = _selectedElements.Count == 1 ? _selectedElements[0] : null;

    <div class="@GetBoardEditorClassName()" style="display: flex; flex-direction: column; height: calc(100vh - 64px); height: calc(100dvh - 64px);">
        @* === Desktop Toolbar === *@
        @if (!_useCompactLayout)
        {
        <MudPaper Elevation="1" Class="orim-board-toolbar orim-board-toolbar-desktop">
            <MudTooltip Text="@Localizer["BackToOverview"]" Arrow="true">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@GoBack" Size="Size.Small" />
            </MudTooltip>
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@_board.Title</MudText>
            @if (_board.OwnerId == _userId)
            {
                <MudTooltip Text="@Localizer["RenameBoard"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@OpenRenameBoardDialog" />
                </MudTooltip>
            }
            <div class="orim-active-participants">
                @foreach (var participant in ActiveParticipants)
                {
                    <MudChip T="string"
                             Size="Size.Small"
                             Variant="Variant.Outlined"
                             Style="@GetParticipantChipStyle(participant.ColorHex)">
                        @participant.DisplayName
                    </MudChip>
                }
            </div>
            <MudSpacer />

            @if (_canEdit)
            {
                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Style="border-radius: 8px;">
                    <MudTooltip Text="@Localizer["SelectToolTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.NearMe"
                                       Color="@(_selectedTool == Tool.Select ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Select))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["DrawRectangleTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Rectangle"
                                       Color="@(_selectedTool == Tool.Rectangle ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Rectangle))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["DrawCircleTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.PanoramaFishEye"
                                       Color="@(_selectedTool == Tool.Circle ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Circle))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["DrawTriangleTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.ChangeHistory"
                                       Color="@(_selectedTool == Tool.Triangle ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Triangle))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["ConnectArrowTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.NorthEast"
                                       Color="@(_selectedTool == Tool.Arrow ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Arrow))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["InsertIconTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.AddReaction"
                                       Color="@(_selectedTool == Tool.Icon ? Color.Primary : Color.Default)"
                                       OnClick="@OpenIconPickerAsync" />
                    </MudTooltip>
                </MudButtonGroup>

                <MudTooltip Text="@Localizer["Undo"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Undo"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   Disabled="@(!_commandStack.CanUndo)"
                                   OnClick="@UndoAsync" />
                </MudTooltip>

                <MudTooltip Text="@Localizer["Redo"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Redo"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   Disabled="@(!_commandStack.CanRedo)"
                                   OnClick="@RedoAsync" />
                </MudTooltip>

                <MudDivider Vertical="true" FlexItem="true" />

                @if (_selectedElement is not null)
                {
                    <MudTooltip Text="@Localizer["DeleteSelectedElement"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@DeleteSelectedElementAsync" />
                    </MudTooltip>
                }

                @if (CanGroupSelection)
                {
                    <MudTooltip Text="@Localizer["GroupSelection"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.CreateNewFolder"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@GroupSelectedElementsAsync" />
                    </MudTooltip>
                }

                @if (CanUngroupSelection)
                {
                    <MudTooltip Text="@Localizer["UngroupSelection"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.FolderOff"
                                       Size="Size.Small"
                                       OnClick="@UngroupSelectedElementsAsync" />
                    </MudTooltip>
                }

                <MudDivider Vertical="true" FlexItem="true" />
            }

            <MudTooltip Text="@Localizer["ZoomOut"]" Arrow="true">
                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                               Size="Size.Small"
                               Color="Color.Default"
                               OnClick="@ZoomOutAsync" />
            </MudTooltip>

              <input value="@_zoomDisplayValue"
                   @onchange="HandleZoomInputChangedAsync"
                  class="orim-board-zoom-input"
                   aria-label="@Localizer["ZoomLevelPercent"]" />

            <MudTooltip Text="@Localizer["ZoomIn"]" Arrow="true">
                <MudIconButton Icon="@Icons.Material.Filled.Add"
                               Size="Size.Small"
                               Color="Color.Default"
                               OnClick="@ZoomInAsync" />
            </MudTooltip>

            <MudTooltip Text="@Localizer["FitToContent"]" Arrow="true">
                <MudIconButton Icon="@Icons.Material.Filled.FitScreen"
                               Size="Size.Small"
                               Color="Color.Default"
                               OnClick="@FitToContentAsync" />
            </MudTooltip>

            <MudTooltip Text="@Localizer["OpenHelp"]" Arrow="true">
                <MudIconButton Icon="@Icons.Material.Filled.Info"
                               Size="Size.Small"
                               Color="Color.Default"
                               OnClick="@OpenHelpDialog" />
            </MudTooltip>

            <MudTooltip Text="@(CanManageBoard ? Localizer["ShareAndAccess"] : Localizer["BoardSettings"])" Arrow="true">
                <MudIconButton Icon="@(CanManageBoard ? Icons.Material.Filled.Group : Icons.Material.Filled.Settings)"
                                Size="Size.Small"
                                Color="Color.Default"
                                OnClick="@OpenBoardSettingsDialogAsync" />
            </MudTooltip>

            @if (_canEdit)
            {
                @if (_selectedElement is not null)
                {
                    <MudTooltip Text="@(_formatTransferActive ? Localizer["FormatTransferCancel"] : Localizer["FormatTransferStart"])" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.FormatPaint"
                                       Size="Size.Small"
                                       Color="@(_formatTransferActive ? Color.Primary : Color.Default)"
                                       OnClick="@ToggleFormatTransfer" />
                    </MudTooltip>
                }

                <MudTooltip Text="@Localizer["Properties"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Tune"
                                   Size="Size.Small"
                                   Color="@(_propertiesPanelOpen ? Color.Primary : Color.Default)"
                                   OnClick="@TogglePropertiesPanel" />
                </MudTooltip>

                <MudTooltip Text="@Localizer["DiagramAssistant"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.AutoAwesome"
                                   Size="Size.Small"
                                   Color="@(_chatPanelOpen ? Color.Primary : Color.Default)"
                                   OnClick="@ToggleChatPanel" />
                </MudTooltip>
            }

            <MudTooltip Text="@Localizer["ExportBoardJson"]" Arrow="true">
                <MudIconButton Icon="@Icons.Material.Filled.FileDownload"
                               Size="Size.Small"
                               OnClick="@ExportJson" />
            </MudTooltip>
        </MudPaper>
        }

        @* === Mobile Toolbar === *@
        @if (_useCompactLayout)
        {
        <MudPaper Elevation="1" Class="orim-board-toolbar orim-board-toolbar-mobile">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@GoBack" Size="Size.Small" />
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 110px;">@_board.Title</MudText>
            <MudSpacer />

            @if (_canEdit)
            {
                @* Select *@
                <MudTooltip Text="@Localizer["SelectToolTooltip"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.NearMe"
                                   Size="Size.Small"
                                   Color="@(_selectedTool == Tool.Select ? Color.Primary : Color.Default)"
                                   OnClick="@(() => SelectTool(Tool.Select))" />
                </MudTooltip>

                @* Shapes popover *@
                <MudMenu Icon="@GetMobileShapeIcon()" Size="Size.Small"
                         Color="@(IsShapeTool(_selectedTool) ? Color.Primary : Color.Default)"
                         Dense="true">
                    <MudMenuItem Icon="@Icons.Material.Filled.Rectangle"
                                 OnClick="@(() => SelectTool(Tool.Rectangle))">@Localizer["DrawRectangleTooltip"]</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.PanoramaFishEye"
                                 OnClick="@(() => SelectTool(Tool.Circle))">@Localizer["DrawCircleTooltip"]</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.ChangeHistory"
                                 OnClick="@(() => SelectTool(Tool.Triangle))">@Localizer["DrawTriangleTooltip"]</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.AddReaction"
                                 OnClick="@OpenIconPickerAsync">@Localizer["InsertIconTooltip"]</MudMenuItem>
                </MudMenu>

                @* Arrow *@
                <MudTooltip Text="@Localizer["ConnectArrowTooltip"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.NorthEast"
                                   Size="Size.Small"
                                   Color="@(_selectedTool == Tool.Arrow ? Color.Primary : Color.Default)"
                                   OnClick="@(() => SelectTool(Tool.Arrow))" />
                </MudTooltip>

                @* Undo *@
                <MudIconButton Icon="@Icons.Material.Filled.Undo"
                               Size="Size.Small"
                               Disabled="@(!_commandStack.CanUndo)"
                               OnClick="@UndoAsync" />

                @* Delete *@
                @if (_selectedElement is not null)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@DeleteSelectedElementAsync" />
                }

                @* Board Settings *@
                <MudIconButton Icon="@(CanManageBoard ? Icons.Material.Filled.Group : Icons.Material.Filled.Settings)"
                               Size="Size.Small"
                               OnClick="@OpenBoardSettingsDialogAsync" />

                @* Element Properties — opens mobile dialog *@
                <MudIconButton Icon="@Icons.Material.Filled.Tune"
                               Size="Size.Small"
                               Color="@(_selectedElement is not null ? Color.Primary : Color.Default)"
                               OnClick="@OpenMobilePropertiesDialog" />
            }
        </MudPaper>
        }

        @* === Mobile Floating Zoom Controls === *@

        <div style="display: flex; flex: 1; min-height: 0; min-width: 0; overflow: hidden;">
            <div @ref="_editorSurface"
                 class="orim-editor-surface"
                 style="flex: 1; min-width: 0; min-height: 0; overflow: hidden; position: relative; outline: none;"
                  @onmousedown="FocusEditorSurfaceAsync"
                  @onkeydown="HandleKeyDown"
                 role="region"
                 aria-label="@Localizer["BoardCanvasRegionLabel"]"
                 aria-describedby="board-editor-shortcuts board-editor-status"
                  tabindex="0">
                <div id="board-editor-shortcuts" class="orim-sr-only">
                    @Localizer["BoardCanvasRegionDescription"]
                </div>
                <div id="board-editor-status" class="orim-sr-only" aria-live="polite" aria-atomic="true">
                    @_screenReaderStatus
                </div>
                <ErrorBoundary @ref="_canvasErrorBoundary">
                    <ChildContent>
                        <WhiteboardCanvas @ref="_canvas" Board="@_board" CanEdit="@_canEdit"
                                          AriaLabel="@Localizer["BoardCanvasRegionLabel"]"
                                          AriaDescription="@Localizer["BoardCanvasRegionDescription"]"
                                          FitRightInset="@CanvasFitRightInset"
                                          RemoteCursors="@_remoteCursors"
                                          OnBoardChanged="@HandleBoardChanged"
                                          OnSelectedElementChanged="@HandleSelectedElementChanged"
                                          OnSelectedElementsChanged="@HandleSelectedElementsChanged"
                                          OnPointerPresenceChanged="@HandlePointerPresenceChangedAsync"
                                          OnZoomChanged="@HandleZoomChanged"
                                          OnToolChanged="@HandleToolChanged"
                                          OnElementDoubleTapped="@OnCanvasElementDoubleTapped"
                                          PendingIconName="@_pendingIconName"
                                          SelectedTool="@_selectedTool" />
                    </ChildContent>
                    <ErrorContent>
                        <MudAlert Severity="Severity.Error" Class="ma-4">
                            @Localizer["CanvasError"]
                            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@RecoverFromCanvasError">
                                @Localizer["Retry"]
                            </MudButton>
                        </MudAlert>
                    </ErrorContent>
                </ErrorBoundary>

                <ChatAssistantPanel Board="@_board"
                                    IsOpen="@_chatPanelOpen"
                                    DockLeftOfProperties="@(_chatPanelOpen && _propertiesPanelOpen)"
                                    OnClose="@CloseChatPanel"
                                    OnBoardChanged="@HandleChatBoardChangedAsync" />

                @if (_canEdit)
                {
                    <ElementPropertiesPanel @key="@(selectedElement?.Id ?? Guid.Empty)"
                                            Board="@_board"
                                            Element="@selectedElement"
                                            SelectionCount="@_selectedElements.Count"
                                            IsOpen="@_propertiesPanelOpen"
                                            OnClose="@ClosePropertiesPanel"
                                            OnPreviewChanged="@OnElementPropertyPreviewChanged"
                                            OnChanged="@OnElementPropertyChanged" />
                }

                @if (_useCompactLayout)
                {
                <div class="orim-mobile-zoom-controls">
                    <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@ZoomOutAsync" />
                    <span class="orim-mobile-zoom-label">@_zoomDisplayValue</span>
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@ZoomInAsync" />
                    <MudIconButton Icon="@Icons.Material.Filled.FitScreen"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@FitToContentAsync" />
                </div>
                }

                @if (_canEdit && _board?.Elements.Count == 0)
                {
                    <MudPaper Class="orim-board-onboarding" Elevation="2">
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">@Localizer["BoardOnboardingTitle"]</MudText>
                        <MudText Typo="Typo.body2" Class="orim-board-muted-text mt-2">@Localizer["BoardOnboardingDescription"]</MudText>
                        <ul class="orim-empty-state-list">
                            <li>@Localizer["BoardOnboardingTipDraw"]</li>
                            <li>@Localizer["BoardOnboardingTipShare"]</li>
                            <li>@Localizer["BoardOnboardingTipImport"]</li>
                        </ul>
                        <div class="d-flex flex-wrap mt-4" style="gap: 12px;">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => SelectTool(Tool.Rectangle))">
                                @Localizer["DrawRectangleTooltip"]
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@OpenHelpDialog">
                                @Localizer["OpenHelp"]
                            </MudButton>
                        </div>
                    </MudPaper>
                }
            </div>
        </div>
    </div>

    <MudDialog @bind-Visible="_iconPickerVisible" Options="_iconDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["MaterialDesignIcons"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_iconSearch"
                          Label="@Localizer["SearchIcon"]"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" />

            @if (_isLoadingIcons)
            {
                <div style="display:flex; align-items:center; justify-content:center; min-height:220px;">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_iconLoadError))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4">@_iconLoadError</MudAlert>
            }
            else
            {
                <MudText Typo="Typo.caption" Class="mt-2 mb-2 orim-board-muted-text">
                    @string.Format(Localizer["IconCount"], FilteredMaterialIcons.Count)
                </MudText>
                <div class="orim-icon-picker-grid">
                    @foreach (var iconName in FilteredMaterialIcons)
                    {
                        <button type="button"
                                @onclick="@(() => SelectMaterialIconAsync(iconName))"
                                class="orim-icon-picker-card">
                            <span class="mdi @iconName orim-icon-picker-preview"></span>
                            <span class="orim-icon-picker-label">@iconName[4..]</span>
                        </button>
                    }
                </div>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@CloseIconPicker">@Localizer["Cancel"]</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_helpDialogVisible" Options="_helpDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["HelpDialogTitle"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["ToolsSectionTitle"]</MudText>
            <ul style="margin:0 0 16px 18px; padding:0; color:#334155; line-height:1.5;">
                <li>@Localizer["HelpToolsSelect"]</li>
                <li>@Localizer["HelpToolsShapes"]</li>
                <li>@Localizer["HelpToolsArrow"]</li>
                <li>@Localizer["HelpToolsIcon"]</li>
            </ul>

            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["SelectionGroupsSectionTitle"]</MudText>
            <ul style="margin:0 0 16px 18px; padding:0; color:#334155; line-height:1.5;">
                <li>@Localizer["HelpSelectionMarquee"]</li>
                <li>@Localizer["HelpSelectionAdditive"]</li>
                <li>@Localizer["HelpSelectionGroupMove"]</li>
                <li>@Localizer["HelpSelectionSingleEdit"]</li>
                <li>@Localizer["HelpSelectionZoom"]</li>
                <li>@Localizer["HelpSelectionSnapDisable"]</li>
            </ul>

            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["ShortcutsSectionTitle"]</MudText>
            <ul style="margin:0 0 0 18px; padding:0; color:#334155; line-height:1.5;">
                <li>@Localizer["ShortcutUndo"]</li>
                <li>@Localizer["ShortcutRedo"]</li>
                <li>@Localizer["ShortcutSelectAll"]</li>
                <li>@Localizer["ShortcutCopy"]</li>
                <li>@Localizer["ShortcutCut"]</li>
                <li>@Localizer["ShortcutPaste"]</li>
                <li>@Localizer["ShortcutGroup"]</li>
                <li>@Localizer["ShortcutUngroup"]</li>
                <li>@Localizer["ShortcutDelete"]</li>
            </ul>
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@CloseHelpDialog">@Localizer["Close"]</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_renameDialogVisible" Options="_helpDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["RenameBoardTitle"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_renameBoardTitle"
                          Label="@Localizer["BoardName"]"
                          Variant="Variant.Outlined"
                          Required="true" />
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@CloseRenameBoardDialog">@Localizer["Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@ConfirmRenameBoardAsync">@Localizer["Save"]</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_boardSettingsDialogVisible" Options="_helpDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["BoardSettings"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2" Class="orim-board-muted-text mb-4">@Localizer["BoardSettingsDescription"]</MudText>

            @if (!string.IsNullOrWhiteSpace(_boardSettingsMessage) && _boardSettingsMessageSeverity is not null)
            {
                <MudAlert Severity="@_boardSettingsMessageSeverity.Value" Dense="true" Class="mb-4">
                    @_boardSettingsMessage
                </MudAlert>
            }

            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["GeneralBoardSettings"]</MudText>
            <MudCheckBox @bind-Value="_boardLabelOutlineEnabled"
                         T="bool"
                         Label="@Localizer["LabelOutlineEnabled"]" />
            <MudCheckBox @bind-Value="_boardArrowOutlineEnabled"
                         T="bool"
                         Label="@Localizer["ArrowOutlineEnabled"]" />
            @if (CanManageBoard)
            {
                <MudSelect T="BoardVisibility" @bind-Value="_boardVisibility" Label="@Localizer["Visibility"]" Variant="Variant.Outlined" Class="mt-4">
                    <MudSelectItem T="BoardVisibility" Value="BoardVisibility.Private">@Localizer["Private"]</MudSelectItem>
                    <MudSelectItem T="BoardVisibility" Value="BoardVisibility.Public">@Localizer["Public"]</MudSelectItem>
                    <MudSelectItem T="BoardVisibility" Value="BoardVisibility.Shared">@Localizer["Shared"]</MudSelectItem>
                </MudSelect>
                <MudText Typo="Typo.caption" Class="orim-board-muted-text">@Localizer["VisibilityExplanation"]</MudText>
            }
            else
            {
                <MudTextField Value="@Localizer[_boardVisibility.ToString()]"
                              Label="@Localizer["Visibility"]"
                              ReadOnly="true"
                              Variant="Variant.Outlined"
                              Class="mt-4" />
                <MudText Typo="Typo.caption" Class="orim-board-muted-text">@Localizer["BoardSettingsOwnerOnly"]</MudText>
            }

            @if (CanManageBoard)
            {
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["ShareAndAccess"]</MudText>
                <MudTextField Value="@GetShareLinkDraftUrl()"
                              Label="@Localizer["ShareLink"]"
                              ReadOnly="true"
                              Variant="Variant.Outlined" />
                <MudText Typo="Typo.caption" Class="orim-board-muted-text">@Localizer["ShareLinkExplanation"]</MudText>
                <div class="d-flex flex-wrap mt-3" style="gap: 8px;">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@GenerateShareLinkDraft">
                        @Localizer["GenerateShareLink"]
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               Disabled="@string.IsNullOrWhiteSpace(GetShareLinkDraftUrl())"
                               OnClick="@CopyShareLinkAsync">
                        @Localizer["CopyShareLink"]
                    </MudButton>
                </div>

                <MudCheckBox @bind-Value="_shareAllowAnonymousEditingDraft"
                             T="bool"
                             Disabled="@(_boardVisibility != BoardVisibility.Shared)"
                             Label="@Localizer["AllowEditingViaShareLink"]"
                             Class="mt-3" />
                <MudCheckBox @bind-Value="_sharePasswordEnabledDraft"
                             T="bool"
                             Disabled="@(_boardVisibility != BoardVisibility.Shared)"
                             Label="@Localizer["RequireSharePassword"]"
                             Class="mt-1" />

                @if (_sharePasswordEnabledDraft)
                {
                    <MudTextField @bind-Value="_sharePasswordDraft"
                                  Label="@Localizer["Password"]"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Password"
                                  Immediate="true"
                                  Class="mt-3" />
                    <MudText Typo="Typo.caption" Class="orim-board-muted-text">
                        @(BoardService.IsSharePasswordProtected(_board!)
                            ? Localizer["LeavePasswordEmpty"]
                            : Localizer["SharePasswordHint"])
                    </MudText>
                }

                <MudDivider Class="my-4" />
                <div class="d-flex justify-space-between align-center mb-2" style="gap: 12px;">
                    <MudText Typo="Typo.subtitle2">@Localizer["Members"]</MudText>
                    <MudText Typo="Typo.caption" Class="orim-board-muted-text">@Localizer["MembersDescription"]</MudText>
                </div>
                @foreach (var member in _memberDrafts.OrderBy(candidate => candidate.Role).ThenBy(candidate => candidate.Username))
                {
                    <MudPaper Class="pa-3 mb-2" Elevation="0" Style="border: 1px solid var(--orim-properties-panel-border);">
                        <div class="d-flex flex-wrap justify-space-between align-center" style="gap: 12px;">
                            <div>
                                <MudText Typo="Typo.subtitle2">@member.Username</MudText>
                                <MudText Typo="Typo.caption" Class="orim-board-muted-text">
                                    @(member.IsOwner ? Localizer["Owner"] : Localizer["Role"])
                                </MudText>
                            </div>
                            @if (member.IsOwner)
                            {
                                <MudChip T="string" Color="Color.Primary">@Localizer["Owner"]</MudChip>
                            }
                            else
                            {
                                <div class="d-flex flex-wrap align-center" style="gap: 8px;">
                                    <MudSelect T="BoardRole" Value="@member.Role" Dense="true" Style="min-width: 140px;"
                                               ValueChanged="@((BoardRole role) => member.Role = role)">
                                        <MudSelectItem T="BoardRole" Value="BoardRole.Editor">@Localizer["Editor"]</MudSelectItem>
                                        <MudSelectItem T="BoardRole" Value="BoardRole.Viewer">@Localizer["Viewer"]</MudSelectItem>
                                    </MudSelect>
                                    <MudIconButton Icon="@Icons.Material.Filled.PersonRemove"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="@(() => RemoveMemberDraft(member.UserId))" />
                                </div>
                            }
                        </div>
                    </MudPaper>
                }

                <div class="d-flex flex-wrap align-end mt-3" style="gap: 12px;">
                    <MudSelect T="Guid?" @bind-Value="_selectedMemberToAddId" Label="@Localizer["AddMember"]" Variant="Variant.Outlined" Style="min-width: 220px;">
                        @foreach (var candidate in AvailableUsersToAdd)
                        {
                            <MudSelectItem T="Guid?" Value="@candidate.Id">@candidate.Username</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect T="BoardRole" @bind-Value="_selectedMemberRoleToAdd" Label="@Localizer["Role"]" Variant="Variant.Outlined" Style="min-width: 160px;">
                        <MudSelectItem T="BoardRole" Value="BoardRole.Editor">@Localizer["Editor"]</MudSelectItem>
                        <MudSelectItem T="BoardRole" Value="BoardRole.Viewer">@Localizer["Viewer"]</MudSelectItem>
                    </MudSelect>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@AddSelectedMemberAsync">
                        @Localizer["AddMember"]
                    </MudButton>
                </div>

                <MudDivider Class="my-4" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["Import"]</MudText>
                <MudText Typo="Typo.caption" Class="orim-board-muted-text">@Localizer["ImportReplaceBoardDescription"]</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mt-2" HtmlTag="label" Disabled="@_isApplyingBoardImport">
                    @Localizer["ImportReplaceBoard"]
                    <InputFile OnChange="@ImportIntoCurrentBoardAsync" accept=".json,application/json" style="display:none" />
                </MudButton>

                <MudDivider Class="my-4" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["Snapshots"]</MudText>
                <MudText Typo="Typo.caption" Class="orim-board-muted-text">@Localizer["SnapshotsDescription"]</MudText>
                <div class="d-flex flex-wrap align-end mt-2" style="gap: 12px;">
                    <MudTextField @bind-Value="_snapshotName" Label="@Localizer["SnapshotName"]" Variant="Variant.Outlined" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@CreateSnapshotAsync">
                        @Localizer["CreateSnapshot"]
                    </MudButton>
                </div>

                @if (_board?.Snapshots.Count > 0)
                {
                    @foreach (var snapshot in _board.Snapshots.OrderByDescending(candidate => candidate.CreatedAt))
                    {
                        <MudPaper Class="pa-3 mt-2" Elevation="0" Style="border: 1px solid var(--orim-properties-panel-border);">
                            <div class="d-flex flex-wrap justify-space-between align-center" style="gap: 12px;">
                                <div>
                                    <MudText Typo="Typo.subtitle2">@snapshot.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="orim-board-muted-text">
                                        @string.Format(Localizer["SnapshotMetadata"], snapshot.CreatedByUsername, snapshot.CreatedAt.ToString("g"))
                                    </MudText>
                                </div>
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => RestoreSnapshotAsync(snapshot.Id))">
                                    @Localizer["RestoreSnapshot"]
                                </MudButton>
                            </div>
                        </MudPaper>
                    }
                }
                else
                {
                    <MudText Typo="Typo.caption" Class="orim-board-muted-text mt-2">@Localizer["NoSnapshots"]</MudText>
                }
            }
            else
            {
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.caption" Class="orim-board-muted-text">@Localizer["BoardSettingsOwnerOnly"]</MudText>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@CloseBoardSettingsDialog">@Localizer["Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@ConfirmBoardSettingsAsync">@Localizer["Save"]</MudButton>
        </DialogActions>
    </MudDialog>

    @* === Mobile Properties Dialog === *@
    <MudDialog @bind-Visible="_mobilePropertiesDialogVisible" Options="_mobilePropertiesDialogOptions">
        <TitleContent>
            <div style="display:flex; align-items:center; gap:8px;">
                <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" />
                <MudText Typo="Typo.h6">@Localizer["Properties"]</MudText>
            </div>
        </TitleContent>
        <DialogContent>
            @if (_board is not null && _canEdit)
            {
                var dlgSelectedElement = _selectedElements.Count == 1 ? _selectedElements[0] : null;
                <ElementPropertiesPanel @key="@(dlgSelectedElement?.Id ?? Guid.Empty)"
                                        Board="@_board"
                                        Element="@dlgSelectedElement"
                                        SelectionCount="@_selectedElements.Count"
                                        IsOpen="true"
                                        DialogMode="true"
                                        OnClose="@CloseMobilePropertiesDialog"
                                        OnPreviewChanged="@OnElementPropertyPreviewChanged"
                                        OnChanged="@OnMobilePropertyChanged" />
            }
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@CloseMobilePropertiesDialog">@Localizer["Close"]</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    [Parameter] public Guid BoardId { get; set; }

    private Board? _board;
    private Guid _userId;
    private string _username = string.Empty;
    private bool _hasAccess;
    private bool _canEdit;
    private Tool _selectedTool = Tool.Select;
    private readonly CommandStack _commandStack = new();
    private WhiteboardCanvas? _canvas;
    private ErrorBoundary? _canvasErrorBoundary;
    private BoardElement? _selectedElement;
    private List<BoardElement> _selectedElements = [];
    private ElementReference _editorSurface;
    private bool _iconPickerVisible;
    private bool _helpDialogVisible;
    private bool _renameDialogVisible;
    private bool _boardSettingsDialogVisible;
    private bool _mobilePropertiesDialogVisible;
    private bool _chatPanelOpen;
    private bool _propertiesPanelOpen = false;
    private bool _boardLabelOutlineEnabled = true;
    private bool _boardArrowOutlineEnabled = true;
    private BoardVisibility _boardVisibility = BoardVisibility.Private;
    private bool _formatTransferActive;
    private Guid? _formatTransferSourceId;
    private bool _isLoadingIcons;
    private bool _isApplyingBoardImport;
    private string _iconSearch = string.Empty;
    private string? _iconLoadError;
    private string? _pendingIconName;
    private List<BoardElement> _clipboardElements = [];
    private int _pasteSequence;
    private string _lastCommittedBoardSnapshot = string.Empty;
    private int _zoomPercentage = 100;
    private string _zoomDisplayValue = "100%";
    private string _renameBoardTitle = string.Empty;
    private string _snapshotName = string.Empty;
    private string? _shareLinkTokenDraft;
    private bool _shareAllowAnonymousEditingDraft;
    private bool _sharePasswordEnabledDraft;
    private string _sharePasswordDraft = string.Empty;
    private string? _boardSettingsMessage;
    private Severity? _boardSettingsMessageSeverity;
    private string _screenReaderStatus = string.Empty;
    private Guid? _selectedMemberToAddId;
    private BoardRole _selectedMemberRoleToAdd = BoardRole.Editor;
    private bool _useCompactLayout;
    private readonly string _boardSyncClientId = Guid.NewGuid().ToString("N");
    private IDisposable? _boardChangeSubscription;
    private IDisposable? _cursorPresenceSubscription;
    private readonly CancellationTokenSource _presenceHeartbeatCancellation = new();
    private Task? _presenceHeartbeatTask;
    private IReadOnlyList<BoardCursorPresence> _remoteCursors = [];
    private BoardPointerPosition? _localPointerPosition;
    private string _cursorColor = "#2563eb";
    private bool CanGroupSelection => _selectedElements.Count(element => element is not ArrowElement) > 1;
    private bool CanUngroupSelection => _selectedElements.Any(element => element.GroupId is not null);
    private bool CanManageBoard => _board?.OwnerId == _userId;
    private IReadOnlyList<BoardCursorPresence> ActiveParticipants =>
    [
        new(_boardSyncClientId, string.IsNullOrWhiteSpace(_username) ? "User" : _username, _cursorColor, _localPointerPosition?.WorldX, _localPointerPosition?.WorldY, DateTime.UtcNow),
        .. _remoteCursors
    ];
    private double CanvasFitRightInset => (_propertiesPanelOpen ? 388d : 0d) + (_chatPanelOpen ? 388d : 0d);
    private List<User> _availableUsers = [];
    private List<MemberDraft> _memberDrafts = [];

    private List<string> _materialIcons = [];
    private readonly DialogOptions _iconDialogOptions = new() { FullWidth = true, MaxWidth = MaxWidth.Medium, CloseButton = true };
    private readonly DialogOptions _helpDialogOptions = new() { FullWidth = true, MaxWidth = MaxWidth.Small, CloseButton = true };
    private readonly DialogOptions _mobilePropertiesDialogOptions = new() { FullWidth = true, MaxWidth = MaxWidth.Small, CloseButton = true };
    private static List<string>? _cachedMaterialIcons;

    private record struct ViewportProfile(double Width, double Height, bool IsCompact);
    private sealed class MemberDraft
    {
        public Guid UserId { get; init; }
        public string Username { get; init; } = string.Empty;
        public BoardRole Role { get; set; }
        public bool IsOwner { get; init; }
    }

    private IReadOnlyList<string> _filteredMaterialIconsCache = [];
    private string _lastIconSearchValue = "\0";
    private IEnumerable<User> AvailableUsersToAdd => _availableUsers
        .Where(user => user.IsActive)
        .Where(user => _board is not null && user.Id != _board.OwnerId)
        .Where(user => _memberDrafts.All(member => member.UserId != user.Id))
        .OrderBy(user => user.Username);

    private IReadOnlyList<string> FilteredMaterialIcons
    {
        get
        {
            if (_iconSearch == _lastIconSearchValue)
                return _filteredMaterialIconsCache;

            _lastIconSearchValue = _iconSearch;
            var search = (_iconSearch ?? string.Empty).Trim();
            _filteredMaterialIconsCache = _materialIcons
                .Where(icon => string.IsNullOrWhiteSpace(search) || icon.Contains(search, StringComparison.OrdinalIgnoreCase))
                .OrderBy(icon => icon.StartsWith($"mdi-{search}", StringComparison.OrdinalIgnoreCase) ? 0 : 1)
                .ThenBy(icon => icon)
                .Take(240)
                .ToList();
            return _filteredMaterialIconsCache;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userId = Guid.Parse(user.FindFirst(ClaimTypes.NameIdentifier)!.Value);
            _username = user.Identity.Name ?? string.Empty;
        }

        _board = await BoardService.GetBoardAsync(BoardId);
        if (_board is null) return;

        _hasAccess = BoardService.HasAccess(_board, _userId);
        _canEdit = BoardService.HasAccess(_board, _userId, BoardRole.Editor);
        _boardLabelOutlineEnabled = _board.LabelOutlineEnabled;
        _boardArrowOutlineEnabled = _board.ArrowOutlineEnabled;
        _boardVisibility = _board.Visibility;
        _cursorColor = BoardPresenceIdentity.ResolveColor(_userId != Guid.Empty ? _userId.ToString() : _username);
        _boardChangeSubscription = _hasAccess
            ? BoardChangeNotifier.Subscribe(_board.Id, _boardSyncClientId, HandleExternalBoardChangeAsync)
            : null;
        _cursorPresenceSubscription = _hasAccess
            ? BoardPresenceService.Subscribe(_board.Id, $"cursor-{_boardSyncClientId}", HandleCursorPresenceChangedAsync)
            : null;
        if (_hasAccess)
        {
            await PublishLocalPresenceAsync(null);
            _presenceHeartbeatTask ??= StartPresenceHeartbeatAsync();
        }
        _commandStack.Clear();
        _lastCommittedBoardSnapshot = CaptureBoardSnapshot(_board);
        UpdateScreenReaderStatus(Localizer["BoardLoadedAnnouncement", _board.Title]);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _board is not null && _hasAccess)
        {
            await JS.InvokeVoidAsync("orimWhiteboard.registerPresenceLifecycle", _board.Id, _boardSyncClientId);
            await _editorSurface.FocusAsync();
            var viewport = await JS.InvokeAsync<ViewportProfile>("orimWhiteboard.getViewportProfile");
            _useCompactLayout = viewport.IsCompact;
            if (!_useCompactLayout)
            {
                _propertiesPanelOpen = true;
            }

            StateHasChanged();
        }
    }

    private string GetBoardEditorClassName() => _useCompactLayout
        ? "orim-board-editor orim-board-editor--compact"
        : "orim-board-editor";

    private void SelectTool(Tool tool) => _selectedTool = tool;

    private void ToggleFormatTransfer()
    {
        if (_selectedElement is null)
        {
            _formatTransferActive = false;
            _formatTransferSourceId = null;
            return;
        }

        if (_formatTransferActive)
        {
            _formatTransferActive = false;
            _formatTransferSourceId = null;
            return;
        }

        _formatTransferSourceId = _selectedElement.Id;
        _formatTransferActive = true;
        SelectTool(Tool.Select);
    }

    private async Task OpenIconPickerAsync()
    {
        _iconPickerVisible = true;
        _iconSearch = string.Empty;
        await EnsureMaterialIconsLoadedAsync();
    }

    private void CloseIconPicker()
    {
        _iconPickerVisible = false;
        if (_selectedTool == Tool.Icon)
        {
            _selectedTool = Tool.Select;
        }
    }

    private void ToggleChatPanel() => _chatPanelOpen = !_chatPanelOpen;

    private void CloseChatPanel() => _chatPanelOpen = false;

    private void RecoverFromCanvasError() => _canvasErrorBoundary?.Recover();

    private void TogglePropertiesPanel() => _propertiesPanelOpen = !_propertiesPanelOpen;

    private void ClosePropertiesPanel() => _propertiesPanelOpen = false;

    private async Task HandleChatBoardChangedAsync()
    {
        if (_board is null) return;
        _lastCommittedBoardSnapshot = CaptureBoardSnapshot(_board);
        await BoardService.UpdateBoardAsync(_board, _boardSyncClientId);
        if (_canvas is not null)
        {
            _canvas.ForceRerender();
            await _canvas.FitToContentAsync();
        }
    }

    private void OpenHelpDialog()
    {
        _helpDialogVisible = true;
    }

    private async Task OpenBoardSettingsDialogAsync()
    {
        if (_board is null)
        {
            return;
        }

        InitializeBoardSettingsDrafts();
        if (CanManageBoard)
        {
            _availableUsers = await UserService.GetAllUsersAsync();
        }

        _boardSettingsDialogVisible = true;
    }

    private void OpenMobilePropertiesDialog() => _mobilePropertiesDialogVisible = true;

    private void CloseMobilePropertiesDialog() => _mobilePropertiesDialogVisible = false;

    private void OnCanvasElementDoubleTapped()
    {
        if (_selectedElement is not null && _canEdit)
            OpenMobilePropertiesDialog();
    }

    private async Task OnMobilePropertyChanged()
    {
        await SaveBoard();
        StateHasChanged();
    }

    private string GetMobileShapeIcon() => _selectedTool switch
    {
        Tool.Circle => Icons.Material.Filled.PanoramaFishEye,
        Tool.Triangle => Icons.Material.Filled.ChangeHistory,
        _ => Icons.Material.Filled.Rectangle
    };

    private static bool IsShapeTool(Tool tool) =>
        tool is Tool.Rectangle or Tool.Circle or Tool.Triangle;

    private void CloseBoardSettingsDialog()
    {
        _boardSettingsDialogVisible = false;
        _boardSettingsMessage = null;
        _boardSettingsMessageSeverity = null;
        InitializeBoardSettingsDrafts();
    }

    private async Task ConfirmBoardSettingsAsync()
    {
        if (_board is null)
        {
            return;
        }

        if (CanManageBoard
            && _boardVisibility == BoardVisibility.Shared
            && _sharePasswordEnabledDraft
            && string.IsNullOrWhiteSpace(_sharePasswordDraft)
            && !BoardService.IsSharePasswordProtected(_board))
        {
            SetBoardSettingsMessage(Localizer["SharePasswordRequired"], Severity.Error, announce: true);
            return;
        }

        _board.LabelOutlineEnabled = _boardLabelOutlineEnabled;
        _board.ArrowOutlineEnabled = _boardArrowOutlineEnabled;

        if (CanManageBoard)
        {
            _board.Visibility = _boardVisibility;
            _board.ShareLinkToken = _boardVisibility == BoardVisibility.Shared
                ? string.IsNullOrWhiteSpace(_shareLinkTokenDraft) ? BoardService.GenerateShareLinkToken() : _shareLinkTokenDraft
                : _shareLinkTokenDraft;
            _board.SharedAllowAnonymousEditing = _boardVisibility == BoardVisibility.Shared && _shareAllowAnonymousEditingDraft;

            if (_boardVisibility == BoardVisibility.Shared)
            {
                if (_sharePasswordEnabledDraft)
                {
                    if (!string.IsNullOrWhiteSpace(_sharePasswordDraft))
                    {
                        BoardService.SetSharePassword(_board, _sharePasswordDraft);
                    }
                }
                else
                {
                    BoardService.ClearSharePassword(_board);
                }
            }
            else
            {
                _board.SharedAllowAnonymousEditing = false;
                BoardService.ClearSharePassword(_board);
            }
        }

        if (CanManageBoard)
        {
            var ownerUsername = _board.Members.FirstOrDefault(member => member.UserId == _board.OwnerId)?.Username
                ?? _username;
            _board.Members =
            [
                new BoardMember
                {
                    UserId = _board.OwnerId,
                    Username = ownerUsername,
                    Role = BoardRole.Owner
                }
            ];

            foreach (var member in _memberDrafts.Where(candidate => !candidate.IsOwner))
            {
                var user = _availableUsers.FirstOrDefault(candidate => candidate.Id == member.UserId)
                    ?? new User { Id = member.UserId, Username = member.Username, IsActive = true };
                BoardService.AddMember(_board, user, member.Role);
            }
        }

        _boardSettingsDialogVisible = false;
        await SaveBoard();
        UpdateScreenReaderStatus(Localizer["BoardSettingsSavedAnnouncement"]);
        _canvas?.ForceRerender();
        StateHasChanged();
    }

    private void CloseHelpDialog()
    {
        _helpDialogVisible = false;
    }

    private void OpenRenameBoardDialog()
    {
        if (_board is null || _board.OwnerId != _userId)
        {
            return;
        }

        _renameBoardTitle = _board.Title;
        _renameDialogVisible = true;
    }

    private void CloseRenameBoardDialog()
    {
        _renameDialogVisible = false;
        _renameBoardTitle = string.Empty;
    }

    private async Task ConfirmRenameBoardAsync()
    {
        if (_board is null || _board.OwnerId != _userId || string.IsNullOrWhiteSpace(_renameBoardTitle))
        {
            return;
        }

        _board.Title = _renameBoardTitle.Trim();
        await BoardService.UpdateBoardAsync(_board, _boardSyncClientId);
        _renameDialogVisible = false;
        StateHasChanged();
    }

    private async Task ZoomInAsync()
    {
        if (_canvas is null)
        {
            return;
        }

        await _canvas.ZoomInAsync();
    }

    private async Task ZoomOutAsync()
    {
        if (_canvas is null)
        {
            return;
        }

        await _canvas.ZoomOutAsync();
    }

    private async Task HandleZoomInputChangedAsync(ChangeEventArgs args)
    {
        if (_canvas is null)
        {
            return;
        }

        var rawValue = args.Value?.ToString()?.Trim() ?? string.Empty;
        var numericValue = new string(rawValue.Where(char.IsDigit).ToArray());
        if (!int.TryParse(numericValue, out var percentage))
        {
            _zoomDisplayValue = $"{_zoomPercentage}%";
            StateHasChanged();
            return;
        }

        percentage = Math.Clamp(percentage, 20, 350);
        await _canvas.SetZoomPercentageAsync(percentage);
    }

    private async Task FitToContentAsync()
    {
        if (_canvas is null)
        {
            return;
        }

        await _canvas.FitToContentAsync();
    }

    private async Task EnsureMaterialIconsLoadedAsync()
    {
        if (_materialIcons.Count > 0 || _isLoadingIcons)
        {
            return;
        }

        if (_cachedMaterialIcons is not null)
        {
            _materialIcons = _cachedMaterialIcons;
            return;
        }

        _isLoadingIcons = true;
        _iconLoadError = null;

        try
        {
            var path = Path.Combine(Environment.WebRootPath, "data", "materialdesignicons.json");
            if (!File.Exists(path))
            {
                throw new FileNotFoundException("materialdesignicons.json not found", path);
            }

            await using var stream = File.OpenRead(path);
            var icons = await System.Text.Json.JsonSerializer.DeserializeAsync<List<string>>(stream) ?? [];
            _materialIcons = icons.Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(icon => icon).ToList();
            _cachedMaterialIcons = _materialIcons;
        }
        catch
        {
            _iconLoadError = Localizer["MaterialIconsLoadError"];
        }
        finally
        {
            _isLoadingIcons = false;
            StateHasChanged();
        }
    }

    private Task SelectMaterialIconAsync(string iconName)
    {
        _pendingIconName = iconName;
        _selectedTool = Tool.Icon;
        _iconPickerVisible = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleToolChanged(Tool tool)
    {
        _selectedTool = tool;
        UpdateScreenReaderStatus(Localizer["ToolSelectedAnnouncement", GetToolLabel(tool)]);
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleZoomChanged(int percentage)
    {
        _zoomPercentage = percentage;
        _zoomDisplayValue = $"{percentage}%";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (_board is null || !_canEdit) return;

        var hasModifier = e.CtrlKey || e.MetaKey;
        var key = e.Key?.ToLowerInvariant();

        if (hasModifier)
        {
            switch (key)
            {
                case "z" when e.ShiftKey:
                    await RedoAsync();
                    return;
                case "z":
                    await UndoAsync();
                    return;
                case "y":
                    await RedoAsync();
                    return;
                case "a":
                    await SelectAllElementsAsync();
                    return;
                case "c":
                    CopySelectedElement();
                    return;
                case "x":
                    await CutSelectedElementAsync();
                    return;
                case "v":
                    await PasteClipboardElementAsync();
                    return;
                case "g" when e.ShiftKey:
                    await UngroupSelectedElementsAsync();
                    return;
                case "g":
                    await GroupSelectedElementsAsync();
                    return;
            }
        }

        if (e.Key == "Escape")
        {
            await ClearSelectionAsync();
            return;
        }

        if (TryGetKeyboardMoveDelta(e, out var deltaX, out var deltaY))
        {
            await MoveSelectedElementsAsync(deltaX, deltaY);
            return;
        }

        if (e.Key == "Delete" || e.Key == "Backspace")
        {
            await DeleteSelectedElementAsync();
        }
    }

    private async Task FocusEditorSurfaceAsync()
    {
        await _editorSurface.FocusAsync();
    }

    private async Task DeleteSelectedElementAsync()
    {
        if (_board is null || !_canEdit || _selectedElements.Count == 0)
        {
            return;
        }

        foreach (var elementId in _selectedElements.Select(element => element.Id).Distinct().ToList())
        {
            if (_formatTransferSourceId == elementId)
            {
                _formatTransferActive = false;
                _formatTransferSourceId = null;
            }

            if (_board.Elements.Any(element => element.Id == elementId))
            {
                var cmd = new RemoveElementCommand(elementId);
                cmd.Execute(_board);
            }
        }

        _selectedElement = null;
        _selectedElements = [];
        _canvas?.ClearSelection();
        await SaveBoard();
        UpdateScreenReaderStatus(Localizer["SelectionDeletedAnnouncement"]);
        StateHasChanged();
    }

    private void CopySelectedElement()
    {
        if (_selectedElements.Count == 0)
        {
            return;
        }

        _clipboardElements = _selectedElements
            .OrderBy(element => element.ZIndex)
            .Select(CloneElement)
            .ToList();
        _pasteSequence = 0;
    }

    private async Task CutSelectedElementAsync()
    {
        if (_selectedElements.Count == 0)
        {
            return;
        }

        CopySelectedElement();
        await DeleteSelectedElementAsync();
    }

    private async Task PasteClipboardElementAsync()
    {
        if (_board is null || _clipboardElements.Count == 0)
        {
            return;
        }

        _pasteSequence++;
        var pastedElements = CloneForPaste(_clipboardElements, _board.Elements.Count, _pasteSequence);
        _board.Elements.AddRange(pastedElements);
        _selectedElements = pastedElements;
        _selectedElement = pastedElements.LastOrDefault();
        if (_canvas is not null)
        {
            await _canvas.SelectElementsAsync(pastedElements);
        }

        await SaveBoard();
        StateHasChanged();
    }

    private async Task SelectAllElementsAsync()
    {
        if (_board is null || _board.Elements.Count == 0 || _canvas is null)
        {
            return;
        }

        var selectableElements = _board.Elements.OrderBy(element => element.ZIndex).ToList();
        _selectedElements = selectableElements;
        _selectedElement = selectableElements.LastOrDefault();
        await _canvas.SelectElementsAsync(selectableElements);
        UpdateScreenReaderStatus(Localizer["SelectionCountAnnouncement", selectableElements.Count]);
        StateHasChanged();
    }

