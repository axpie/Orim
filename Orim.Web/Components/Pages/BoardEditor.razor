    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (_board is null || !_canEdit) return;

        var hasModifier = e.CtrlKey || e.MetaKey;
        var key = e.Key?.ToLowerInvariant();

        if (hasModifier)
        {
            switch (key)
            {
                case "z" when e.ShiftKey:
                    await RedoAsync();
                    return;
                case "z":
                    await UndoAsync();
                    return;
                case "y":
                    await RedoAsync();
                    return;
                case "a":
                    await SelectAllElementsAsync();
                    return;
                case "c":
                    CopySelectedElement();
                    return;
                case "x":
                    await CutSelectedElementAsync();
                    return;
                case "v":
                    await PasteClipboardElementAsync();
                    return;
                case "g" when e.ShiftKey:
                    await UngroupSelectedElementsAsync();
                    return;
                case "g":
                    await GroupSelectedElementsAsync();
                    return;
            }
        }

        if (e.Key == "Delete" || e.Key == "Backspace")
        {
            await DeleteSelectedElementAsync();
        }
    }

