        }

        _commandStack.Undo(_board);
        await PersistBoardStateAsync();
    }

    private async Task RedoAsync()
    {
        if (_board is null || !_commandStack.CanRedo)
        {
            return;
        }

        _commandStack.Redo(_board);
        await PersistBoardStateAsync();
    }

    private Task HandleBoardChanged() => SaveBoard();

    private async Task SaveBoard(bool recordHistory = true)
    {
        if (_board is null) return;

        var currentSnapshot = CaptureBoardSnapshot(_board);
        var historyRecorded = false;
        if (recordHistory && currentSnapshot != _lastCommittedBoardSnapshot)
        {
            _commandStack.Execute(_board, new BoardSnapshotCommand(_lastCommittedBoardSnapshot, currentSnapshot));
            currentSnapshot = CaptureBoardSnapshot(_board);
            historyRecorded = true;
        }

        _lastCommittedBoardSnapshot = currentSnapshot;

        if (historyRecorded)
        {
            await SyncSelectionToBoardAsync();
        }

        await BoardService.UpdateBoardAsync(_board);
    }

    private async Task PersistBoardStateAsync()
    {
        if (_board is null)
        {
            return;
        }

        _lastCommittedBoardSnapshot = CaptureBoardSnapshot(_board);
        await SyncSelectionToBoardAsync();
        await SaveBoard(recordHistory: false);
        StateHasChanged();
    }

