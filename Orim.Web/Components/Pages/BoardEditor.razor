@page "/board/{BoardId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject BoardService BoardService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject IWebHostEnvironment Environment
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["AppTitle"] - @(_board?.Title ?? Localizer["Board"])</PageTitle>

@if (_board is null)
{
    <MudContainer Class="py-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </MudContainer>
}
else if (!_hasAccess)
{
    <MudContainer Class="py-8">
        <MudAlert Severity="Severity.Error">@Localizer["NoBoardAccess"]</MudAlert>
    </MudContainer>
}
else
{
    var selectedElement = _selectedElements.Count == 1 ? _selectedElements[0] : null;

    <div style="display: flex; flex-direction: column; height: calc(100vh - 64px);">
        @* === Desktop Toolbar === *@
        <MudPaper Elevation="1" Class="orim-board-toolbar orim-board-toolbar-desktop">
            <MudTooltip Text="@Localizer["BackToOverview"]" Arrow="true">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@GoBack" Size="Size.Small" />
            </MudTooltip>
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@_board.Title</MudText>
            @if (_board.OwnerId == _userId)
            {
                <MudTooltip Text="@Localizer["RenameBoard"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@OpenRenameBoardDialog" />
                </MudTooltip>
            }
            <MudSpacer />

            @if (_canEdit)
            {
                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Style="border-radius: 8px;">
                    <MudTooltip Text="@Localizer["SelectToolTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.NearMe"
                                       Color="@(_selectedTool == Tool.Select ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Select))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["DrawRectangleTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Rectangle"
                                       Color="@(_selectedTool == Tool.Rectangle ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Rectangle))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["DrawCircleTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.PanoramaFishEye"
                                       Color="@(_selectedTool == Tool.Circle ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Circle))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["DrawTriangleTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.ChangeHistory"
                                       Color="@(_selectedTool == Tool.Triangle ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Triangle))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["ConnectArrowTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.NorthEast"
                                       Color="@(_selectedTool == Tool.Arrow ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(Tool.Arrow))" />
                    </MudTooltip>
                    <MudTooltip Text="@Localizer["InsertIconTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.AddReaction"
                                       Color="@(_selectedTool == Tool.Icon ? Color.Primary : Color.Default)"
                                       OnClick="@OpenIconPickerAsync" />
                    </MudTooltip>
                </MudButtonGroup>

                <MudTooltip Text="@Localizer["Undo"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Undo"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   Disabled="@(!_commandStack.CanUndo)"
                                   OnClick="@UndoAsync" />
                </MudTooltip>

                <MudTooltip Text="@Localizer["Redo"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Redo"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   Disabled="@(!_commandStack.CanRedo)"
                                   OnClick="@RedoAsync" />
                </MudTooltip>

                <MudDivider Vertical="true" FlexItem="true" />

                <MudTooltip Text="@Localizer["ZoomOut"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@ZoomOutAsync" />
                </MudTooltip>

                  <input value="@_zoomDisplayValue"
                       @onchange="HandleZoomInputChangedAsync"
                      class="orim-board-zoom-input"
                       aria-label="@Localizer["ZoomLevelPercent"]" />

                <MudTooltip Text="@Localizer["ZoomIn"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@ZoomInAsync" />
                </MudTooltip>

                <MudTooltip Text="@Localizer["FitToContent"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.FitScreen"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@FitToContentAsync" />
                </MudTooltip>

                <MudTooltip Text="@Localizer["OpenHelp"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Info"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@OpenHelpDialog" />
                </MudTooltip>

                <MudTooltip Text="@Localizer["BoardSettings"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Settings"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@OpenBoardSettingsDialog" />
                </MudTooltip>

                @if (_selectedElement is not null)
                {
                    <MudTooltip Text="@Localizer["DeleteSelectedElement"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@DeleteSelectedElementAsync" />
                    </MudTooltip>
                }

                @if (CanGroupSelection)
                {
                    <MudTooltip Text="@Localizer["GroupSelection"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.CreateNewFolder"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@GroupSelectedElementsAsync" />
                    </MudTooltip>
                }

                @if (CanUngroupSelection)
                {
                    <MudTooltip Text="@Localizer["UngroupSelection"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.FolderOff"
                                       Size="Size.Small"
                                       OnClick="@UngroupSelectedElementsAsync" />
                    </MudTooltip>
                }

                <MudDivider Vertical="true" FlexItem="true" />
            }

            @if (_canEdit)
            {
                @if (_selectedElement is not null)
                {
                    <MudTooltip Text="@(_formatTransferActive ? "Formatübertragung abbrechen" : "Format übertragen")" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.FormatPaint"
                                       Size="Size.Small"
                                       Color="@(_formatTransferActive ? Color.Primary : Color.Default)"
                                       OnClick="@ToggleFormatTransfer" />
                    </MudTooltip>
                }

                <MudTooltip Text="@Localizer["Properties"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Tune"
                                   Size="Size.Small"
                                   Color="@(_propertiesPanelOpen ? Color.Primary : Color.Default)"
                                   OnClick="@TogglePropertiesPanel" />
                </MudTooltip>

                <MudTooltip Text="@Localizer["DiagramAssistant"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.AutoAwesome"
                                   Size="Size.Small"
                                   Color="@(_chatPanelOpen ? Color.Primary : Color.Default)"
                                   OnClick="@ToggleChatPanel" />
                </MudTooltip>
            }

            <MudTooltip Text="@Localizer["ExportBoardJson"]" Arrow="true">
                <MudIconButton Icon="@Icons.Material.Filled.FileDownload"
                               Size="Size.Small"
                               OnClick="@ExportJson" />
            </MudTooltip>
        </MudPaper>

        @* === Mobile Toolbar === *@
        <MudPaper Elevation="1" Class="orim-board-toolbar orim-board-toolbar-mobile">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@GoBack" Size="Size.Small" />
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 110px;">@_board.Title</MudText>
            <MudSpacer />

            @if (_canEdit)
            {
                @* Select *@
                <MudTooltip Text="@Localizer["SelectToolTooltip"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.NearMe"
                                   Size="Size.Small"
                                   Color="@(_selectedTool == Tool.Select ? Color.Primary : Color.Default)"
                                   OnClick="@(() => SelectTool(Tool.Select))" />
                </MudTooltip>

                @* Shapes popover *@
                <MudMenu Icon="@GetMobileShapeIcon()" Size="Size.Small"
                         Color="@(IsShapeTool(_selectedTool) ? Color.Primary : Color.Default)"
                         Dense="true">
                    <MudMenuItem Icon="@Icons.Material.Filled.Rectangle"
                                 OnClick="@(() => SelectTool(Tool.Rectangle))">@Localizer["DrawRectangleTooltip"]</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.PanoramaFishEye"
                                 OnClick="@(() => SelectTool(Tool.Circle))">@Localizer["DrawCircleTooltip"]</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.ChangeHistory"
                                 OnClick="@(() => SelectTool(Tool.Triangle))">@Localizer["DrawTriangleTooltip"]</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.AddReaction"
                                 OnClick="@OpenIconPickerAsync">@Localizer["InsertIconTooltip"]</MudMenuItem>
                </MudMenu>

                @* Arrow *@
                <MudTooltip Text="@Localizer["ConnectArrowTooltip"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.NorthEast"
                                   Size="Size.Small"
                                   Color="@(_selectedTool == Tool.Arrow ? Color.Primary : Color.Default)"
                                   OnClick="@(() => SelectTool(Tool.Arrow))" />
                </MudTooltip>

                @* Undo *@
                <MudIconButton Icon="@Icons.Material.Filled.Undo"
                               Size="Size.Small"
                               Disabled="@(!_commandStack.CanUndo)"
                               OnClick="@UndoAsync" />

                @* Delete *@
                @if (_selectedElement is not null)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@DeleteSelectedElementAsync" />
                }

                @* Board Settings *@
                <MudIconButton Icon="@Icons.Material.Filled.Settings"
                               Size="Size.Small"
                               OnClick="@OpenBoardSettingsDialog" />

                @* Element Properties — opens mobile dialog *@
                <MudIconButton Icon="@Icons.Material.Filled.Tune"
                               Size="Size.Small"
                               Color="@(_selectedElement is not null ? Color.Primary : Color.Default)"
                               OnClick="@OpenMobilePropertiesDialog" />
            }
        </MudPaper>

        @* === Mobile Floating Zoom Controls === *@

        <div style="display: flex; flex: 1; min-height: 0; min-width: 0; overflow: hidden;">
            <div @ref="_editorSurface"
                 style="flex: 1; min-width: 0; min-height: 0; overflow: hidden; position: relative; outline: none;"
                 @onmousedown="FocusEditorSurfaceAsync"
                 @onkeydown="HandleKeyDown"
                 tabindex="0">
                <WhiteboardCanvas @ref="_canvas" Board="@_board" CanEdit="@_canEdit"
                                  FitRightInset="@CanvasFitRightInset"
                                  OnBoardChanged="@HandleBoardChanged"
                                  OnSelectedElementChanged="@HandleSelectedElementChanged"
                                  OnSelectedElementsChanged="@HandleSelectedElementsChanged"
                                  OnZoomChanged="@HandleZoomChanged"
                                  OnToolChanged="@HandleToolChanged"
                                  OnElementDoubleTapped="@OnCanvasElementDoubleTapped"
                                  PendingIconName="@_pendingIconName"
                                  SelectedTool="@_selectedTool" />

                <ChatAssistantPanel Board="@_board"
                                    IsOpen="@_chatPanelOpen"
                                    DockLeftOfProperties="@(_chatPanelOpen && _propertiesPanelOpen)"
                                    OnClose="@CloseChatPanel"
                                    OnBoardChanged="@HandleChatBoardChangedAsync" />

                @if (_canEdit)
                {
                    <ElementPropertiesPanel @key="@(selectedElement?.Id ?? Guid.Empty)"
                                            Board="@_board"
                                            Element="@selectedElement"
                                            SelectionCount="@_selectedElements.Count"
                                            IsOpen="@_propertiesPanelOpen"
                                            OnClose="@ClosePropertiesPanel"
                                            OnPreviewChanged="@OnElementPropertyPreviewChanged"
                                            OnChanged="@OnElementPropertyChanged" />
                }

                <div class="orim-mobile-zoom-controls">
                    <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@ZoomOutAsync" />
                    <span class="orim-mobile-zoom-label">@_zoomDisplayValue</span>
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@ZoomInAsync" />
                    <MudIconButton Icon="@Icons.Material.Filled.FitScreen"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@FitToContentAsync" />
                </div>
            </div>
        </div>
    </div>

    <MudDialog @bind-Visible="_iconPickerVisible" Options="_iconDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["MaterialDesignIcons"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_iconSearch"
                          Label="@Localizer["SearchIcon"]"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" />

            @if (_isLoadingIcons)
            {
                <div style="display:flex; align-items:center; justify-content:center; min-height:220px;">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_iconLoadError))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4">@_iconLoadError</MudAlert>
            }
            else
            {
                <MudText Typo="Typo.caption" Class="mt-2 mb-2 orim-board-muted-text">
                    @string.Format(Localizer["IconCount"], FilteredMaterialIcons.Count)
                </MudText>
                <div class="orim-icon-picker-grid">
                    @foreach (var iconName in FilteredMaterialIcons)
                    {
                        <button type="button"
                                @onclick="@(() => SelectMaterialIconAsync(iconName))"
                                class="orim-icon-picker-card">
                            <span class="mdi @iconName orim-icon-picker-preview"></span>
                            <span class="orim-icon-picker-label">@iconName[4..]</span>
                        </button>
                    }
                </div>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@CloseIconPicker">@Localizer["Cancel"]</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_helpDialogVisible" Options="_helpDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["HelpDialogTitle"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["ToolsSectionTitle"]</MudText>
            <ul style="margin:0 0 16px 18px; padding:0; color:#334155; line-height:1.5;">
                <li>@Localizer["HelpToolsSelect"]</li>
                <li>@Localizer["HelpToolsShapes"]</li>
                <li>@Localizer["HelpToolsArrow"]</li>
                <li>@Localizer["HelpToolsIcon"]</li>
            </ul>

            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["SelectionGroupsSectionTitle"]</MudText>
            <ul style="margin:0 0 16px 18px; padding:0; color:#334155; line-height:1.5;">
                <li>@Localizer["HelpSelectionMarquee"]</li>
                <li>@Localizer["HelpSelectionAdditive"]</li>
                <li>@Localizer["HelpSelectionGroupMove"]</li>
                <li>@Localizer["HelpSelectionSingleEdit"]</li>
                <li>@Localizer["HelpSelectionZoom"]</li>
                <li>@Localizer["HelpSelectionSnapDisable"]</li>
            </ul>

            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["ShortcutsSectionTitle"]</MudText>
            <ul style="margin:0 0 0 18px; padding:0; color:#334155; line-height:1.5;">
                <li>@Localizer["ShortcutUndo"]</li>
                <li>@Localizer["ShortcutRedo"]</li>
                <li>@Localizer["ShortcutSelectAll"]</li>
                <li>@Localizer["ShortcutCopy"]</li>
                <li>@Localizer["ShortcutCut"]</li>
                <li>@Localizer["ShortcutPaste"]</li>
                <li>@Localizer["ShortcutGroup"]</li>
                <li>@Localizer["ShortcutUngroup"]</li>
                <li>@Localizer["ShortcutDelete"]</li>
            </ul>
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@CloseHelpDialog">@Localizer["Close"]</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_renameDialogVisible" Options="_helpDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["RenameBoardTitle"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_renameBoardTitle"
                          Label="@Localizer["BoardName"]"
                          Variant="Variant.Outlined"
                          Required="true" />
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@CloseRenameBoardDialog">@Localizer["Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@ConfirmRenameBoardAsync">@Localizer["Save"]</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_boardSettingsDialogVisible" Options="_helpDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["BoardSettings"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudCheckBox @bind-Value="_boardLabelOutlineEnabled"
                         T="bool"
                         Label="@Localizer["LabelOutlineEnabled"]" />
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@CloseBoardSettingsDialog">@Localizer["Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@ConfirmBoardSettingsAsync">@Localizer["Save"]</MudButton>
        </DialogActions>
    </MudDialog>

    @* === Mobile Properties Dialog === *@
    <MudDialog @bind-Visible="_mobilePropertiesDialogVisible" Options="_mobilePropertiesDialogOptions">
        <TitleContent>
            <div style="display:flex; align-items:center; gap:8px;">
                <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" />
                <MudText Typo="Typo.h6">@Localizer["Properties"]</MudText>
            </div>
        </TitleContent>
        <DialogContent>
            @if (_board is not null && _canEdit)
            {
                var dlgSelectedElement = _selectedElements.Count == 1 ? _selectedElements[0] : null;
                <ElementPropertiesPanel @key="@(dlgSelectedElement?.Id ?? Guid.Empty)"
                                        Board="@_board"
                                        Element="@dlgSelectedElement"
                                        SelectionCount="@_selectedElements.Count"
                                        IsOpen="true"
                                        DialogMode="true"
                                        OnClose="@CloseMobilePropertiesDialog"
                                        OnPreviewChanged="@OnElementPropertyPreviewChanged"
                                        OnChanged="@OnMobilePropertyChanged" />
            }
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@CloseMobilePropertiesDialog">@Localizer["Close"]</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    [Parameter] public Guid BoardId { get; set; }

    private Board? _board;
    private Guid _userId;
    private bool _hasAccess;
    private bool _canEdit;
    private Tool _selectedTool = Tool.Select;
    private readonly CommandStack _commandStack = new();
    private WhiteboardCanvas? _canvas;
    private BoardElement? _selectedElement;
    private List<BoardElement> _selectedElements = [];
    private ElementReference _editorSurface;
    private bool _iconPickerVisible;
    private bool _helpDialogVisible;
    private bool _renameDialogVisible;
    private bool _boardSettingsDialogVisible;
    private bool _mobilePropertiesDialogVisible;
    private bool _chatPanelOpen;
    private bool _propertiesPanelOpen = false;
    private bool _boardLabelOutlineEnabled = true;
    private bool _formatTransferActive;
    private Guid? _formatTransferSourceId;
    private bool _isLoadingIcons;
    private string _iconSearch = string.Empty;
    private string? _iconLoadError;
    private string? _pendingIconName;
    private List<BoardElement> _clipboardElements = [];
    private int _pasteSequence;
    private string _lastCommittedBoardSnapshot = string.Empty;
    private int _zoomPercentage = 100;
    private string _zoomDisplayValue = "100%";
    private string _renameBoardTitle = string.Empty;
    private bool CanGroupSelection => _selectedElements.Count(element => element is not ArrowElement) > 1;
    private bool CanUngroupSelection => _selectedElements.Any(element => element.GroupId is not null);
    private double CanvasFitRightInset => (_propertiesPanelOpen ? 388d : 0d) + (_chatPanelOpen ? 388d : 0d);

    private List<string> _materialIcons = [];
    private readonly DialogOptions _iconDialogOptions = new() { FullWidth = true, MaxWidth = MaxWidth.Medium, CloseButton = true };
    private readonly DialogOptions _helpDialogOptions = new() { FullWidth = true, MaxWidth = MaxWidth.Small, CloseButton = true };
    private readonly DialogOptions _mobilePropertiesDialogOptions = new() { FullWidth = true, MaxWidth = MaxWidth.Small, CloseButton = true };
    private static List<string>? _cachedMaterialIcons;

    private IReadOnlyList<string> FilteredMaterialIcons => _materialIcons
        .Where(icon => string.IsNullOrWhiteSpace(_iconSearch) || icon.Contains(_iconSearch.Trim(), StringComparison.OrdinalIgnoreCase))
        .OrderBy(icon => icon.StartsWith($"mdi-{_iconSearch.Trim()}", StringComparison.OrdinalIgnoreCase) ? 0 : 1)
        .ThenBy(icon => icon)
        .Take(240)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userId = Guid.Parse(user.FindFirst(ClaimTypes.NameIdentifier)!.Value);
        }

        _board = await BoardService.GetBoardAsync(BoardId);
        if (_board is null) return;

        _hasAccess = BoardService.HasAccess(_board, _userId);
        _canEdit = BoardService.HasAccess(_board, _userId, BoardRole.Editor);
        _boardLabelOutlineEnabled = _board.LabelOutlineEnabled;
        _commandStack.Clear();
        _lastCommittedBoardSnapshot = CaptureBoardSnapshot(_board);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _board is not null && _hasAccess)
        {
            await _editorSurface.FocusAsync();
            var width = await JS.InvokeAsync<int>("orimWhiteboard.getWindowWidth");
            if (width > 768)
            {
                _propertiesPanelOpen = true;
                StateHasChanged();
            }
        }
    }

    private void SelectTool(Tool tool) => _selectedTool = tool;

    private void ToggleFormatTransfer()
    {
        if (_selectedElement is null)
        {
            _formatTransferActive = false;
            _formatTransferSourceId = null;
            return;
        }

        if (_formatTransferActive)
        {
            _formatTransferActive = false;
            _formatTransferSourceId = null;
            return;
        }

        _formatTransferSourceId = _selectedElement.Id;
        _formatTransferActive = true;
        SelectTool(Tool.Select);
    }

    private async Task OpenIconPickerAsync()
    {
        _iconPickerVisible = true;
        _iconSearch = string.Empty;
        await EnsureMaterialIconsLoadedAsync();
    }

    private void CloseIconPicker()
    {
        _iconPickerVisible = false;
        if (_selectedTool == Tool.Icon)
        {
            _selectedTool = Tool.Select;
        }
    }

    private void ToggleChatPanel() => _chatPanelOpen = !_chatPanelOpen;

    private void CloseChatPanel() => _chatPanelOpen = false;

    private void TogglePropertiesPanel() => _propertiesPanelOpen = !_propertiesPanelOpen;

    private void ClosePropertiesPanel() => _propertiesPanelOpen = false;

    private async Task HandleChatBoardChangedAsync()
    {
        if (_board is null) return;
        _lastCommittedBoardSnapshot = CaptureBoardSnapshot(_board);
        await BoardService.UpdateBoardAsync(_board);
        if (_canvas is not null)
        {
            _canvas.ForceRerender();
            await _canvas.FitToContentAsync();
        }
        StateHasChanged();
    }

    private void OpenHelpDialog()
    {
        _helpDialogVisible = true;
    }

    private void OpenBoardSettingsDialog()
    {
        if (_board is null)
        {
            return;
        }

        _boardLabelOutlineEnabled = _board.LabelOutlineEnabled;
        _boardSettingsDialogVisible = true;
    }

    private void OpenMobilePropertiesDialog() => _mobilePropertiesDialogVisible = true;

    private void CloseMobilePropertiesDialog() => _mobilePropertiesDialogVisible = false;

    private void OnCanvasElementDoubleTapped()
    {
        if (_selectedElement is not null && _canEdit)
            OpenMobilePropertiesDialog();
    }

    private async Task OnMobilePropertyChanged()
    {
        await SaveBoard();
        StateHasChanged();
    }

    private string GetMobileShapeIcon() => _selectedTool switch
    {
        Tool.Circle => Icons.Material.Filled.PanoramaFishEye,
        Tool.Triangle => Icons.Material.Filled.ChangeHistory,
        _ => Icons.Material.Filled.Rectangle
    };

    private static bool IsShapeTool(Tool tool) =>
        tool is Tool.Rectangle or Tool.Circle or Tool.Triangle;

    private void CloseBoardSettingsDialog()
    {
        _boardSettingsDialogVisible = false;
        if (_board is not null)
        {
            _boardLabelOutlineEnabled = _board.LabelOutlineEnabled;
        }
    }

