@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Forms
@using Orim.Core.Models
@using Orim.Core.Services
@using Orim.Web.Services
@inject BoardService BoardService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Localizer
@inject UserPreferencesManager UserPreferences

<PageTitle>@Localizer["AppTitle"] - @Localizer["Dashboard"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h4" Style="font-weight: 700;">@Localizer["MyBoards"]</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@CreateBoard" Style="border-radius: 8px; font-weight: 600;">
            @Localizer["NewBoard"]
        </MudButton>
    </div>

    <MudPaper Class="pa-5 mb-6 orim-quick-start-panel" Elevation="1">
        <div class="d-flex flex-wrap justify-space-between align-center" style="gap: 16px;">
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 700;">@Localizer["QuickStartTitle"]</MudText>
                <MudText Typo="Typo.body2" Class="orim-board-muted-text">@GetQuickStartDescription()</MudText>
            </div>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.UploadFile" HtmlTag="label">
                @Localizer["ImportBoardJson"]
                <InputFile OnChange="@HandleImportBoardAsync" accept=".json,application/json" style="display:none" />
            </MudButton>
        </div>

        @if (!string.IsNullOrWhiteSpace(_importError))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-4">@_importError</MudAlert>
        }

        @if (UserPreferences.ShowDashboardTemplates)
        {
            <MudGrid Class="mt-2">
                @foreach (var template in _templates)
                {
                    <MudItem xs="12" sm="6" md="4" lg="2">
                        <MudCard Class="orim-template-card" Elevation="0">
                            <MudCardContent>
                                <div class="d-flex align-center mb-2" style="gap: 8px;">
                                    <MudIcon Icon="@GetTemplateIcon(template)" Color="Color.Primary" />
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@Localizer[template.TitleResourceKey]</MudText>
                                </div>
                                <MudText Typo="Typo.body2" Class="orim-board-muted-text">@Localizer[template.DescriptionResourceKey]</MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => CreateBoardFromTemplate(template))">
                                    @Localizer["UseTemplate"]
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudPaper>

    @if (_boards is null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else if (_boards.Count == 0)
    {
        <MudPaper Class="pa-6 orim-empty-state" Elevation="1">
            <MudText Typo="Typo.h5" Style="font-weight: 700;">@Localizer["NoBoardsHeadline"]</MudText>
            <MudText Typo="Typo.body1" Class="mt-2 orim-board-muted-text">@Localizer["NoBoards"]</MudText>
            <ul class="orim-empty-state-list">
                @if (UserPreferences.ShowDashboardTemplates)
                {
                    <li>@Localizer["DashboardEmptyStateTemplateTip"]</li>
                }
                <li>@Localizer["DashboardEmptyStateImportTip"]</li>
                <li>@Localizer["DashboardEmptyStateShareTip"]</li>
            </ul>
            <div class="d-flex flex-wrap mt-4" style="gap: 12px;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@CreateBoard">
                    @Localizer["NewBoard"]
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.UploadFile" HtmlTag="label">
                    @Localizer["ImportBoardJson"]
                    <InputFile OnChange="@HandleImportBoardAsync" accept=".json,application/json" style="display:none" />
                </MudButton>
            </div>
        </MudPaper>
    }
    else
    {
        <MudGrid>
            @foreach (var board in _boards)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="2" Style="border-radius: 12px; cursor: pointer; transition: box-shadow 0.2s;"
                             Class="hover-card" @onclick="() => OpenBoard(board.Id)">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Style="font-weight: 600;">@board.Title</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                @if (board.OwnerId == _userId)
                                {
                                    <div @onclick:stopPropagation="true">
                                        <MudTooltip Text="@Localizer["RenameBoard"]" Arrow="true">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                           Color="Color.Default"
                                                           Size="Size.Small"
                                                           OnClick="@(() => OpenRenameBoardDialog(board))" />
                                        </MudTooltip>
                                    </div>
                                    <div @onclick:stopPropagation="true">
                                        <MudTooltip Text="@Localizer["DeleteBoard"]" Arrow="true">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(async () => await DeleteBoardFromOverviewAsync(board))" />
                                        </MudTooltip>
                                    </div>
                                }
                                <MudChip T="string" Size="Size.Small"
                                         Color="@GetVisibilityColor(board.Visibility)">
                                    @GetVisibilityLabel(board.Visibility)
                                </MudChip>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @string.Format(Localizer["ElementsMembersSummary"], board.ElementCount, board.Members.Count)
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @Localizer["UpdatedAt"]: @board.UpdatedAt.ToString("g")
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

<MudDialog @bind-Visible="_createDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">@Localizer["CreateBoardTitle"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newBoardTitle" Label="@Localizer["BoardName"]" Variant="Variant.Outlined" Required="true" />
        <MudSelect T="string" @bind-Value="_selectedTemplateId" Label="@Localizer["Template"]" Variant="Variant.Outlined" Class="mt-4">
            @foreach (var template in _templates)
            {
                <MudSelectItem T="string" Value="@template.Id">@Localizer[template.TitleResourceKey]</MudSelectItem>
            }
        </MudSelect>
        <MudSelect @bind-Value="_newBoardVisibility" Label="@Localizer["Visibility"]" Variant="Variant.Outlined" Class="mt-4">
            <MudSelectItem Value="BoardVisibility.Private">@Localizer["Private"]</MudSelectItem>
            <MudSelectItem Value="BoardVisibility.Public">@Localizer["Public"]</MudSelectItem>
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseCreateBoardDialog">@Localizer["Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@ConfirmCreateBoard">@Localizer["Create"]</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_renameDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">@Localizer["RenameBoardTitle"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_renameBoardTitle"
                      Label="@Localizer["BoardName"]"
                      Variant="Variant.Outlined"
                      Required="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseRenameBoardDialog">@Localizer["Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@ConfirmRenameBoardAsync">@Localizer["Save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<BoardSummary>? _boards;
    private List<BoardTemplateDefinition> _templates = [];
    private Guid _userId;
    private string _username = "";
    private bool _createDialogVisible;
    private bool _renameDialogVisible;
    private string _newBoardTitle = "";
    private string _renameBoardTitle = "";
    private string _selectedTemplateId = BoardTemplateCatalog.BlankTemplateId;
    private string? _importError;
    private BoardVisibility _newBoardVisibility = BoardVisibility.Private;
    private BoardSummary? _boardBeingRenamed;

    protected override async Task OnInitializedAsync()
    {
        UserPreferences.Changed += HandleUserPreferencesChanged;
        _templates = BoardService.GetTemplates().ToList();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userId = Guid.Parse(user.FindFirst(ClaimTypes.NameIdentifier)!.Value);
            _username = user.Identity.Name ?? "";
            _boards = await BoardService.GetAccessibleBoardSummariesAsync(_userId);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await UserPreferences.InitializeAsync(JS);
    }

    public void Dispose()
    {
        UserPreferences.Changed -= HandleUserPreferencesChanged;
    }

    private void CreateBoard() => OpenCreateBoardDialog(BoardTemplateCatalog.BlankTemplateId, string.Empty);

    private void CreateBoardFromTemplate(BoardTemplateDefinition template) =>
        OpenCreateBoardDialog(template.Id, Localizer[template.TitleResourceKey]);

    private void OpenCreateBoardDialog(string templateId, string title)
    {
        _selectedTemplateId = templateId;
        _newBoardTitle = title;
        _newBoardVisibility = BoardVisibility.Private;
        _importError = null;
        _createDialogVisible = true;
    }

    private void CloseCreateBoardDialog()
    {
        _createDialogVisible = false;
        _newBoardTitle = string.Empty;
        _selectedTemplateId = BoardTemplateCatalog.BlankTemplateId;
    }

    private void OpenRenameBoardDialog(BoardSummary board)
    {
        _boardBeingRenamed = board;
        _renameBoardTitle = board.Title;
        _renameDialogVisible = true;
    }

    private void CloseRenameBoardDialog()
    {
        _renameDialogVisible = false;
        _renameBoardTitle = string.Empty;
        _boardBeingRenamed = null;
    }

    private async Task ConfirmCreateBoard()
    {
        if (string.IsNullOrWhiteSpace(_newBoardTitle))
        {
            return;
        }

        var board = await BoardService.CreateBoardAsync(_newBoardTitle.Trim(), _userId, _username, _selectedTemplateId);
        if (_newBoardVisibility != BoardVisibility.Private)
        {
            board.Visibility = _newBoardVisibility;
            await BoardService.UpdateBoardAsync(board);
        }

        CloseCreateBoardDialog();
        Navigation.NavigateTo($"/board/{board.Id}");
    }

    private async Task HandleImportBoardAsync(InputFileChangeEventArgs args)
    {
        _importError = null;

        var file = args.File;
        if (file is null)
        {
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var importedBoard = await System.Text.Json.JsonSerializer.DeserializeAsync<Board>(stream, Orim.Core.OrimJsonOptions.Default);
            if (importedBoard is null)
            {
                throw new InvalidDataException("Board import payload was empty.");
            }

            var title = string.IsNullOrWhiteSpace(importedBoard.Title)
                ? Path.GetFileNameWithoutExtension(file.Name)
                : importedBoard.Title.Trim();

            var board = await BoardService.CreateBoardFromImportAsync(importedBoard, title, _userId, _username);
            Navigation.NavigateTo($"/board/{board.Id}");
        }
        catch (System.Text.Json.JsonException)
        {
            _importError = Localizer["ImportBoardInvalidJson"];
        }
        catch (InvalidDataException)
        {
            _importError = Localizer["ImportBoardInvalidJson"];
        }
        catch (IOException)
        {
            _importError = Localizer["ImportBoardReadError"];
        }
    }

    private async Task ConfirmRenameBoardAsync()
    {
        if (_boardBeingRenamed is null || string.IsNullOrWhiteSpace(_renameBoardTitle))
        {
            return;
        }

        var board = await BoardService.GetBoardAsync(_boardBeingRenamed.Id);
        if (board is null)
        {
            CloseRenameBoardDialog();
            return;
        }

        board.Title = _renameBoardTitle.Trim();
        await BoardService.UpdateBoardAsync(board);
        _boardBeingRenamed.Title = board.Title;
        CloseRenameBoardDialog();
        StateHasChanged();
    }

    private async Task DeleteBoardFromOverviewAsync(BoardSummary board)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", string.Format(Localizer["DeleteBoardConfirmation"], board.Title));
        if (!confirmed)
        {
            return;
        }

        await BoardService.DeleteBoardAsync(board.Id);
        _boards?.RemoveAll(candidate => candidate.Id == board.Id);
        StateHasChanged();
    }

    private void OpenBoard(Guid boardId) => Navigation.NavigateTo($"/board/{boardId}");

    private string GetQuickStartDescription() => UserPreferences.ShowDashboardTemplates
        ? Localizer["QuickStartDescription"]
        : Localizer["QuickStartDescriptionWithoutTemplates"];

    private void HandleUserPreferencesChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private static string GetTemplateIcon(BoardTemplateDefinition template) => template.Id switch
    {
        BoardTemplateCatalog.ProcessTemplateId => Icons.Material.Filled.AltRoute,
        BoardTemplateCatalog.OrgChartTemplateId => Icons.Material.Filled.AccountTree,
        BoardTemplateCatalog.SwimlaneTemplateId => Icons.Material.Filled.ViewWeek,
        BoardTemplateCatalog.DecisionTreeTemplateId => Icons.Material.Filled.Schema,
        BoardTemplateCatalog.WorkshopTemplateId => Icons.Material.Filled.DynamicFeed,
        _ => Icons.Material.Filled.Dashboard
    };

    private Color GetVisibilityColor(BoardVisibility v) => v switch
    {
        BoardVisibility.Private => Color.Default,
        BoardVisibility.Public => Color.Success,
        BoardVisibility.Shared => Color.Info,
        _ => Color.Default
    };

    private string GetVisibilityLabel(BoardVisibility visibility) => visibility switch
    {
        BoardVisibility.Private => Localizer["Private"],
        BoardVisibility.Public => Localizer["Public"],
        BoardVisibility.Shared => Localizer["Shared"],
        _ => visibility.ToString()
    };
}
