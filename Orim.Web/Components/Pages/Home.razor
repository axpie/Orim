@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@inject BoardService BoardService
@inject UserService UserService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Orim – Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h4" Style="font-weight: 700;">Meine Boards</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@CreateBoard" Style="border-radius: 8px; font-weight: 600;">
            Neues Board
        </MudButton>
    </div>

    @if (_boards is null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else if (_boards.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            Noch keine Boards vorhanden. Erstelle dein erstes Board!
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var board in _boards)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="2" Style="border-radius: 12px; cursor: pointer; transition: box-shadow 0.2s;"
                             Class="hover-card" @onclick="() => OpenBoard(board.Id)">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Style="font-weight: 600;">@board.Title</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@GetVisibilityColor(board.Visibility)">
                                    @board.Visibility
                                </MudChip>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @board.Elements.Count Elemente · @board.Members.Count Mitglieder
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Aktualisiert: @board.UpdatedAt.ToString("dd.MM.yyyy HH:mm")
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

<MudDialog @bind-Visible="_createDialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">Neues Board erstellen</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newBoardTitle" Label="Board-Name" Variant="Variant.Outlined" Required="true" />
        <MudSelect @bind-Value="_newBoardVisibility" Label="Sichtbarkeit" Variant="Variant.Outlined" Class="mt-4">
            <MudSelectItem Value="BoardVisibility.Private">Privat</MudSelectItem>
            <MudSelectItem Value="BoardVisibility.Public">Öffentlich</MudSelectItem>
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _createDialogVisible = false)">Abbrechen</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@ConfirmCreateBoard">Erstellen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Board>? _boards;
    private Guid _userId;
    private string _username = "";
    private bool _createDialogVisible;
    private string _newBoardTitle = "";
    private BoardVisibility _newBoardVisibility = BoardVisibility.Private;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userId = Guid.Parse(user.FindFirst(ClaimTypes.NameIdentifier)!.Value);
            _username = user.Identity.Name ?? "";
            _boards = await BoardService.GetAccessibleBoardsAsync(_userId);
        }
    }

    private void CreateBoard() => _createDialogVisible = true;

    private async Task ConfirmCreateBoard()
    {
        if (string.IsNullOrWhiteSpace(_newBoardTitle)) return;
        var board = await BoardService.CreateBoardAsync(_newBoardTitle.Trim(), _userId, _username);
        if (_newBoardVisibility != BoardVisibility.Private)
        {
            board.Visibility = _newBoardVisibility;
            await BoardService.UpdateBoardAsync(board);
        }
        _createDialogVisible = false;
        _newBoardTitle = "";
        Navigation.NavigateTo($"/board/{board.Id}");
    }

    private void OpenBoard(Guid boardId) => Navigation.NavigateTo($"/board/{boardId}");

    private Color GetVisibilityColor(BoardVisibility v) => v switch
    {
        BoardVisibility.Private => Color.Default,
        BoardVisibility.Public => Color.Success,
        BoardVisibility.Shared => Color.Info,
        _ => Color.Default
    };
}
