@page "/shared/{Token}"
@layout EmptyLayout
@rendermode InteractiveServer
@inject BoardService BoardService

@if (_board is null)
{
    <MudContainer Class="py-8">
        @if (_notFound)
        {
            <MudAlert Severity="Severity.Error">Dieser Share-Link ist ungültig oder abgelaufen.</MudAlert>
        }
        else
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        }
    </MudContainer>
}
else
{
    <div style="display: flex; flex-direction: column; height: 100vh;">
        <MudPaper Elevation="1" Class="orim-shared-header">
            <MudText Typo="Typo.h6" Class="orim-brand">Orim</MudText>
            <MudDivider Vertical="true" FlexItem="true" DividerType="DividerType.Middle" Class="orim-shared-divider" />
            <MudText Typo="Typo.subtitle1" Class="orim-shared-subtitle">@_board.Title (Nur-Lesen)</MudText>
        </MudPaper>
        <div style="flex: 1; overflow: hidden;">
            <WhiteboardCanvas Board="@_board" CanEdit="false"
                              CommandStack="@(new CommandStack())"
                              SelectedTool="BoardEditor.Tool.Select" />
        </div>
    </div>
}

@code {
    [Parameter] public string Token { get; set; } = "";
    private Board? _board;
    private bool _notFound;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Token))
        {
            _notFound = true;
            return;
        }
        _board = await BoardService.GetBoardByShareTokenAsync(Token);
        if (_board is null)
            _notFound = true;
    }
}
