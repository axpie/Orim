    private async Task EnsureMaterialIconsLoadedAsync()
    {
        if (_materialIcons.Count > 0 || _isLoadingIcons)
        {
            return;
        }

        if (_cachedMaterialIcons is not null)
        {
            _materialIcons = _cachedMaterialIcons;
            return;
        }

        _isLoadingIcons = true;
        _iconLoadError = null;

        try
        {
            var path = Path.Combine(Environment.WebRootPath, "data", "materialdesignicons.json");
            if (!File.Exists(path))
            {
                throw new FileNotFoundException("materialdesignicons.json not found", path);
            }

            await using var stream = File.OpenRead(path);
            var icons = await System.Text.Json.JsonSerializer.DeserializeAsync<List<string>>(stream) ?? [];
            _materialIcons = icons.Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(icon => icon).ToList();
            _cachedMaterialIcons = _materialIcons;
        }
        catch
        {
            _iconLoadError = Localizer["MaterialIconsLoadError"];
        }
        finally
        {
            _isLoadingIcons = false;
            StateHasChanged();
        }
    }

