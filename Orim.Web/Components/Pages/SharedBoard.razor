    private async Task StartPresenceHeartbeatAsync()
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            while (await timer.WaitForNextTickAsync(_presenceHeartbeatCancellation.Token))
            {
                await PublishPresenceAsync(_localPointerPosition);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private Task HandleExternalBoardChangeAsync(BoardChangeNotification notification)
    {
        return InvokeAsync(async () =>
        {
            var latestBoard = await BoardService.GetBoardByShareTokenAsync(Token);
            if (latestBoard is null || latestBoard.Visibility != BoardVisibility.Shared)
            {
                if (_board is not null)
                {
                    await TearDownSharedRealtimeAsync(_board.Id);
                }

                _board = null;
                _notFound = true;
                _shareAccessGranted = false;
                _shareCanEdit = false;
                StateHasChanged();
                return;
            }

            _board = latestBoard;

            if (!BoardService.HasSharedLinkAccess(latestBoard, _verifiedSharePassword))
            {
                await TearDownSharedRealtimeAsync(latestBoard.Id);
                _shareAccessGranted = false;
                _shareCanEdit = false;
                _sharePasswordInput = string.Empty;
                _sharePasswordError = Localizer["SharedLinkProtected"];
                _propertiesPanelOpen = false;
                _selectedElement = null;
                _selectedElements = [];
                _selectedTool = BoardEditor.Tool.Select;
                _commandStack.Clear();
                _remoteCursors = [];
                StateHasChanged();
                return;
            }

            _shareCanEdit = BoardService.HasSharedLinkAccess(latestBoard, _verifiedSharePassword, BoardRole.Editor);
            _lastCommittedBoardSnapshot = CaptureBoardSnapshot(latestBoard);
            InitializeBoardSettingsDrafts();
            _canvas?.ForceRerender();
            StateHasChanged();
        });
    }

    private Task HandleCursorPresenceChangedAsync(IReadOnlyList<BoardCursorPresence> cursors)
    {
        return InvokeAsync(() =>
        {
            _remoteCursors = cursors
                .Where(cursor => cursor.ClientId != _boardSyncClientId)
                .ToList();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        _presenceHeartbeatCancellation.Cancel();
        if (_board is not null)
        {
            _ = BoardPresenceService.RemoveCursorAsync(_board.Id, _boardSyncClientId);
            if (_presenceLifecycleRegistered)
            {
                try
                {
                    _ = JS.InvokeVoidAsync("orimWhiteboard.unregisterPresenceLifecycle", _board.Id, _boardSyncClientId);
                }
                catch
                {
                }
            }
        }

        _cursorPresenceSubscription?.Dispose();
        _boardChangeSubscription?.Dispose();
        _presenceHeartbeatCancellation.Dispose();
    }

    private async Task GrantSharedAccessAsync(string? password)
    {
        if (_board is null)
        {
            return;
        }

        if (!BoardService.HasSharedLinkAccess(_board, password))
        {
            _shareAccessGranted = false;
            _shareCanEdit = false;
            return;
        }

        _verifiedSharePassword = BoardService.IsSharePasswordProtected(_board) ? password?.Trim() : null;
        _shareAccessGranted = true;
        _shareCanEdit = BoardService.HasSharedLinkAccess(_board, _verifiedSharePassword, BoardRole.Editor);
        _sharePasswordError = null;
        _lastCommittedBoardSnapshot = CaptureBoardSnapshot(_board);
        InitializeBoardSettingsDrafts();
        _commandStack.Clear();

        _boardChangeSubscription ??= BoardChangeNotifier.Subscribe(_board.Id, _boardSyncClientId, HandleExternalBoardChangeAsync);
        _cursorPresenceSubscription ??= BoardPresenceService.Subscribe(_board.Id, $"cursor-{_boardSyncClientId}", HandleCursorPresenceChangedAsync);
        await PublishPresenceAsync(null);
        _presenceHeartbeatTask ??= StartPresenceHeartbeatAsync();
        StateHasChanged();
    }

    private async Task TearDownSharedRealtimeAsync(Guid boardId)
    {
        await BoardPresenceService.RemoveCursorAsync(boardId, _boardSyncClientId);
        _cursorPresenceSubscription?.Dispose();
        _boardChangeSubscription?.Dispose();
        _cursorPresenceSubscription = null;
        _boardChangeSubscription = null;

        if (_presenceLifecycleRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("orimWhiteboard.unregisterPresenceLifecycle", boardId, _boardSyncClientId);
            }
            catch
            {
            }

            _presenceLifecycleRegistered = false;
        }
    }

    private async Task ExportJson()
    {
        if (_board is null)
        {
            return;
        }

        var json = System.Text.Json.JsonSerializer.Serialize(_board, Orim.Core.OrimJsonOptions.Indented);
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("orimWhiteboard.downloadFile", $"{_board.Title}.json", "application/json", base64);
    }
