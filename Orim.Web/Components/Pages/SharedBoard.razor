    private Task HandleBoardChangedAsync() => SaveBoardAsync();

    private async Task SaveBoardAsync(bool recordHistory = true)
    {
        if (_board is null || !_shareCanEdit)
        {
            return;
        }

        var currentSnapshot = CaptureBoardSnapshot(_board);
        var historyRecorded = false;
        if (recordHistory && currentSnapshot != _lastCommittedBoardSnapshot)
        {
            _commandStack.Execute(_board, new BoardSnapshotCommand(_lastCommittedBoardSnapshot, currentSnapshot));
            currentSnapshot = CaptureBoardSnapshot(_board);
            historyRecorded = true;
        }

        _lastCommittedBoardSnapshot = currentSnapshot;

        if (historyRecorded)
        {
            await SyncSelectionToBoardAsync();
        }

        await BoardService.UpdateBoardAsync(_board, _boardSyncClientId);
    }

    private async Task PersistBoardStateAsync()
    {
        if (_board is null)
        {
            return;
        }

        _lastCommittedBoardSnapshot = CaptureBoardSnapshot(_board);
        await SyncSelectionToBoardAsync();
        await SaveBoardAsync(recordHistory: false);
        StateHasChanged();
    }

    private async Task SyncSelectionToBoardAsync()
    {
        if (_board is null)
        {
            return;
        }

        var selectedIds = _selectedElements.Select(element => element.Id).ToHashSet();
        var nextSelection = _board.Elements
            .Where(element => selectedIds.Contains(element.Id))
            .OrderBy(element => element.ZIndex)
            .ToList();

        _selectedElements = nextSelection;
        _selectedElement = nextSelection.LastOrDefault();

        if (_canvas is not null)
        {
            await _canvas.SelectElementsAsync(nextSelection);
        }
    }

    private async Task UndoAsync()
    {
        if (_board is null || !_commandStack.CanUndo)
        {
            return;
        }

        _commandStack.Undo(_board);
        await PersistBoardStateAsync();
    }

    private async Task RedoAsync()
    {
        if (_board is null || !_commandStack.CanRedo)
        {
            return;
        }

        _commandStack.Redo(_board);
        await PersistBoardStateAsync();
    }

    private async Task DeleteSelectedElementAsync()
    {
        if (_board is null || !_shareCanEdit || _selectedElements.Count == 0)
        {
            return;
        }

        foreach (var elementId in _selectedElements.Select(element => element.Id).Distinct().ToList())
        {
            if (_board.Elements.Any(element => element.Id == elementId))
            {
                var command = new RemoveElementCommand(elementId);
                command.Execute(_board);
            }
        }

        _selectedElement = null;
        _selectedElements = [];
        _canvas?.ClearSelection();
        await SaveBoardAsync();
    }

