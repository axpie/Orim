@page "/shared/{Token}"
@layout MainLayout
@rendermode InteractiveServer
@implements IDisposable
@inject BoardService BoardService
@inject BoardChangeNotifier BoardChangeNotifier
@inject BoardPresenceService BoardPresenceService
@inject IJSRuntime JS
@inject IWebHostEnvironment Environment
@inject ThemeManager ThemeManager
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Localizer
@using Orim.Web.Services

@if (_board is null)
{
    <MudContainer Class="py-8">
        @if (_notFound)
        {
            <MudAlert Severity="Severity.Error">Dieser Share-Link ist ungültig oder abgelaufen.</MudAlert>
        }
        else
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        }
    </MudContainer>
}
else if (!_shareAccessGranted)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
        <MudPaper Class="pa-6">
            <MudText Typo="Typo.h6">@Localizer["SharedLinkProtected"]</MudText>
            <MudText Typo="Typo.body2" Class="mt-2 mb-4">@Localizer["SharedLinkPasswordPrompt"]</MudText>

            @if (!string.IsNullOrWhiteSpace(_sharePasswordError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">@_sharePasswordError</MudAlert>
            }

            <MudTextField @bind-Value="_sharePasswordInput"
                          Label="@Localizer["Password"]"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Immediate="true"
                          OnKeyDown="@HandleSharePasswordKeyDownAsync" />

            <div class="d-flex justify-end mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@UnlockSharedBoardAsync">
                    @Localizer["UnlockSharedLink"]
                </MudButton>
            </div>
        </MudPaper>
    </MudContainer>
}
else
{
    var selectedElement = _selectedElements.Count == 1 ? _selectedElements[0] : null;

    <div style="display: flex; flex-direction: column; height: calc(100vh - 64px); height: calc(100dvh - 64px);">
        @if (!_useCompactLayout)
        {
            <MudPaper Elevation="1" Class="orim-board-toolbar orim-board-toolbar-desktop">
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@_board.Title</MudText>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                    @(_shareCanEdit ? Localizer["Edit"] : Localizer["ReadOnly"])
                </MudChip>
                <MudTextField T="string"
                              Value="@_displayName"
                              ValueChanged="@HandleDisplayNameChangedAsync"
                              Immediate="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="orim-shared-name-input"
                              Label="@Localizer["DisplayName"]" />
                <div class="orim-active-participants">
                    @foreach (var participant in ActiveParticipants)
                    {
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Outlined"
                                 Style="@GetParticipantChipStyle(participant.ColorHex)">
                            @participant.DisplayName
                        </MudChip>
                    }
                </div>
                <MudSpacer />

                @if (_shareCanEdit)
                {
                    <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Style="border-radius: 8px;">
                        <MudTooltip Text="@Localizer["SelectToolTooltip"]" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.NearMe"
                                           Color="@(_selectedTool == BoardEditor.Tool.Select ? Color.Primary : Color.Default)"
                                           OnClick="@(() => SelectTool(BoardEditor.Tool.Select))" />
                        </MudTooltip>
                        <MudTooltip Text="@Localizer["DrawRectangleTooltip"]" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Rectangle"
                                           Color="@(_selectedTool == BoardEditor.Tool.Rectangle ? Color.Primary : Color.Default)"
                                           OnClick="@(() => SelectTool(BoardEditor.Tool.Rectangle))" />
                        </MudTooltip>
                        <MudTooltip Text="@Localizer["DrawCircleTooltip"]" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.PanoramaFishEye"
                                           Color="@(_selectedTool == BoardEditor.Tool.Circle ? Color.Primary : Color.Default)"
                                           OnClick="@(() => SelectTool(BoardEditor.Tool.Circle))" />
                        </MudTooltip>
                        <MudTooltip Text="@Localizer["DrawTriangleTooltip"]" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.ChangeHistory"
                                           Color="@(_selectedTool == BoardEditor.Tool.Triangle ? Color.Primary : Color.Default)"
                                           OnClick="@(() => SelectTool(BoardEditor.Tool.Triangle))" />
                        </MudTooltip>
                        <MudTooltip Text="@Localizer["ConnectArrowTooltip"]" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.NorthEast"
                                           Color="@(_selectedTool == BoardEditor.Tool.Arrow ? Color.Primary : Color.Default)"
                                           OnClick="@(() => SelectTool(BoardEditor.Tool.Arrow))" />
                        </MudTooltip>
                        <MudTooltip Text="@Localizer["InsertIconTooltip"]" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.AddReaction"
                                           Color="@(_selectedTool == BoardEditor.Tool.Icon ? Color.Primary : Color.Default)"
                                           OnClick="@OpenIconPickerAsync" />
                        </MudTooltip>
                    </MudButtonGroup>

                    <MudTooltip Text="@Localizer["Undo"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Undo"
                                       Size="Size.Small"
                                       Disabled="@(!_commandStack.CanUndo)"
                                       OnClick="@UndoAsync" />
                    </MudTooltip>

                    <MudTooltip Text="@Localizer["Redo"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Redo"
                                       Size="Size.Small"
                                       Disabled="@(!_commandStack.CanRedo)"
                                       OnClick="@RedoAsync" />
                    </MudTooltip>

                    <MudDivider Vertical="true" FlexItem="true" />

                    @if (_selectedElement is not null)
                    {
                        <MudTooltip Text="@Localizer["DeleteSelectedElement"]" Arrow="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@DeleteSelectedElementAsync" />
                        </MudTooltip>
                    }

                    <MudTooltip Text="@Localizer["Properties"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Tune"
                                       Size="Size.Small"
                                       Color="@(_propertiesPanelOpen ? Color.Primary : Color.Default)"
                                       OnClick="@TogglePropertiesPanel" />
                    </MudTooltip>
                }

                <MudTooltip Text="@Localizer["ZoomOut"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                   Size="Size.Small"
                                   OnClick="@ZoomOutAsync" />
                </MudTooltip>
                  <input class="orim-board-zoom-input"
                       value="@_zoomDisplayValue"
                       @onchange="HandleZoomInputChangedAsync"
                      aria-label="@Localizer["ZoomLevelPercent"]" />
                <MudTooltip Text="@Localizer["ZoomIn"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   OnClick="@ZoomInAsync" />
                </MudTooltip>
                <MudTooltip Text="@Localizer["FitToContent"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.FitScreen"
                                   Size="Size.Small"
                                   OnClick="@FitToContentAsync" />
                </MudTooltip>
                <MudTooltip Text="@Localizer["OpenHelp"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.HelpOutline"
                                   Size="Size.Small"
                                   OnClick="@OpenHelpDialog" />
                </MudTooltip>
                @if (_shareCanEdit)
                {
                    <MudTooltip Text="@Localizer["BoardSettings"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Settings"
                                       Size="Size.Small"
                                       OnClick="@OpenBoardSettingsDialogAsync" />
                    </MudTooltip>
                }
                <MudTooltip Text="@Localizer["ExportBoardJson"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.FileDownload"
                                   Size="Size.Small"
                                   OnClick="@ExportJson" />
                </MudTooltip>
            </MudPaper>
        }
        @if (_useCompactLayout)
        {
            <MudPaper Elevation="1" Class="orim-board-toolbar orim-board-toolbar-mobile">
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">@_board.Title</MudText>
                <MudSpacer />

                @if (_shareCanEdit)
                {
                    <MudTooltip Text="@Localizer["SelectToolTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.NearMe"
                                       Size="Size.Small"
                                       Color="@(_selectedTool == BoardEditor.Tool.Select ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(BoardEditor.Tool.Select))" />
                    </MudTooltip>

                    <MudMenu Icon="@GetMobileShapeIcon()"
                             Size="Size.Small"
                             Color="@(IsShapeTool(_selectedTool) ? Color.Primary : Color.Default)"
                             Dense="true">
                        <MudMenuItem Icon="@Icons.Material.Filled.Rectangle"
                                     OnClick="@(() => SelectTool(BoardEditor.Tool.Rectangle))">@Localizer["DrawRectangleTooltip"]</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.PanoramaFishEye"
                                     OnClick="@(() => SelectTool(BoardEditor.Tool.Circle))">@Localizer["DrawCircleTooltip"]</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.ChangeHistory"
                                     OnClick="@(() => SelectTool(BoardEditor.Tool.Triangle))">@Localizer["DrawTriangleTooltip"]</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.AddReaction"
                                     OnClick="@OpenIconPickerAsync">@Localizer["InsertIconTooltip"]</MudMenuItem>
                    </MudMenu>

                    <MudTooltip Text="@Localizer["ConnectArrowTooltip"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.NorthEast"
                                       Size="Size.Small"
                                       Color="@(_selectedTool == BoardEditor.Tool.Arrow ? Color.Primary : Color.Default)"
                                       OnClick="@(() => SelectTool(BoardEditor.Tool.Arrow))" />
                    </MudTooltip>

                    <MudIconButton Icon="@Icons.Material.Filled.Undo"
                                   Size="Size.Small"
                                   Disabled="@(!_commandStack.CanUndo)"
                                   OnClick="@UndoAsync" />

                    @if (_selectedElement is not null)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@DeleteSelectedElementAsync" />
                    }

                    <MudIconButton Icon="@Icons.Material.Filled.Settings"
                                   Size="Size.Small"
                                   OnClick="@OpenBoardSettingsDialogAsync" />

                    <MudIconButton Icon="@Icons.Material.Filled.Tune"
                                   Size="Size.Small"
                                   Color="@(_propertiesPanelOpen ? Color.Primary : Color.Default)"
                                   OnClick="@TogglePropertiesPanel" />
                }

                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true">
                    <MudMenuItem Disabled="true">@_displayName</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Remove" OnClick="@ZoomOutAsync">@Localizer["ZoomOut"]</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@ZoomInAsync">@Localizer["ZoomIn"]</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.FitScreen" OnClick="@FitToContentAsync">@Localizer["FitToContent"]</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.HelpOutline" OnClick="@OpenHelpDialog">@Localizer["OpenHelp"]</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.FileDownload" OnClick="@ExportJson">@Localizer["ExportBoardJson"]</MudMenuItem>
                </MudMenu>
            </MudPaper>
        }
        <div style="flex: 1; overflow: hidden; position: relative;">
            <WhiteboardCanvas @ref="_canvas" Board="@_board" CanEdit="@_shareCanEdit"
                              CommandStack="@_commandStack"
                              FitRightInset="@(_shareCanEdit && _propertiesPanelOpen ? 388d : 0d)"
                              OnBoardChanged="@HandleBoardChangedAsync"
                              OnSelectedElementChanged="@HandleSelectedElementChangedAsync"
                              OnSelectedElementsChanged="@HandleSelectedElementsChangedAsync"
                              OnZoomChanged="@HandleZoomChanged"
                              OnToolChanged="@HandleToolChangedAsync"
                              PendingIconName="@_pendingIconName"
                              RemoteCursors="@_remoteCursors"
                              OnPointerPresenceChanged="@HandlePointerPresenceChangedAsync"
                              SelectedTool="@_selectedTool" />

            @if (_shareCanEdit)
            {
                <ElementPropertiesPanel @key="@(selectedElement?.Id ?? Guid.Empty)"
                                        Board="@_board"
                                        Element="@selectedElement"
                                        SelectionCount="@_selectedElements.Count"
                                        IsOpen="@_propertiesPanelOpen"
                                        OnClose="@ClosePropertiesPanel"
                                        OnPreviewChanged="@OnElementPropertyPreviewChangedAsync"
                                        OnChanged="@OnElementPropertyChangedAsync" />
            }

            @if (_useCompactLayout)
            {
                <div class="orim-mobile-zoom-controls">
                    <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@ZoomOutAsync" />
                    <span class="orim-mobile-zoom-label">@_zoomDisplayValue</span>
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@ZoomInAsync" />
                    <MudIconButton Icon="@Icons.Material.Filled.FitScreen"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@FitToContentAsync" />
                </div>
            }
        </div>
    </div>

    <MudDialog @bind-Visible="_iconPickerVisible" Options="_iconDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["MaterialDesignIcons"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_iconSearch"
                          Label="@Localizer["SearchIcon"]"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" />

            @if (_isLoadingIcons)
            {
                <div style="display:flex; align-items:center; justify-content:center; min-height:220px;">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_iconLoadError))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4">@_iconLoadError</MudAlert>
            }
            else
            {
                <MudText Typo="Typo.caption" Class="mt-2 mb-2 orim-board-muted-text">
                    @string.Format(Localizer["IconCount"], FilteredMaterialIcons.Count)
                </MudText>
                <div class="orim-icon-picker-grid">
                    @foreach (var iconName in FilteredMaterialIcons)
                    {
                        <button type="button"
                                @onclick="@(() => SelectMaterialIconAsync(iconName))"
                                class="orim-icon-picker-card">
                            <span class="mdi @iconName orim-icon-picker-preview"></span>
                            <span class="orim-icon-picker-label">@iconName[4..]</span>
                        </button>
                    }
                </div>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@CloseIconPicker">@Localizer["Cancel"]</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_helpDialogVisible" Options="_helpDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["HelpDialogTitle"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["ToolsSectionTitle"]</MudText>
            <ul style="margin:0 0 16px 18px; padding:0; color:#334155; line-height:1.5;">
                <li>@Localizer["HelpToolsSelect"]</li>
                <li>@Localizer["HelpToolsShapes"]</li>
                <li>@Localizer["HelpToolsArrow"]</li>
                <li>@Localizer["HelpToolsIcon"]</li>
            </ul>

            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["SelectionGroupsSectionTitle"]</MudText>
            <ul style="margin:0 0 16px 18px; padding:0; color:#334155; line-height:1.5;">
                <li>@Localizer["HelpSelectionMarquee"]</li>
                <li>@Localizer["HelpSelectionAdditive"]</li>
                <li>@Localizer["HelpSelectionGroupMove"]</li>
                <li>@Localizer["HelpSelectionSingleEdit"]</li>
                <li>@Localizer["HelpSelectionZoom"]</li>
                <li>@Localizer["HelpSelectionSnapDisable"]</li>
            </ul>

            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["ShortcutsSectionTitle"]</MudText>
            <ul style="margin:0 0 0 18px; padding:0; color:#334155; line-height:1.5;">
                <li>@Localizer["ShortcutUndo"]</li>
                <li>@Localizer["ShortcutRedo"]</li>
                <li>@Localizer["ShortcutDelete"]</li>
            </ul>
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@CloseHelpDialog">@Localizer["Close"]</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog @bind-Visible="_boardSettingsDialogVisible" Options="_helpDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">@Localizer["BoardSettings"]</MudText>
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2" Class="orim-board-muted-text mb-4">@Localizer["BoardSettingsDescription"]</MudText>
            <MudText Typo="Typo.subtitle2" Class="mb-2">@Localizer["GeneralBoardSettings"]</MudText>
            <MudCheckBox @bind-Value="_boardLabelOutlineEnabled"
                         T="bool"
                         Label="@Localizer["LabelOutlineEnabled"]" />
            <MudCheckBox @bind-Value="_boardArrowOutlineEnabled"
                         T="bool"
                         Label="@Localizer["ArrowOutlineEnabled"]" />
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@CloseBoardSettingsDialog">@Localizer["Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(!_shareCanEdit)"
                       OnClick="@ConfirmBoardSettingsAsync">@Localizer["Save"]</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    [Parameter] public string Token { get; set; } = "";
    private Board? _board;
    private bool _notFound;
    private WhiteboardCanvas? _canvas;
    private readonly CommandStack _commandStack = new();
    private readonly string _boardSyncClientId = Guid.NewGuid().ToString("N");
    private IDisposable? _boardChangeSubscription;
    private IDisposable? _cursorPresenceSubscription;
    private readonly CancellationTokenSource _presenceHeartbeatCancellation = new();
    private Task? _presenceHeartbeatTask;
    private IReadOnlyList<BoardCursorPresence> _remoteCursors = [];
    private BoardPointerPosition? _localPointerPosition;
    private BoardEditor.Tool _selectedTool = BoardEditor.Tool.Select;
    private BoardElement? _selectedElement;
    private List<BoardElement> _selectedElements = [];
    private bool _propertiesPanelOpen;
    private string _lastCommittedBoardSnapshot = string.Empty;
    private string _displayName = BoardPresenceIdentity.CreateFantasyName();
    private string _cursorColor = BoardPresenceIdentity.ResolveColor(Guid.NewGuid().ToString("N"));
    private bool _shareAccessGranted;
    private bool _shareCanEdit;
    private string? _verifiedSharePassword;
    private string _sharePasswordInput = string.Empty;
    private string? _sharePasswordError;
    private bool _presenceLifecycleRegistered;
    private bool _loadedPresenceIdentity;
    private bool _useCompactLayout;
    private bool _iconPickerVisible;
    private bool _helpDialogVisible;
    private bool _boardSettingsDialogVisible;
    private bool _boardLabelOutlineEnabled = true;
    private bool _boardArrowOutlineEnabled = true;
    private bool _isLoadingIcons;
    private int _zoomPercentage = 100;
    private string _zoomDisplayValue = "100%";
    private string _iconSearch = string.Empty;
    private string _lastIconSearchValue = string.Empty;
    private string? _iconLoadError;
    private string? _pendingIconName;
    private IReadOnlyList<string> _filteredMaterialIconsCache = [];
    private readonly DialogOptions _iconDialogOptions = new() { FullWidth = true, MaxWidth = MaxWidth.Medium, CloseButton = true };
    private readonly DialogOptions _helpDialogOptions = new() { FullWidth = true, MaxWidth = MaxWidth.Small, CloseButton = true };
    private List<string> _materialIcons = [];
    private static List<string>? _cachedMaterialIcons;
    private const string SharedNameStorageKey = "orim.shared.display-name";
    private const string SharedColorStorageKey = "orim.shared.cursor-color";
    private record struct ViewportProfile(double Width, double Height, bool IsCompact);
    private IReadOnlyList<BoardCursorPresence> ActiveParticipants =>
    [
        new(_boardSyncClientId, _displayName, _cursorColor, _localPointerPosition?.WorldX, _localPointerPosition?.WorldY, DateTime.UtcNow),
        .. _remoteCursors
    ];
    private IReadOnlyList<string> FilteredMaterialIcons
    {
        get
        {
            if (_iconSearch == _lastIconSearchValue)
            {
                return _filteredMaterialIconsCache;
            }

            _lastIconSearchValue = _iconSearch;
            var search = (_iconSearch ?? string.Empty).Trim();
            _filteredMaterialIconsCache = _materialIcons
                .Where(icon => string.IsNullOrWhiteSpace(search)
                    || icon.Contains(search, StringComparison.OrdinalIgnoreCase))
                .Take(200)
                .ToList();

            return _filteredMaterialIconsCache;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Token))
        {
            _notFound = true;
            return;
        }
        _board = await BoardService.GetBoardByShareTokenAsync(Token);
        if (_board is null || _board.Visibility != BoardVisibility.Shared)
        {
            _notFound = true;
            return;
        }

        if (!BoardService.IsSharePasswordProtected(_board))
        {
            await GrantSharedAccessAsync(null);
        }

        InitializeBoardSettingsDrafts();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var viewport = await JS.InvokeAsync<ViewportProfile>("orimWhiteboard.getViewportProfile");
                _useCompactLayout = viewport.IsCompact;
                StateHasChanged();
            }
            catch
            {
            }
        }

        if (!_loadedPresenceIdentity)
        {
            var storedName = await JS.InvokeAsync<string?>("orimWhiteboard.getLocalStorageValue", SharedNameStorageKey);
            var storedColor = await JS.InvokeAsync<string?>("orimWhiteboard.getLocalStorageValue", SharedColorStorageKey);
            var changed = false;

            if (!string.IsNullOrWhiteSpace(storedName) && storedName != _displayName)
            {
                _displayName = storedName;
                changed = true;
            }

            if (!string.IsNullOrWhiteSpace(storedColor) && storedColor != _cursorColor)
            {
                _cursorColor = storedColor;
                changed = true;
            }

            if (string.IsNullOrWhiteSpace(storedName))
            {
                await JS.InvokeVoidAsync("orimWhiteboard.setLocalStorageValue", SharedNameStorageKey, _displayName);
            }

            if (string.IsNullOrWhiteSpace(storedColor))
            {
                await JS.InvokeVoidAsync("orimWhiteboard.setLocalStorageValue", SharedColorStorageKey, _cursorColor);
            }

            if (_localPointerPosition is not null)
            {
                await PublishPresenceAsync(_localPointerPosition);
            }

            _loadedPresenceIdentity = true;

            if (changed)
            {
                StateHasChanged();
            }
        }

        if (_board is not null && _shareAccessGranted && !_presenceLifecycleRegistered)
        {
            await JS.InvokeVoidAsync("orimWhiteboard.registerPresenceLifecycle", _board.Id, _boardSyncClientId);
            _presenceLifecycleRegistered = true;
        }
    }

    private async Task UnlockSharedBoardAsync()
    {
        if (_board is null)
        {
            return;
        }

        if (!BoardService.HasSharedLinkAccess(_board, _sharePasswordInput))
        {
            _sharePasswordError = Localizer["InvalidSharePassword"];
            return;
        }

        _sharePasswordError = null;
        await GrantSharedAccessAsync(_sharePasswordInput);
    }

    private async Task HandleSharePasswordKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await UnlockSharedBoardAsync();
        }
    }

    private async Task FitToContentAsync()
    {
        if (_canvas is null)
        {
            return;
        }

        await _canvas.FitToContentAsync();
    }

    private async Task ZoomInAsync()
    {
        if (_canvas is null)
        {
            return;
        }

        await _canvas.ZoomInAsync();
    }

    private async Task ZoomOutAsync()
    {
        if (_canvas is null)
        {
            return;
        }

        await _canvas.ZoomOutAsync();
    }

    private async Task HandleZoomInputChangedAsync(ChangeEventArgs args)
    {
        if (_canvas is null)
        {
            return;
        }

        var rawValue = args.Value?.ToString()?.Trim() ?? string.Empty;
        var numericValue = new string(rawValue.Where(char.IsDigit).ToArray());
        if (!int.TryParse(numericValue, out var percentage))
        {
            _zoomDisplayValue = $"{_zoomPercentage}%";
            StateHasChanged();
            return;
        }

        percentage = Math.Clamp(percentage, 20, 350);
        await _canvas.SetZoomPercentageAsync(percentage);
    }

    private async Task HandleDisplayNameChangedAsync(string value)
    {
        _displayName = string.IsNullOrWhiteSpace(value) ? BoardPresenceIdentity.CreateFantasyName() : value.Trim();
        await JS.InvokeVoidAsync("orimWhiteboard.setLocalStorageValue", SharedNameStorageKey, _displayName);
        await PublishPresenceAsync(_localPointerPosition);
    }

    private Task HandlePointerPresenceChangedAsync(BoardPointerPosition? pointer)
    {
        _localPointerPosition = pointer;
        if (_board is null)
        {
            return Task.CompletedTask;
        }

        return PublishPresenceAsync(pointer);
    }

    private Task PublishPresenceAsync(BoardPointerPosition? pointer)
    {
        if (_board is null)
        {
            return Task.CompletedTask;
        }

        return BoardPresenceService.UpsertCursorAsync(
            _board.Id,
            new BoardCursorPresence(
                _boardSyncClientId,
                _displayName,
                _cursorColor,
                pointer?.WorldX,
                pointer?.WorldY,
                DateTime.UtcNow));
    }

