@page "/admin/settings"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using Orim.Web.Services
@inject ThemeCatalogService ThemeCatalogService
@inject ThemeManager ThemeManager
@inject IJSRuntime JS
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["AppTitle"] - @Localizer["OrimSettings"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <div class="d-flex justify-space-between align-center mb-6" style="gap: 16px; flex-wrap: wrap;">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 700;">@Localizer["OrimSettings"]</MudText>
            <MudText Typo="Typo.body1" Class="orim-board-muted-text mt-2">@Localizer["ThemeManagementDescription"]</MudText>
        </div>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.UploadFile" HtmlTag="label">
            @Localizer["UploadThemeJson"]
            <InputFile OnChange="@HandleThemeUploadAsync" accept=".json,application/json" style="display:none" />
        </MudButton>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message) && _messageSeverity is not null)
    {
        <MudAlert Severity="@_messageSeverity.Value" Dense="true" Class="mb-4">
            @_message
        </MudAlert>
    }

    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudText Typo="Typo.subtitle2">@Localizer["ThemeManagement"]</MudText>
        <MudText Typo="Typo.body2" Class="orim-board-muted-text mt-2">@Localizer["ThemeUploadReplaceHint"]</MudText>
        <MudText Typo="Typo.body2" Class="orim-board-muted-text mt-1">@Localizer["ThemeImmutableHint"]</MudText>
    </MudPaper>

    <MudTable Items="@_themes" Hover="true" Elevation="2" Style="border-radius: 12px;" Loading="@_isLoading">
        <HeaderContent>
            <MudTh>@Localizer["ThemeName"]</MudTh>
            <MudTh>@Localizer["ThemeKey"]</MudTh>
            <MudTh>@Localizer["ThemeMode"]</MudTh>
            <MudTh>@Localizer["ThemeAvailability"]</MudTh>
            <MudTh>@Localizer["ThemeProtection"]</MudTh>
            <MudTh>@Localizer["Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@Localizer["ThemeName"]">
                <div class="d-flex align-center" style="gap: 8px;">
                    <span>@context.Name</span>
                    @if (string.Equals(context.Key, ThemeManager.CurrentThemeKey, StringComparison.OrdinalIgnoreCase))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary">@Localizer["CurrentTheme"]</MudChip>
                    }
                </div>
            </MudTd>
            <MudTd DataLabel="@Localizer["ThemeKey"]">@context.Key</MudTd>
            <MudTd DataLabel="@Localizer["ThemeMode"]">
                <MudChip T="string" Size="Size.Small" Color="@(context.IsDarkMode ? Color.Secondary : Color.Default)">
                    @(context.IsDarkMode ? Localizer["DarkMode"] : Localizer["LightMode"])
                </MudChip>
            </MudTd>
            <MudTd DataLabel="@Localizer["ThemeAvailability"]">
                <MudSwitch T="bool"
                           Value="@context.IsEnabled"
                           ValueChanged="@((bool value) => ToggleThemeAvailabilityAsync(context, value))"
                           Disabled="@context.IsProtected"
                           Color="Color.Primary" />
            </MudTd>
            <MudTd DataLabel="@Localizer["ThemeProtection"]">
                <MudChip T="string" Size="Size.Small" Color="@(context.IsProtected ? Color.Warning : Color.Success)">
                    @(context.IsProtected ? Localizer["Protected"] : Localizer["Editable"])
                </MudChip>
            </MudTd>
            <MudTd>
                <MudTooltip Text="@Localizer["DownloadThemeJson"]" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small"
                                   OnClick="@(() => DownloadThemeAsync(context))" />
                </MudTooltip>
                @if (!context.IsProtected)
                {
                    <MudTooltip Text="@Localizer["DeleteTheme"]" Arrow="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteThemeAsync(context))" />
                    </MudTooltip>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>

@code {
    private List<ThemeDefinition> _themes = [];
    private bool _isLoading = true;
    private string? _message;
    private Severity? _messageSeverity;

    protected override async Task OnInitializedAsync()
    {
        await LoadThemesAsync();
    }

    private async Task LoadThemesAsync()
    {
        _isLoading = true;
        _themes = (await ThemeCatalogService.GetThemesAsync()).ToList();
        _isLoading = false;
    }

    private async Task HandleThemeUploadAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(1024 * 1024);
            await ThemeCatalogService.ImportThemeAsync(stream);
            await ThemeManager.ReloadThemesAsync(JS);
            await LoadThemesAsync();
            SetMessage(Localizer["ThemeUploaded"], Severity.Success);
        }
        catch (Exception ex) when (ex is InvalidOperationException or System.Text.Json.JsonException)
        {
            SetMessage(ex.Message, Severity.Error);
        }
    }

    private async Task ToggleThemeAvailabilityAsync(ThemeDefinition theme, bool enabled)
    {
        try
        {
            await ThemeCatalogService.SetEnabledAsync(theme.Key, enabled);
            await ThemeManager.ReloadThemesAsync(JS);
            await LoadThemesAsync();
        }
        catch (InvalidOperationException ex)
        {
            SetMessage(ex.Message, Severity.Error);
        }
    }

    private async Task DownloadThemeAsync(ThemeDefinition theme)
    {
        var json = await ThemeCatalogService.ExportThemeJsonAsync(theme.Key);
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("orimWhiteboard.downloadFile", $"{theme.Key}.json", "application/json", base64);
    }

    private async Task DeleteThemeAsync(ThemeDefinition theme)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", string.Format(Localizer["ThemeDeleteConfirmation"], theme.Name));
        if (!confirmed)
        {
            return;
        }

        try
        {
            await ThemeCatalogService.DeleteThemeAsync(theme.Key);
            await ThemeManager.ReloadThemesAsync(JS);
            await LoadThemesAsync();
            SetMessage(Localizer["ThemeDeleted"], Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            SetMessage(ex.Message, Severity.Error);
        }
    }

    private void SetMessage(string message, Severity severity)
    {
        _message = message;
        _messageSeverity = severity;
    }
}