@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject UserService UserService
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["AppTitle"] - @Localizer["UserManagement"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h4" Style="font-weight: 700;">@Localizer["UserManagement"]</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="@OpenCreateDialog" Style="border-radius: 8px;">
            @Localizer["NewUser"]
        </MudButton>
    </div>

    <MudTable Items="@_users" Hover="true" Elevation="2" Style="border-radius: 12px;" Loading="@(_users is null)">
        <HeaderContent>
            <MudTh>@Localizer["Username"]</MudTh>
            <MudTh>@Localizer["Role"]</MudTh>
            <MudTh>@Localizer["Status"]</MudTh>
            <MudTh>@Localizer["Created"]</MudTh>
            <MudTh>@Localizer["Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@Localizer["Username"]">@context.Username</MudTd>
            <MudTd DataLabel="@Localizer["Role"]">
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Role == UserRole.Admin ? Color.Primary : Color.Default)">
                    @(context.Role == UserRole.Admin ? Localizer["Admin"] : Localizer["User"])
                </MudChip>
            </MudTd>
            <MudTd DataLabel="@Localizer["Status"]">
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.IsActive ? Color.Success : Color.Error)">
                    @(context.IsActive ? Localizer["Active"] : Localizer["Deactivated"])
                </MudChip>
            </MudTd>
            <MudTd DataLabel="@Localizer["Created"]">@context.CreatedAt.ToString("d")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => OpenEditDialog(context))" />
                @if (context.IsActive)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Block" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeactivateUser(context))" />
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>

<MudDialog @bind-Visible="_dialogVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingUser is null ? Localizer["NewUser"] : Localizer["EditUser"])</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_formUsername" Label="@Localizer["Username"]" Variant="Variant.Outlined"
                      Required="true" Disabled="@(_editingUser is not null)" />
        <MudTextField @bind-Value="_formPassword" Label="@Localizer["Password"]" Variant="Variant.Outlined"
                      InputType="InputType.Password" Class="mt-4"
                      HelperText="@(_editingUser is not null ? Localizer["LeavePasswordEmpty"] : string.Empty)"
                      Required="@(_editingUser is null)" />
        <MudSelect @bind-Value="_formRole" Label="@Localizer["Role"]" Variant="Variant.Outlined" Class="mt-4">
            <MudSelectItem Value="UserRole.User">@Localizer["User"]</MudSelectItem>
            <MudSelectItem Value="UserRole.Admin">@Localizer["Admin"]</MudSelectItem>
        </MudSelect>
        @if (!string.IsNullOrEmpty(_formError))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">@_formError</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseDialog">@Localizer["Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@SaveUser">@Localizer["Save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<User>? _users;
    private bool _dialogVisible;
    private User? _editingUser;
    private string _formUsername = "";
    private string _formPassword = "";
    private UserRole _formRole = UserRole.User;
    private string? _formError;

    protected override async Task OnInitializedAsync()
    {
        _users = await UserService.GetAllUsersAsync();
    }

    private void OpenCreateDialog()
    {
        _editingUser = null;
        _formUsername = "";
        _formPassword = "";
        _formRole = UserRole.User;
        _formError = null;
        _dialogVisible = true;
    }

    private void OpenEditDialog(User user)
    {
        _editingUser = user;
        _formUsername = user.Username;
        _formPassword = "";
        _formRole = user.Role;
        _formError = null;
        _dialogVisible = true;
    }

    private void CloseDialog() => _dialogVisible = false;

    private async Task SaveUser()
    {
        _formError = null;
        try
        {
            if (_editingUser is null)
            {
                if (string.IsNullOrWhiteSpace(_formUsername) || string.IsNullOrWhiteSpace(_formPassword))
                {
                    _formError = Localizer["UsernameAndPasswordRequired"];
                    return;
                }
                await UserService.CreateUserAsync(_formUsername.Trim(), _formPassword, _formRole);
            }
            else
            {
                _editingUser.Role = _formRole;
                await UserService.UpdateUserAsync(_editingUser);
                if (!string.IsNullOrWhiteSpace(_formPassword))
                    await UserService.SetPasswordAsync(_editingUser.Id, _formPassword);
            }
            _dialogVisible = false;
            _users = await UserService.GetAllUsersAsync();
        }
        catch (InvalidOperationException ex)
        {
            _formError = ex.Message;
        }
    }

    private async Task DeactivateUser(User user)
    {
        await UserService.DeactivateUserAsync(user.Id);
        _users = await UserService.GetAllUsersAsync();
    }
}
