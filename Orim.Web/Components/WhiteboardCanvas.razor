@using Orim.Web.Components.Pages
@inject IJSRuntime JS

<div id="whiteboard-surface"
     style="@GetSurfaceStyle()"
     @onmousedown="OnSurfaceMouseDown"
     @onmousemove="OnSurfaceMouseMove"
     @onmouseup="OnSurfaceMouseUp"
     @onmouseleave="OnSurfaceMouseLeave"
     @onwheel="OnSurfaceWheel"
     @onmousedown:preventDefault="true"
     @onwheel:preventDefault="true">

    <div style="@GetWorldStyle()">
        @if (Board is not null)
        {
            @foreach (var element in Board.Elements.OrderBy(e => e.ZIndex))
            {
                @RenderElement(element)
            }
        }

        @if (_draftRectangle is not null)
        {
            <div style="position: absolute; left: @Px(_draftRectangle.X); top: @Px(_draftRectangle.Y); width: @Px(_draftRectangle.Width); height: @Px(_draftRectangle.Height); border: 2px dashed #2563eb; background: rgba(37, 99, 235, 0.12); border-radius: 10px; pointer-events: none;"></div>
        }

        @if (SelectedElement is not null)
        {
            <div style="position: absolute; left: @Px(SelectedElement.X - 4); top: @Px(SelectedElement.Y - 4); width: @Px(SelectedElement.Width + 8); height: @Px(SelectedElement.Height + 8); border: 2px dashed #2563eb; border-radius: 12px; pointer-events: none;"></div>
        }
    </div>
</div>

@code {
    private const string SurfaceId = "whiteboard-surface";
    private const double MinimumRectangleSize = 12;
    private const double MinZoom = 0.2;
    private const double MaxZoom = 3.5;
    private const double ZoomStep = 1.1;

    [Parameter] public Board? Board { get; set; }
    [Parameter] public bool CanEdit { get; set; }
    [Parameter] public CommandStack CommandStack { get; set; } = new();
    [Parameter] public EventCallback OnBoardChanged { get; set; }
    [Parameter] public BoardEditor.Tool SelectedTool { get; set; }

    public BoardElement? SelectedElement { get; private set; }

    private bool _isDraggingSelection;
    private bool _isDrawingRectangle;
    private bool _isPanning;
    private bool _hasInteractionChanged;
    private Point _dragPointerOffset;
    private Point _drawStart;
    private Point _panStartScreen;
    private Point _cameraOffset = new(0, 0);
    private Size _surfaceSize;
    private ShapeElement? _draftRectangle;
    private double _zoom = 1;

    private record struct Point(double X, double Y);
    private record struct Size(double Width, double Height);
    private record struct RelativePointer(double X, double Y, double Width, double Height);

    public void ClearSelection()
    {
        SelectedElement = null;
        StateHasChanged();
    }

    private async Task<Point> GetScreenPointerAsync(MouseEventArgs e)
    {
        var pointer = await JS.InvokeAsync<RelativePointer>("orimWhiteboard.clientToElement", SurfaceId, e.ClientX, e.ClientY);
        _surfaceSize = new Size(SanitizeCoordinate(pointer.Width), SanitizeCoordinate(pointer.Height));
        return ClampToSurface(new Point(SanitizeCoordinate(pointer.X), SanitizeCoordinate(pointer.Y)));
    }

    private Point ScreenToWorld(Point point) => new(
        (point.X - _cameraOffset.X) / _zoom,
        (point.Y - _cameraOffset.Y) / _zoom);

    private string GetSurfaceStyle()
    {
        var gridStep = 24 * _zoom;
        var offsetX = GetWrappedGridOffset(_cameraOffset.X, gridStep);
        var offsetY = GetWrappedGridOffset(_cameraOffset.Y, gridStep);

        return $"position: relative; width: 100%; height: 100%; overflow: hidden; background-color: #ffffff; background-image: linear-gradient(#eef2f7 1px, transparent 1px), linear-gradient(90deg, #eef2f7 1px, transparent 1px); background-size: {CssNumber(gridStep)}px {CssNumber(gridStep)}px; background-position: {CssNumber(offsetX)}px {CssNumber(offsetY)}px; cursor: {GetCursor()}; touch-action: none; user-select: none;";
    }

    private string GetWorldStyle() =>
        $"position: absolute; inset: 0; overflow: visible; transform-origin: 0 0; transform: translate({CssNumber(_cameraOffset.X)}px, {CssNumber(_cameraOffset.Y)}px) scale({CssNumber(_zoom)});";

    private static double GetWrappedGridOffset(double offset, double step)
    {
        if (step <= 0)
        {
            return 0;
        }

        var wrapped = offset % step;
        return wrapped < 0 ? wrapped + step : wrapped;
    }

    private async Task OnSurfaceMouseDown(MouseEventArgs e)
    {
        if (e.Button != 0 && e.Button != 1)
        {
            return;
        }

        var screenPoint = await GetScreenPointerAsync(e);

        if (e.Button == 1)
        {
            _isPanning = true;
            _panStartScreen = screenPoint;
            return;
        }

        var worldPoint = ScreenToWorld(screenPoint);

        if (SelectedTool == BoardEditor.Tool.Rectangle && CanEdit)
        {
            SelectedElement = null;
            _isDrawingRectangle = true;
            _hasInteractionChanged = false;
            _drawStart = worldPoint;
            _draftRectangle = new ShapeElement
            {
                X = SanitizeCoordinate(worldPoint.X),
                Y = SanitizeCoordinate(worldPoint.Y),
                Width = 0,
                Height = 0,
                ShapeType = ShapeType.Rectangle,
                FillColor = "#ffffff",
                StrokeColor = "#0f172a",
                StrokeWidth = 2
            };
            return;
        }

        var clicked = HitTest(worldPoint);
        SelectedElement = clicked;

        if (!CanEdit || SelectedTool != BoardEditor.Tool.Select)
        {
            return;
        }

        if (clicked is null)
        {
            _isPanning = true;
            _panStartScreen = screenPoint;
            return;
        }

        _isDraggingSelection = true;
        _hasInteractionChanged = false;
        _dragPointerOffset = new Point(worldPoint.X - clicked.X, worldPoint.Y - clicked.Y);
    }

    private async Task OnSurfaceMouseMove(MouseEventArgs e)
    {
        var screenPoint = await GetScreenPointerAsync(e);

        if (_isPanning)
        {
            var dx = screenPoint.X - _panStartScreen.X;
            var dy = screenPoint.Y - _panStartScreen.Y;
            _cameraOffset = new Point(_cameraOffset.X + dx, _cameraOffset.Y + dy);
            _panStartScreen = screenPoint;
            return;
        }

        var worldPoint = ScreenToWorld(screenPoint);

        if (_isDraggingSelection && SelectedElement is not null)
        {
            var nextX = worldPoint.X - _dragPointerOffset.X;
            var nextY = worldPoint.Y - _dragPointerOffset.Y;

            if (Math.Abs(SelectedElement.X - nextX) > 0.1 || Math.Abs(SelectedElement.Y - nextY) > 0.1)
            {
                SelectedElement.X = nextX;
                SelectedElement.Y = nextY;
                _hasInteractionChanged = true;
            }

            return;
        }

        if (_isDrawingRectangle && _draftRectangle is not null)
        {
            UpdateDraftRectangle(worldPoint);
        }
    }

    private async Task OnSurfaceMouseUp(MouseEventArgs e)
    {
        var worldPoint = ScreenToWorld(await GetScreenPointerAsync(e));
        await FinalizeInteractionAsync(worldPoint);
    }

    private async Task OnSurfaceMouseLeave(MouseEventArgs _)
    {
        await FinalizeInteractionAsync(null);
    }

    private async Task OnSurfaceWheel(WheelEventArgs e)
    {
        var screenPoint = await GetScreenPointerAsync(new MouseEventArgs { ClientX = e.ClientX, ClientY = e.ClientY });
        var worldPoint = ScreenToWorld(screenPoint);
        var factor = e.DeltaY < 0 ? ZoomStep : 1 / ZoomStep;
        var nextZoom = Math.Clamp(_zoom * factor, MinZoom, MaxZoom);

        if (Math.Abs(nextZoom - _zoom) < 0.0001)
        {
            return;
        }

        _zoom = nextZoom;
        _cameraOffset = new Point(
            screenPoint.X - worldPoint.X * _zoom,
            screenPoint.Y - worldPoint.Y * _zoom);
    }

    private async Task FinalizeInteractionAsync(Point? pointer)
    {
        _isPanning = false;

        if (_isDraggingSelection)
        {
            _isDraggingSelection = false;
            if (_hasInteractionChanged)
            {
                _hasInteractionChanged = false;
                await OnBoardChanged.InvokeAsync();
            }
        }

        if (_isDrawingRectangle)
        {
            if (pointer is not null && _draftRectangle is not null)
            {
                UpdateDraftRectangle(pointer.Value);
            }

            _isDrawingRectangle = false;

            if (_draftRectangle is not null &&
                _draftRectangle.Width >= MinimumRectangleSize &&
                _draftRectangle.Height >= MinimumRectangleSize &&
                Board is not null)
            {
                var rectangle = new ShapeElement
                {
                    X = SanitizeCoordinate(_draftRectangle.X),
                    Y = SanitizeCoordinate(_draftRectangle.Y),
                    Width = SanitizeCoordinate(_draftRectangle.Width),
                    Height = SanitizeCoordinate(_draftRectangle.Height),
                    ShapeType = ShapeType.Rectangle,
                    FillColor = "#ffffff",
                    StrokeColor = "#0f172a",
                    StrokeWidth = 2,
                    ZIndex = Board.Elements.Count
                };

                Board.Elements.Add(rectangle);
                SelectedElement = rectangle;
                await OnBoardChanged.InvokeAsync();
            }

            _draftRectangle = null;
            _hasInteractionChanged = false;
        }
    }

    private void UpdateDraftRectangle(Point point)
    {
        if (_draftRectangle is null)
        {
            return;
        }

        var currentX = SanitizeCoordinate(point.X);
        var currentY = SanitizeCoordinate(point.Y);
        var startX = SanitizeCoordinate(_drawStart.X);
        var startY = SanitizeCoordinate(_drawStart.Y);

        _draftRectangle.X = Math.Min(startX, currentX);
        _draftRectangle.Y = Math.Min(startY, currentY);
        _draftRectangle.Width = Math.Abs(currentX - startX);
        _draftRectangle.Height = Math.Abs(currentY - startY);
        _hasInteractionChanged = _draftRectangle.Width >= MinimumRectangleSize || _draftRectangle.Height >= MinimumRectangleSize;
    }

    private BoardElement? HitTest(Point point)
    {
        if (Board is null)
        {
            return null;
        }

        foreach (var element in Board.Elements.OrderByDescending(e => e.ZIndex))
        {
            if (element is ArrowElement arrow)
            {
                var source = Board.Elements.FirstOrDefault(candidate => candidate.Id == arrow.SourceElementId);
                var target = Board.Elements.FirstOrDefault(candidate => candidate.Id == arrow.TargetElementId);
                if (source is null || target is null)
                {
                    continue;
                }

                var start = GetDockPosition(source, arrow.SourceDock);
                var end = GetDockPosition(target, arrow.TargetDock);
                if (PointToLineDistance(point, start, end) <= 8)
                {
                    return element;
                }

                continue;
            }

            if (point.X >= element.X && point.X <= element.X + element.Width &&
                point.Y >= element.Y && point.Y <= element.Y + element.Height)
            {
                return element;
            }
        }

        return null;
    }

    private string GetCursor() => SelectedTool switch
    {
        _ when _isPanning => "grabbing",
        BoardEditor.Tool.Rectangle => "crosshair",
        _ when _isDraggingSelection => "grabbing",
        _ => "grab"
    };

    private static string CssNumber(double value) =>
        Math.Round(value, 2, MidpointRounding.AwayFromZero)
            .ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private string Px(double value) => $"{CssNumber(value)}px";

    private Point ClampToSurface(Point point) => new(
        Clamp(SanitizeCoordinate(point.X), 0, Math.Max(0, SanitizeCoordinate(_surfaceSize.Width))),
        Clamp(SanitizeCoordinate(point.Y), 0, Math.Max(0, SanitizeCoordinate(_surfaceSize.Height))));

    private static double SanitizeCoordinate(double value) =>
        double.IsFinite(value) ? value : 0;

    private static double Clamp(double value, double min, double max) => Math.Max(min, Math.Min(max, value));

    private static double PointToLineDistance(Point point, Point start, Point end)
    {
        var dx = end.X - start.X;
        var dy = end.Y - start.Y;
        var lengthSquared = dx * dx + dy * dy;
        if (lengthSquared == 0)
        {
            return Math.Sqrt(Math.Pow(point.X - start.X, 2) + Math.Pow(point.Y - start.Y, 2));
        }

        var projection = Math.Clamp(((point.X - start.X) * dx + (point.Y - start.Y) * dy) / lengthSquared, 0, 1);
        var projectionX = start.X + projection * dx;
        var projectionY = start.Y + projection * dy;
        return Math.Sqrt(Math.Pow(point.X - projectionX, 2) + Math.Pow(point.Y - projectionY, 2));
    }

    private static Point GetDockPosition(BoardElement element, DockPoint dockPoint) => dockPoint switch
    {
        DockPoint.Top => new Point(element.X + element.Width / 2, element.Y),
        DockPoint.Bottom => new Point(element.X + element.Width / 2, element.Y + element.Height),
        DockPoint.Left => new Point(element.X, element.Y + element.Height / 2),
        DockPoint.Right => new Point(element.X + element.Width, element.Y + element.Height / 2),
        _ => new Point(element.X + element.Width / 2, element.Y + element.Height / 2)
    };

    private RenderFragment RenderElement(BoardElement element) => element switch
    {
        ShapeElement shape => RenderShape(shape),
        TextElement text => RenderText(text),
        StickyNoteElement sticky => RenderSticky(sticky),
        ArrowElement arrow => RenderArrow(arrow),
        _ => builder => { }
    };

    private RenderFragment RenderShape(ShapeElement shape) => builder =>
    {
        var selected = SelectedElement?.Id == shape.Id;
        var style = $"position: absolute; left: {Px(shape.X)}; top: {Px(shape.Y)}; width: {Px(shape.Width)}; height: {Px(shape.Height)}; background: {shape.FillColor}; border: {CssNumber(shape.StrokeWidth)}px solid {(selected ? "#2563eb" : shape.StrokeColor)}; box-sizing: border-box;";

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "style", style + GetShapeSpecificStyle(shape.ShapeType));
        builder.CloseElement();
    };

    private string GetShapeSpecificStyle(ShapeType shapeType) => shapeType switch
    {
        ShapeType.Ellipse => " border-radius: 999px;",
        ShapeType.Triangle => " clip-path: polygon(50% 0%, 0% 100%, 100% 100%);",
        _ => " border-radius: 10px;"
    };

    private RenderFragment RenderText(TextElement text) => builder =>
    {
        var style = $"position: absolute; left: {Px(text.X)}; top: {Px(text.Y)}; width: {Px(text.Width)}; min-height: {Px(Math.Max(text.Height, text.FontSize + 8))}; color: {text.Color}; font-size: {Px(text.FontSize)}; font-weight: {(text.IsBold ? "700" : "400")}; font-style: {(text.IsItalic ? "italic" : "normal")}; white-space: pre-wrap;";
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "style", style);
        builder.AddContent(2, text.Text);
        builder.CloseElement();
    };

    private RenderFragment RenderSticky(StickyNoteElement sticky) => builder =>
    {
        var style = $"position: absolute; left: {Px(sticky.X)}; top: {Px(sticky.Y)}; width: {Px(sticky.Width)}; min-height: {Px(sticky.Height)}; padding: 10px; box-sizing: border-box; background: {sticky.BackgroundColor}; border: {CssNumber(1.5)}px solid #d4b94f; border-radius: 12px; color: #1f2937; font-size: {Px(sticky.FontSize)};";
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "style", style);
        builder.AddContent(2, sticky.Text);
        builder.CloseElement();
    };

    private RenderFragment RenderArrow(ArrowElement arrow) => builder =>
    {
        if (Board is null)
        {
            return;
        }

        var source = Board.Elements.FirstOrDefault(element => element.Id == arrow.SourceElementId);
        var target = Board.Elements.FirstOrDefault(element => element.Id == arrow.TargetElementId);
        if (source is null || target is null)
        {
            return;
        }

        var start = GetDockPosition(source, arrow.SourceDock);
        var end = GetDockPosition(target, arrow.TargetDock);
        var dx = end.X - start.X;
        var dy = end.Y - start.Y;
        var length = Math.Sqrt(dx * dx + dy * dy);
        var angle = Math.Atan2(dy, dx) * (180 / Math.PI);
        var style = $"position: absolute; left: {Px(start.X)}; top: {Px(start.Y)}; width: {Px(length)}; height: {Px(Math.Max(arrow.StrokeWidth, 2))}; background: {arrow.StrokeColor}; transform-origin: 0 50%; transform: translateY(-50%) rotate({CssNumber(angle)}deg); border-radius: 999px;";

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "style", style);
        builder.CloseElement();
    };
}