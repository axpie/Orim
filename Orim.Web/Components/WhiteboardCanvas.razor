@using System.Web
@using Orim.Web.Components.Pages
@inject IJSRuntime JS

<div style="width: 100%; height: 100%; overflow: hidden; position: relative;"
     @onmousedown="OnCanvasMouseDown"
     @onmousemove="OnCanvasMouseMove"
     @onmouseup="OnCanvasMouseUp"
     @onwheel="OnWheel">
    <svg id="whiteboard-svg"
         width="100%" height="100%"
         viewBox="@($"{_viewBox.X} {_viewBox.Y} {_viewBox.W} {_viewBox.H}")"
         style="background: #ffffff; cursor: @GetCursor();"
         xmlns="http://www.w3.org/2000/svg">

        <defs>
            <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
                <polygon points="0 0, 10 3.5, 0 7" fill="#000" />
            </marker>
        </defs>

        @* Grid pattern *@
        <defs>
            <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse"
                     x="@_viewBox.X" y="@_viewBox.Y">
                <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#e8ecf0" stroke-width="0.5"/>
            </pattern>
        </defs>
        <rect x="@_viewBox.X" y="@_viewBox.Y" width="@_viewBox.W" height="@_viewBox.H" fill="url(#grid)" />

        @* Render elements *@
        @if (Board is not null)
        {
            @foreach (var element in Board.Elements.OrderBy(e => e.ZIndex))
            {
                @RenderElement(element)
            }
        }

        @* Lasso selection rectangle *@
        @if (_isLassoSelecting)
        {
            <rect x="@Math.Min(_lassoStart.X, _lassoEnd.X)" y="@Math.Min(_lassoStart.Y, _lassoEnd.Y)"
                  width="@Math.Abs(_lassoEnd.X - _lassoStart.X)" height="@Math.Abs(_lassoEnd.Y - _lassoStart.Y)"
                  fill="rgba(110, 64, 201, 0.1)" stroke="#6E40C9" stroke-width="1" stroke-dasharray="4" />
        }

        @* Selection handles *@
        @if (SelectedElement is not null && CanEdit)
        {
            @RenderSelectionHandles(SelectedElement)
        }
        @foreach (var el in _multiSelected)
        {
            @RenderSelectionHandles(el)
        }

        @* Dock points when creating arrows *@
        @if (SelectedTool == BoardEditor.Tool.Arrow && _hoverElement is not null)
        {
            @RenderDockPoints(_hoverElement)
        }

        @* Arrow being drawn *@
        @if (_isDrawingArrow && _arrowStart is not null)
        {
            <line x1="@_arrowStart.Value.X" y1="@_arrowStart.Value.Y"
                  x2="@_currentMouse.X" y2="@_currentMouse.Y"
                  stroke="#6E40C9" stroke-width="2" stroke-dasharray="4"
                  marker-end="url(#arrowhead)" />
        }
    </svg>
</div>

@code {
    [Parameter] public Board? Board { get; set; }
    [Parameter] public bool CanEdit { get; set; }
    [Parameter] public CommandStack CommandStack { get; set; } = new();
    [Parameter] public EventCallback OnBoardChanged { get; set; }
    [Parameter] public BoardEditor.Tool SelectedTool { get; set; }

    public BoardElement? SelectedElement { get; private set; }
    private List<BoardElement> _multiSelected = [];

    private ViewBox _viewBox = new(0, 0, 1200, 800);
    private double _zoom = 1.0;

    private bool _isDragging;
    private bool _isPanning;
    private bool _isResizing;
    private bool _isLassoSelecting;
    private bool _isDrawingArrow;
    private int _resizeHandle = -1;
    private Point _dragStart;
    private Point _dragElementStart;
    private double _dragElementW, _dragElementH;
    private Point _lassoStart;
    private Point _lassoEnd;
    private Point _currentMouse;
    private Point? _arrowStart;
    private Guid? _arrowSourceId;
    private DockPoint _arrowSourceDock;
    private BoardElement? _hoverElement;

    private record struct ViewBox(double X, double Y, double W, double H);
    private record struct Point(double X, double Y);

    public void ClearSelection()
    {
        SelectedElement = null;
        _multiSelected.Clear();
    }

    private Point ScreenToSvg(double clientX, double clientY)
    {
        return new Point(
            _viewBox.X + clientX / _zoom * (_viewBox.W / (1200 / _zoom)),
            _viewBox.Y + clientY / _zoom * (_viewBox.H / (800 / _zoom))
        );
    }

    private Point ScreenToSvgSimple(MouseEventArgs e)
    {
        return new Point(
            _viewBox.X + e.OffsetX * (_viewBox.W / 1200.0 * _zoom),
            _viewBox.Y + e.OffsetY * (_viewBox.H / 800.0 * _zoom)
        );
    }

    private void OnCanvasMouseDown(MouseEventArgs e)
    {
        var svgPoint = ScreenToSvgSimple(e);
        _currentMouse = svgPoint;

        // Space+drag = pan
        if (e.Button == 1 || _isPanning)
        {
            _isPanning = true;
            _dragStart = new Point(e.ClientX, e.ClientY);
            return;
        }

        if (!CanEdit)
        {
            // In viewer mode, just select for inspection
            var clicked = HitTest(svgPoint);
            SelectedElement = clicked;
            return;
        }

        if (SelectedTool == BoardEditor.Tool.Select)
        {
            var clicked = HitTest(svgPoint);
            if (clicked is not null)
            {
                if (e.ShiftKey)
                {
                    if (!_multiSelected.Contains(clicked))
                        _multiSelected.Add(clicked);
                }
                else
                {
                    SelectedElement = clicked;
                    _multiSelected.Clear();
                }

                // Check if clicking on a resize handle
                var handle = HitTestResizeHandle(clicked, svgPoint);
                if (handle >= 0)
                {
                    _isResizing = true;
                    _resizeHandle = handle;
                    _dragStart = svgPoint;
                    _dragElementStart = new Point(clicked.X, clicked.Y);
                    _dragElementW = clicked.Width;
                    _dragElementH = clicked.Height;
                }
                else
                {
                    _isDragging = true;
                    _dragStart = svgPoint;
                    _dragElementStart = new Point(clicked.X, clicked.Y);
                }
            }
            else
            {
                SelectedElement = null;
                _multiSelected.Clear();
                // Start lasso selection
                _isLassoSelecting = true;
                _lassoStart = svgPoint;
                _lassoEnd = svgPoint;
            }
        }
        else if (SelectedTool == BoardEditor.Tool.Arrow)
        {
            var target = HitTest(svgPoint);
            if (target is not null)
            {
                _isDrawingArrow = true;
                _arrowSourceId = target.Id;
                _arrowSourceDock = GetClosestDockPoint(target, svgPoint);
                _arrowStart = GetDockPosition(target, _arrowSourceDock);
            }
        }
        else
        {
            // Creating a new element
            CreateElementAt(svgPoint);
        }
    }

    private void OnCanvasMouseMove(MouseEventArgs e)
    {
        var svgPoint = ScreenToSvgSimple(e);
        _currentMouse = svgPoint;

        if (_isPanning)
        {
            var dx = (e.ClientX - _dragStart.X) * _zoom;
            var dy = (e.ClientY - _dragStart.Y) * _zoom;
            _viewBox = _viewBox with
            {
                X = _viewBox.X - dx,
                Y = _viewBox.Y - dy
            };
            _dragStart = new Point(e.ClientX, e.ClientY);
            return;
        }

        if (_isDragging && SelectedElement is not null && CanEdit)
        {
            var dx = svgPoint.X - _dragStart.X;
            var dy = svgPoint.Y - _dragStart.Y;
            SelectedElement.X = _dragElementStart.X + dx;
            SelectedElement.Y = _dragElementStart.Y + dy;
        }

        if (_isResizing && SelectedElement is not null && CanEdit)
        {
            ApplyResize(SelectedElement, svgPoint);
        }

        if (_isLassoSelecting)
        {
            _lassoEnd = svgPoint;
        }

        if (SelectedTool == BoardEditor.Tool.Arrow && !_isDrawingArrow)
        {
            _hoverElement = HitTest(svgPoint);
        }
    }

    private async Task OnCanvasMouseUp(MouseEventArgs e)
    {
        var svgPoint = ScreenToSvgSimple(e);

        if (_isPanning)
        {
            _isPanning = false;
            return;
        }

        if (_isDragging && SelectedElement is not null && Board is not null)
        {
            var cmd = new MoveElementCommand(SelectedElement.Id, SelectedElement.X, SelectedElement.Y);
            // Already moved visually, just record
            _isDragging = false;
            await OnBoardChanged.InvokeAsync();
        }

        if (_isResizing && SelectedElement is not null && Board is not null)
        {
            _isResizing = false;
            _resizeHandle = -1;
            await OnBoardChanged.InvokeAsync();
        }

        if (_isLassoSelecting && Board is not null)
        {
            _isLassoSelecting = false;
            var minX = Math.Min(_lassoStart.X, _lassoEnd.X);
            var maxX = Math.Max(_lassoStart.X, _lassoEnd.X);
            var minY = Math.Min(_lassoStart.Y, _lassoEnd.Y);
            var maxY = Math.Max(_lassoStart.Y, _lassoEnd.Y);

            _multiSelected = Board.Elements.Where(el =>
                el.X >= minX && el.X + el.Width <= maxX &&
                el.Y >= minY && el.Y + el.Height <= maxY
            ).ToList();

            if (_multiSelected.Count == 1)
            {
                SelectedElement = _multiSelected[0];
                _multiSelected.Clear();
            }
        }

        if (_isDrawingArrow && Board is not null)
        {
            _isDrawingArrow = false;
            var target = HitTest(svgPoint);
            if (target is not null && _arrowSourceId is not null && target.Id != _arrowSourceId)
            {
                var targetDock = GetClosestDockPoint(target, svgPoint);
                var arrow = new ArrowElement
                {
                    SourceElementId = _arrowSourceId,
                    TargetElementId = target.Id,
                    SourceDock = _arrowSourceDock,
                    TargetDock = targetDock,
                    Width = 0,
                    Height = 0
                };
                var cmd = new AddElementCommand(arrow);
                CommandStack.Execute(Board, cmd);
                await OnBoardChanged.InvokeAsync();
            }
            _arrowStart = null;
            _arrowSourceId = null;
        }

        _isDragging = false;
    }

    private void OnWheel(WheelEventArgs e)
    {
        var factor = e.DeltaY > 0 ? 1.1 : 0.9;
        _zoom *= factor;
        _zoom = Math.Clamp(_zoom, 0.1, 10.0);

        var centerX = _viewBox.X + _viewBox.W / 2;
        var centerY = _viewBox.Y + _viewBox.H / 2;
        var newW = 1200 * _zoom;
        var newH = 800 * _zoom;
        _viewBox = new ViewBox(centerX - newW / 2, centerY - newH / 2, newW, newH);
    }

    private async Task CreateElementAt(Point pos)
    {
        if (Board is null) return;

        BoardElement element = SelectedTool switch
        {
            BoardEditor.Tool.Rectangle => new ShapeElement
            {
                X = pos.X, Y = pos.Y, Width = 150, Height = 100,
                ShapeType = ShapeType.Rectangle
            },
            BoardEditor.Tool.Ellipse => new ShapeElement
            {
                X = pos.X, Y = pos.Y, Width = 120, Height = 120,
                ShapeType = ShapeType.Ellipse
            },
            BoardEditor.Tool.Triangle => new ShapeElement
            {
                X = pos.X, Y = pos.Y, Width = 120, Height = 120,
                ShapeType = ShapeType.Triangle
            },
            BoardEditor.Tool.Text => new TextElement
            {
                X = pos.X, Y = pos.Y, Width = 200, Height = 40,
                Text = "Text"
            },
            _ => null!
        };

        if (element is null) return;

        element.ZIndex = Board.Elements.Count;
        var cmd = new AddElementCommand(element);
        CommandStack.Execute(Board, cmd);
        SelectedElement = element;
        await OnBoardChanged.InvokeAsync();
    }

    private BoardElement? HitTest(Point p)
    {
        if (Board is null) return null;

        // Check in reverse z-order (top first)
        foreach (var el in Board.Elements.OrderByDescending(e => e.ZIndex))
        {
            if (el is ArrowElement arrow)
            {
                // For arrows, check proximity to the line
                var source = Board.Elements.FirstOrDefault(e => e.Id == arrow.SourceElementId);
                var target = Board.Elements.FirstOrDefault(e => e.Id == arrow.TargetElementId);
                if (source is not null && target is not null)
                {
                    var sp = GetDockPosition(source, arrow.SourceDock);
                    var tp = GetDockPosition(target, arrow.TargetDock);
                    if (PointToLineDistance(p, sp, tp) < 8)
                        return el;
                }
                continue;
            }

            if (p.X >= el.X && p.X <= el.X + el.Width &&
                p.Y >= el.Y && p.Y <= el.Y + el.Height)
                return el;
        }
        return null;
    }

    private static double PointToLineDistance(Point p, Point a, Point b)
    {
        var dx = b.X - a.X;
        var dy = b.Y - a.Y;
        var len2 = dx * dx + dy * dy;
        if (len2 == 0) return Math.Sqrt((p.X - a.X) * (p.X - a.X) + (p.Y - a.Y) * (p.Y - a.Y));
        var t = Math.Clamp(((p.X - a.X) * dx + (p.Y - a.Y) * dy) / len2, 0, 1);
        var projX = a.X + t * dx;
        var projY = a.Y + t * dy;
        return Math.Sqrt((p.X - projX) * (p.X - projX) + (p.Y - projY) * (p.Y - projY));
    }

    private int HitTestResizeHandle(BoardElement el, Point p)
    {
        var handles = GetResizeHandles(el);
        for (int i = 0; i < handles.Length; i++)
        {
            var h = handles[i];
            if (Math.Abs(p.X - h.X) < 6 && Math.Abs(p.Y - h.Y) < 6)
                return i;
        }
        return -1;
    }

    private Point[] GetResizeHandles(BoardElement el)
    {
        var x = el.X; var y = el.Y; var w = el.Width; var h = el.Height;
        return
        [
            new(x, y), new(x + w / 2, y), new(x + w, y),
            new(x, y + h / 2), new(x + w, y + h / 2),
            new(x, y + h), new(x + w / 2, y + h), new(x + w, y + h)
        ];
    }

    private void ApplyResize(BoardElement el, Point current)
    {
        var dx = current.X - _dragStart.X;
        var dy = current.Y - _dragStart.Y;

        switch (_resizeHandle)
        {
            case 0: // Top-left
                el.X = _dragElementStart.X + dx;
                el.Y = _dragElementStart.Y + dy;
                el.Width = Math.Max(20, _dragElementW - dx);
                el.Height = Math.Max(20, _dragElementH - dy);
                break;
            case 1: // Top-center
                el.Y = _dragElementStart.Y + dy;
                el.Height = Math.Max(20, _dragElementH - dy);
                break;
            case 2: // Top-right
                el.Y = _dragElementStart.Y + dy;
                el.Width = Math.Max(20, _dragElementW + dx);
                el.Height = Math.Max(20, _dragElementH - dy);
                break;
            case 3: // Middle-left
                el.X = _dragElementStart.X + dx;
                el.Width = Math.Max(20, _dragElementW - dx);
                break;
            case 4: // Middle-right
                el.Width = Math.Max(20, _dragElementW + dx);
                break;
            case 5: // Bottom-left
                el.X = _dragElementStart.X + dx;
                el.Width = Math.Max(20, _dragElementW - dx);
                el.Height = Math.Max(20, _dragElementH + dy);
                break;
            case 6: // Bottom-center
                el.Height = Math.Max(20, _dragElementH + dy);
                break;
            case 7: // Bottom-right
                el.Width = Math.Max(20, _dragElementW + dx);
                el.Height = Math.Max(20, _dragElementH + dy);
                break;
        }
    }

    private DockPoint GetClosestDockPoint(BoardElement el, Point p)
    {
        var docks = new (DockPoint dp, Point pos)[]
        {
            (DockPoint.Top, new(el.X + el.Width / 2, el.Y)),
            (DockPoint.Bottom, new(el.X + el.Width / 2, el.Y + el.Height)),
            (DockPoint.Left, new(el.X, el.Y + el.Height / 2)),
            (DockPoint.Right, new(el.X + el.Width, el.Y + el.Height / 2)),
            (DockPoint.Center, new(el.X + el.Width / 2, el.Y + el.Height / 2))
        };

        return docks.MinBy(d => Math.Sqrt(
            Math.Pow(d.pos.X - p.X, 2) + Math.Pow(d.pos.Y - p.Y, 2)
        )).dp;
    }

    private Point GetDockPosition(BoardElement el, DockPoint dock) => dock switch
    {
        DockPoint.Top => new(el.X + el.Width / 2, el.Y),
        DockPoint.Bottom => new(el.X + el.Width / 2, el.Y + el.Height),
        DockPoint.Left => new(el.X, el.Y + el.Height / 2),
        DockPoint.Right => new(el.X + el.Width, el.Y + el.Height / 2),
        DockPoint.Center => new(el.X + el.Width / 2, el.Y + el.Height / 2),
        _ => new(el.X, el.Y)
    };

    private string GetCursor() => SelectedTool switch
    {
        BoardEditor.Tool.Select => _isDragging ? "grabbing" : "default",
        BoardEditor.Tool.Arrow => "crosshair",
        _ => "crosshair"
    };

    private RenderFragment RenderElement(BoardElement element) => element switch
    {
        ArrowElement arrow => RenderArrow(arrow),
        ShapeElement shape => RenderShape(shape),
        TextElement text => RenderText(text),
        StickyNoteElement sticky => RenderStickyNote(sticky),
        _ => builder => { }
    };

    private RenderFragment RenderShape(ShapeElement shape) => builder =>
    {
        var isSelected = SelectedElement?.Id == shape.Id || _multiSelected.Any(e => e.Id == shape.Id);
        builder.OpenElement(0, "g");
        builder.AddAttribute(1, "class", "board-element");

        switch (shape.ShapeType)
        {
            case ShapeType.Rectangle:
                builder.OpenElement(2, "rect");
                builder.AddAttribute(3, "x", shape.X);
                builder.AddAttribute(4, "y", shape.Y);
                builder.AddAttribute(5, "width", shape.Width);
                builder.AddAttribute(6, "height", shape.Height);
                builder.AddAttribute(7, "rx", 4);
                builder.AddAttribute(8, "fill", shape.FillColor);
                builder.AddAttribute(9, "stroke", isSelected ? "#6E40C9" : shape.StrokeColor);
                builder.AddAttribute(10, "stroke-width", isSelected ? shape.StrokeWidth + 1 : shape.StrokeWidth);
                builder.CloseElement();
                break;

            case ShapeType.Ellipse:
                builder.OpenElement(2, "ellipse");
                builder.AddAttribute(3, "cx", shape.X + shape.Width / 2);
                builder.AddAttribute(4, "cy", shape.Y + shape.Height / 2);
                builder.AddAttribute(5, "rx", shape.Width / 2);
                builder.AddAttribute(6, "ry", shape.Height / 2);
                builder.AddAttribute(7, "fill", shape.FillColor);
                builder.AddAttribute(8, "stroke", isSelected ? "#6E40C9" : shape.StrokeColor);
                builder.AddAttribute(9, "stroke-width", isSelected ? shape.StrokeWidth + 1 : shape.StrokeWidth);
                builder.CloseElement();
                break;

            case ShapeType.Triangle:
                var points = $"{shape.X + shape.Width / 2},{shape.Y} {shape.X},{shape.Y + shape.Height} {shape.X + shape.Width},{shape.Y + shape.Height}";
                builder.OpenElement(2, "polygon");
                builder.AddAttribute(3, "points", points);
                builder.AddAttribute(4, "fill", shape.FillColor);
                builder.AddAttribute(5, "stroke", isSelected ? "#6E40C9" : shape.StrokeColor);
                builder.AddAttribute(6, "stroke-width", isSelected ? shape.StrokeWidth + 1 : shape.StrokeWidth);
                builder.CloseElement();
                break;
        }

        builder.CloseElement();
    };

    private RenderFragment RenderText(TextElement text) => builder =>
    {
        var isSelected = SelectedElement?.Id == text.Id || _multiSelected.Any(e => e.Id == text.Id);
        builder.OpenElement(0, "g");
        builder.AddAttribute(1, "class", "board-element");

        // Background rect for text selection
        if (isSelected)
        {
            builder.OpenElement(2, "rect");
            builder.AddAttribute(3, "x", text.X - 2);
            builder.AddAttribute(4, "y", text.Y - 2);
            builder.AddAttribute(5, "width", text.Width + 4);
            builder.AddAttribute(6, "height", text.Height + 4);
            builder.AddAttribute(7, "fill", "none");
            builder.AddAttribute(8, "stroke", "#6E40C9");
            builder.AddAttribute(9, "stroke-width", 1);
            builder.AddAttribute(10, "stroke-dasharray", "4");
            builder.CloseElement();
        }

        builder.OpenElement(11, "text");
        builder.AddAttribute(12, "x", text.X);
        builder.AddAttribute(13, "y", text.Y + text.FontSize);
        builder.AddAttribute(14, "font-size", text.FontSize);
        builder.AddAttribute(15, "fill", text.Color);
        builder.AddAttribute(16, "font-weight", text.IsBold ? "bold" : "normal");
        builder.AddAttribute(17, "font-style", text.IsItalic ? "italic" : "normal");
        builder.AddAttribute(18, "font-family", "Inter, system-ui, sans-serif");
        // Escape text content for XSS prevention
        builder.AddContent(19, text.Text);
        builder.CloseElement();

        builder.CloseElement();
    };

    private RenderFragment RenderArrow(ArrowElement arrow) => builder =>
    {
        if (Board is null) return;
        var source = Board.Elements.FirstOrDefault(e => e.Id == arrow.SourceElementId);
        var target = Board.Elements.FirstOrDefault(e => e.Id == arrow.TargetElementId);
        if (source is null || target is null) return;

        var sp = GetDockPosition(source, arrow.SourceDock);
        var tp = GetDockPosition(target, arrow.TargetDock);
        var isSelected = SelectedElement?.Id == arrow.Id;

        builder.OpenElement(0, "line");
        builder.AddAttribute(1, "x1", sp.X);
        builder.AddAttribute(2, "y1", sp.Y);
        builder.AddAttribute(3, "x2", tp.X);
        builder.AddAttribute(4, "y2", tp.Y);
        builder.AddAttribute(5, "stroke", isSelected ? "#6E40C9" : arrow.StrokeColor);
        builder.AddAttribute(6, "stroke-width", arrow.StrokeWidth);
        builder.AddAttribute(7, "marker-end", "url(#arrowhead)");
        builder.CloseElement();
    };

    private RenderFragment RenderStickyNote(StickyNoteElement sticky) => builder =>
    {
        var isSelected = SelectedElement?.Id == sticky.Id;
        builder.OpenElement(0, "g");
        builder.OpenElement(1, "rect");
        builder.AddAttribute(2, "x", sticky.X);
        builder.AddAttribute(3, "y", sticky.Y);
        builder.AddAttribute(4, "width", sticky.Width);
        builder.AddAttribute(5, "height", sticky.Height);
        builder.AddAttribute(6, "rx", 4);
        builder.AddAttribute(7, "fill", sticky.BackgroundColor);
        builder.AddAttribute(8, "stroke", isSelected ? "#6E40C9" : "#e0d68a");
        builder.AddAttribute(9, "stroke-width", isSelected ? 2 : 1);
        builder.AddAttribute(10, "filter", "drop-shadow(2px 2px 4px rgba(0,0,0,0.15))");
        builder.CloseElement();

        builder.OpenElement(11, "text");
        builder.AddAttribute(12, "x", sticky.X + 8);
        builder.AddAttribute(13, "y", sticky.Y + sticky.FontSize + 8);
        builder.AddAttribute(14, "font-size", sticky.FontSize);
        builder.AddAttribute(15, "fill", "#333");
        builder.AddAttribute(16, "font-family", "Inter, system-ui, sans-serif");
        builder.AddContent(17, sticky.Text);
        builder.CloseElement();

        builder.CloseElement();
    };

    private RenderFragment RenderSelectionHandles(BoardElement el) => builder =>
    {
        if (el is ArrowElement) return;
        var handles = GetResizeHandles(el);
        for (int i = 0; i < handles.Length; i++)
        {
            builder.OpenElement(i * 10, "rect");
            builder.AddAttribute(i * 10 + 1, "x", handles[i].X - 4);
            builder.AddAttribute(i * 10 + 2, "y", handles[i].Y - 4);
            builder.AddAttribute(i * 10 + 3, "width", 8);
            builder.AddAttribute(i * 10 + 4, "height", 8);
            builder.AddAttribute(i * 10 + 5, "fill", "#ffffff");
            builder.AddAttribute(i * 10 + 6, "stroke", "#6E40C9");
            builder.AddAttribute(i * 10 + 7, "stroke-width", 1.5);
            builder.AddAttribute(i * 10 + 8, "rx", 2);
            builder.CloseElement();
        }
    };

    private RenderFragment RenderDockPoints(BoardElement el) => builder =>
    {
        var docks = new[]
        {
            GetDockPosition(el, DockPoint.Top),
            GetDockPosition(el, DockPoint.Bottom),
            GetDockPosition(el, DockPoint.Left),
            GetDockPosition(el, DockPoint.Right),
            GetDockPosition(el, DockPoint.Center)
        };

        for (int i = 0; i < docks.Length; i++)
        {
            builder.OpenElement(i * 5, "circle");
            builder.AddAttribute(i * 5 + 1, "cx", docks[i].X);
            builder.AddAttribute(i * 5 + 2, "cy", docks[i].Y);
            builder.AddAttribute(i * 5 + 3, "r", 5);
            builder.AddAttribute(i * 5 + 4, "fill", "#6E40C9");
            builder.AddAttribute(i * 5 + 5, "opacity", 0.7);
            builder.CloseElement();
        }
    };
}
