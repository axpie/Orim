@using Microsoft.AspNetCore.Components.Rendering
@using Orim.Web.Components.Pages
@using Orim.Web.Services
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject ThemeManager ThemeManager

<div id="whiteboard-surface"
     role="group"
     aria-label="@AriaLabel"
     aria-description="@AriaDescription"
     style="@GetSurfaceStyle()"
     @onmousedown="OnSurfaceMouseDown"
     @onmousemove="OnSurfaceMouseMove"
     @onmouseup="OnSurfaceMouseUp"
     @onmouseleave="OnSurfaceMouseLeave"
     @onwheel="OnSurfaceWheel"
     @onmousedown:preventDefault="true"
     @onwheel:preventDefault="true">

    <div style="@GetWorldStyle()">
        @if (Board is not null)
        {
            @foreach (var element in _sortedElements)
            {
                <div @key="element.Id">
                    @RenderElement(element)
                </div>
            }
        }

        @if (_draftShape is not null)
        {
            @RenderDraftShape(_draftShape)
        }

        @if (_draftArrow is not null)
        {
            @RenderDraftArrow(_draftArrow.Value)
        }

        @if (_activeAlignmentGuides.Count > 0)
        {
            @foreach (var guide in _activeAlignmentGuides)
            {
                <div style="@GetAlignmentGuideStyle(guide)"></div>
            }
        }

        @if (_isMarqueeSelecting)
        {
            <div style="@GetSelectionFrameStyle()"></div>
        }

        @if (CanEdit && (SelectedTool == BoardEditor.Tool.Arrow || _draftArrow is not null || _arrowEndpointDrag is not null))
        {
            @foreach (var handle in GetDockHandles())
            {
                <div style="@GetDockHandleStyle(handle)"></div>
            }
        }

        @if (GetSelectedNonArrowElements().Count > 1)
        {
            <div style="@GetSelectionOutlineStyle()"></div>
        }
        else
        {
            @foreach (var selectedElement in GetSelectedNonArrowElements())
            {
                <div style="@GetSingleSelectionOutlineStyle(selectedElement)"></div>

                @if (CanResizeSelectedElement && ReferenceEquals(selectedElement, SelectedElement))
                {
                    @foreach (var handle in GetResizeHandles(selectedElement))
                    {
                        <div style="@GetResizeHandleStyle(handle)"></div>
                    }
                }
            }
        }

        @if (CanEdit && SelectedTool == BoardEditor.Tool.Select && _selectedElements.Count == 1 && SelectedElement is ArrowElement selectedArrow)
        {
            @foreach (var handle in GetArrowEndpointHandles(selectedArrow))
            {
                <div style="@GetArrowEndpointHandleStyle(handle)"></div>
            }

            @if (GetArrowMiddleSegmentHandle(selectedArrow) is ArrowMiddleSegmentHandleDefinition middleHandle)
            {
                <div style="@GetArrowMiddleSegmentHandleStyle(middleHandle)"></div>
            }
        }
    </div>
</div>

@code {
    private const string SurfaceId = "whiteboard-surface";
    private const double MinimumRectangleSize = 12;
    private const double MinZoom = 0.2;
    private const double MaxZoom = 3.5;
    private const double ZoomStep = 1.1;
    private const double ResizeHandleScreenSize = 10;
    private const double ResizeHandleHitScreenSize = 16;
    private const double MinimumAutoLabelFontSize = 8;
    private const double MinimumLabelFontSize = 10;
    private const double MaximumLabelFontSize = 48;
    private const double ClickPanThreshold = 3;
    private const double DockSnapRadiusScreen = 28;
    private const double ElementAlignmentSnapThresholdScreen = 10;
    private const double StraightArrowAngleSnapStepDegrees = 45;
    private const double StraightArrowAngleSnapThresholdDegrees = 5;

    [Parameter] public Board? Board { get; set; }
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string? AriaDescription { get; set; }
    [Parameter] public bool CanEdit { get; set; }
    [Parameter] public EventCallback OnBoardChanged { get; set; }
    [Parameter] public EventCallback<BoardElement?> OnSelectedElementChanged { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<BoardElement>> OnSelectedElementsChanged { get; set; }
    [Parameter] public EventCallback<BoardEditor.Tool> OnToolChanged { get; set; }
    [Parameter] public EventCallback<int> OnZoomChanged { get; set; }
    [Parameter] public EventCallback OnElementDoubleTapped { get; set; }
    [Parameter] public string? PendingIconName { get; set; }
    [Parameter] public BoardEditor.Tool SelectedTool { get; set; }
    [Parameter] public double FitRightInset { get; set; }

    public BoardElement? SelectedElement => _selectedElements.LastOrDefault();

    private bool _isDraggingSelection;
    private bool _isDrawingRectangle;
    private bool _isMarqueeSelecting;
    private bool _isPanning;
    private bool _isResizingSelection;
    private bool _hasInteractionChanged;
    private bool _clearSelectionOnPanRelease;
    private bool _panExceededClickThreshold;
    private readonly List<BoardElement> _selectedElements = [];
    private readonly List<AlignmentGuide> _activeAlignmentGuides = [];
    private readonly Dictionary<Guid, Point> _dragStartPositions = [];
    private Point _drawStart;
    private Point _dragStartPointer;
    private Point _marqueeStart;
    private Point _marqueeCurrent;
    private Point _panStartScreen;
    private Point _panPointerOrigin;
    private Point _cameraOffset = new(0, 0);
    private Size _surfaceSize;
    private ShapeElement? _draftShape;
    private ArrowDraft? _draftArrow;
    private ArrowEndpointDrag? _arrowEndpointDrag;
    private ArrowMiddleSegmentDrag? _arrowMiddleSegmentDrag;
    private ArrowEndpointHandleDefinition? _hoverArrowEndpointHandle;
    private ArrowMiddleSegmentHandleDefinition? _hoverArrowMiddleSegmentHandle;
    private double _zoom = 1;
    private bool _hasInitializedViewport;
    private DotNetObjectReference<WhiteboardCanvas>? _selfRef;
    private SurfaceRect _surfaceRect;
    private Point _lastTouchWorldPoint;
    private DateTime _lastTapTime = DateTime.MinValue;
    private Guid? _lastTapElementId;
    private ResizeHandle _activeResizeHandle;
    private ResizeHandle _hoverResizeHandle;
    private ElementBounds _resizeStartBounds;

    private record struct Point(double X, double Y);
    private record struct Size(double Width, double Height);
    private record struct RelativePointer(double X, double Y, double Width, double Height);
    private record struct SurfaceRect(double Left, double Top, double Width, double Height);
    private record struct ElementBounds(double X, double Y, double Width, double Height);
    private record struct SelectionBounds(double Left, double Top, double Width, double Height);
    private record struct ResizeHandleDefinition(ResizeHandle Handle, Point Center);
    private record struct DockHandleDefinition(Guid ElementId, DockPoint DockPoint, Point Center, bool IsActive, bool IsTarget);
    private record struct ArrowDraft(Guid? SourceElementId, Point SourcePoint, DockPoint SourceDock, Guid? TargetElementId, DockPoint? TargetDock, Point Pointer);
    private record struct ArrowRenderData(IReadOnlyList<Point> Points, Point LabelPoint);
    private record struct ArrowEndpointHandleDefinition(bool IsSource, Point Center, bool IsActive);
    private record struct ArrowEndpointDrag(Guid ArrowId, bool IsSource, Guid? FixedElementId, Point FixedPoint, DockPoint FixedDock, Guid? HoverElementId, DockPoint? HoverDock, Point Pointer);
    private record struct ArrowMiddleSegmentHandleDefinition(bool IsVertical, Point Start, Point End, Point Center, bool IsActive);
    private record struct ArrowMiddleSegmentDrag(Guid ArrowId, bool IsVertical, double PointerOffset, double InitialCoordinate, double CurrentCoordinate);
    private record struct AlignmentGuide(bool IsVertical, double Coordinate, double Start, double End);
    private record struct AlignmentMatch(bool IsVertical, double Coordinate, double Start, double End, double Delta, double Distance);
    private record struct ResizeAlignmentMatch(bool IsVertical, double AppliedDelta, double Distance);
    private record struct RgbColor(byte R, byte G, byte B);

    private enum ResizeHandle
    {
        None,
        NorthWest,
        North,
        NorthEast,
        East,
        SouthEast,
        South,
        SouthWest,
        West
    }

    private IReadOnlyList<BoardElement> _sortedElements = [];
    private IReadOnlyList<BoardElement> _cachedSelectedNonArrow = [];

    private void InvalidateElementOrder()
    {
        _sortedElements = Board is not null
            ? Board.Elements.OrderBy(e => e.ZIndex).ToList()
            : [];
    }

    private void InvalidateSelectionCache()
    {
        _cachedSelectedNonArrow = _selectedElements
            .Where(e => e is not ArrowElement)
            .OrderBy(e => e.ZIndex).ToList();
    }

    private bool CanResizeSelectedElement => _selectedElements.Count == 1 && SelectedElement is not ArrowElement;

    private IReadOnlyList<BoardElement> GetSelectedNonArrowElements() => _cachedSelectedNonArrow;

    public void ClearSelection()
    {
        _ = SetSelectionAsync([]);
        StateHasChanged();
    }

    public void ForceRerender()
    {
        InvalidateElementOrder();
        InvalidateSelectionCache();
        StateHasChanged();
    }

    public async Task SelectElementAsync(BoardElement? element)
    {
        await SetSelectionAsync(element is null ? [] : ResolveSelectionScope(element));
        StateHasChanged();
    }

    public async Task SelectElementsAsync(IReadOnlyList<BoardElement> elements)
    {
        await SetSelectionAsync(elements);
        StateHasChanged();
    }

    public async Task ZoomInAsync()
    {
        await ApplyZoomAsync(_zoom * ZoomStep, GetSurfaceCenter());
    }

    public async Task ZoomOutAsync()
    {
        await ApplyZoomAsync(_zoom / ZoomStep, GetSurfaceCenter());
    }

    public async Task SetZoomPercentageAsync(int percentage)
    {
        var nextZoom = Math.Clamp(percentage / 100d, MinZoom, MaxZoom);
        await ApplyZoomAsync(nextZoom, GetSurfaceCenter());
    }

    public async Task FitToContentAsync()
    {
        await EnsureSurfaceSizeAsync();
        ApplyFitToContent();
        await NotifyZoomChangedAsync();
        StateHasChanged();
    }

    protected override void OnParametersSet()
    {
        InvalidateElementOrder();
        InvalidateSelectionCache();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("orimWhiteboard.registerTouchHandler", SurfaceId, _selfRef);
        }

        if (!_hasInitializedViewport && Board is not null)
        {
            await EnsureSurfaceSizeAsync();
            if (_surfaceSize.Width > 0 && _surfaceSize.Height > 0)
            {
                ApplyFitToContent();
                _hasInitializedViewport = true;
                await NotifyZoomChangedAsync();
                StateHasChanged();
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("orimWhiteboard.disposeTouchHandler");
        }
        catch (JSDisconnectedException) { }
        _selfRef?.Dispose();
    }

}
