{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    // Connection string for the local PostgreSQL container started by docker-compose.
    // Change only if you're using a custom database setup.
    "DefaultConnection": "Host=localhost;Port=5432;Database=orim;Username=orim;Password=orim_dev_password"
  },
  "Jwt": {
    // Must be at least 32 characters. Generate a random value, e.g.:
    //   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
    "Key": "REPLACE_WITH_A_RANDOM_SECRET_KEY_MIN_32_CHARS"
  },
  "SeedAdmin": {
    // Password for the local admin account. Reset on every debug start.
    "Password": "Admin123!",
    "ResetPasswordOnStartup": true
  },
  "Authentication": {
    "Microsoft": {
      "Enabled": false,
      "TenantId": "YOUR_ENTRA_TENANT_ID",
      "ClientId": "YOUR_ENTRA_CLIENT_ID",
      "Scopes": [ "openid", "profile", "email" ]
    },
    "Google": {
      "Enabled": false,
      "ClientId": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
      "HostedDomain": ""
    }
  },
  "Cors": {
    // Vite dev server origin. Add more if needed (e.g. http://localhost:4173 for vite preview).
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "Telemetry": {
    "Enabled": false
  }
}
